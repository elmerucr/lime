                            	   253: *
                            	   254: *******************************************************************
                            	   255: *
                            	   256: * What follows is the code to execute direct and statement
                            	   257: * commands. Control is transferred to these points via the command
                            	   258: * table lookup code of 'DIRECT' and 'EXEC' in the last section.
                            	   259: * After the command is executed, control is transferred to other
                            	   260: * sections as follows:
                            	   261: *
                            	   262: * For 'LIST', 'NEW', and 'STOP': go back to the warm start point.
                            	   263: * For 'RUN': go execute the first stored line if any; else go
                            	   264: * back to the warm start point.
                            	   265: * For 'GOTO' and 'GOSUB': go execute the target line.
                            	   266: * For 'RETURN' and 'NEXT'; go back to saved return line.
                            	   267: * For all others: if 'CURRNT' is 0, go to warm start; else go
                            	   268: * execute next command. (This is done in 'FINISH'.)
                            	   269: *
                            	   270: *******************************************************************
                            	   271: *
                            	   272: * *** NEW *** STOP *** RUN (& friends) *** GOTO ***
                            	   273: *
                            	   274: * 'NEW<CR>' sets TXTUNF to point to TXTBGN
                            	   275: *
                            	   276: * 'STOP<CR>' goes back to WSTART
                            	   277: *
                            	   278: * 'RUN<CR>' finds the first stored line, stores its address
                            	   279: * in CURRNT, and starts executing it. Note that only those
                            	   280: * commands in TAB2 are legal for a stored program.
                            	   281: *
                            	   282: * There are 3 more entries in 'RUN':
                            	   283: * 'RUNNXL' finds next line, stores it's address and executes it.
                            	   284: * 'RUNTSL' stores the address of this line and executes it.
                            	   285: * 'RUNSML' continues the execution on same line.
                            	   286: *
                            	   287: * 'GOTO expr<CR>' evaluates the expression, finds the target
                            	   288: * line, and jumps to 'RUNTSL' to do it.
                            	   289: *
00:00010B7A 61000714        	   290: NEW	BSR	ENDCHK
00:00010B7E 23F9000109360000	   291: 	MOVE.L	TXTBGN,TXTUNF	set the end pointer
00:00010B86 6142
                            	   292: 
00:00010B88 61000706        	   293: STOP	BSR	ENDCHK
00:00010B8C 6000FDE4        	   294: 	BRA	WSTART
                            	   295: 
00:00010B90 610006FE        	   296: RUN	BSR	ENDCHK
00:00010B94 207900010936    	   297: 	MOVE.L	TXTBGN,A0	set pointer to beginning
00:00010B9A 23C800006122    	   298: 	MOVE.L	A0,CURRNT
                            	   299: 
00:00010BA0 4AB900006122    	   300: RUNNXL	TST.L	CURRNT		executing a program?
00:00010BA6 6700FDCA        	   301: 	BEQ	WSTART		if not, we've finished a direct stat.
00:00010BAA 4281            	   302: 	CLR.L	D1		else find the next line number
00:00010BAC 2248            	   303: 	MOVE.L	A0,A1
00:00010BAE 61000814        	   304: 	BSR	FNDLNP
00:00010BB2 6500FDBE        	   305: 	BCS	WSTART		if we've fallen off the end, stop
                            	   306: 
00:00010BB6 23C900006122    	   307: RUNTSL	MOVE.L	A1,CURRNT	set CURRNT to point to the line no.
00:00010BBC 2049            	   308: 	MOVE.L	A1,A0		set the text pointer to
00:00010BBE 5488            	   309: 	ADDQ.L	#2,A0		the start of the line text
                            	   310: 
00:00010BC0 61000A74        	   311: RUNSML	BSR	CHKIO		see if a control-C was pressed
00:00010BC4 43F900010A36    	   312: 	LEA	TAB2,A1 	find command in TAB2
00:00010BCA 45F900010AA4    	   313: 	LEA	TAB2.1,A2
00:00010BD0 6000FF5A        	   314: 	BRA	EXEC		and execute it
                            	   315: 
00:00010BD4 610003FA        	   316: GOTO	BSR	EXPR		evaluate the following expression
00:00010BD8 610006B6        	   317: 	BSR	ENDCHK		must find end of line
00:00010BDC 2200            	   318: 	MOVE.L	D0,D1
00:00010BDE 610007D4        	   319: 	BSR	FNDLN		find the target line
00:00010BE2 6600070C        	   320: 	BNE	QHOW		no such line no.
00:00010BE6 6000FFCE        	   321: 	BRA	RUNTSL		go do it
