                            	   913: 
                            	   914: *
                            	   915: * ===== Multiplies the 32 bit values in D0 and D1, returning
                            	   916: *	the 32 bit result in D0.
                            	   917: *
00:000111A2 2801            	   918: MULT32	MOVE.L	D1,D4
00:000111A4 B184            	   919: 	EOR.L	D0,D4		see if the signs are the same
00:000111A6 4A80            	   920: 	TST.L	D0		take absolute value of D0
00:000111A8 6A000004        	   921: 	BPL	MLT1
00:000111AC 4480            	   922: 	NEG.L	D0
00:000111AE 4A81            	   923: MLT1	TST.L	D1		take absolute value of D1
00:000111B0 6A000004        	   924: 	BPL	MLT2
00:000111B4 4481            	   925: 	NEG.L	D1
00:000111B6 B2BC0000FFFF    	   926: MLT2	CMP.L	#$FFFF,D1	is second argument <= 16 bits?
00:000111BC 6300000E        	   927: 	BLS	MLT3		OK, let it through
00:000111C0 C141            	   928: 	EXG	D0,D1		else swap the two arguments
00:000111C2 B2BC0000FFFF    	   929: 	CMP.L	#$FFFF,D1	and check 2nd argument again
00:000111C8 62000168        	   930: 	BHI	QHOW		one of them MUST be 16 bits
00:000111CC 3400            	   931: MLT3	MOVE	D0,D2		prepare for 32 bit X 16 bit multiply
00:000111CE C4C1            	   932: 	MULU	D1,D2		multiply low word
00:000111D0 4840            	   933: 	SWAP	D0
00:000111D2 C0C1            	   934: 	MULU	D1,D0		multiply high word
00:000111D4 4840            	   935: 	SWAP	D0
                            	   936: *** Rick Murray's bug correction follows:
00:000111D6 4A40            	   937: 	TST	D0		if lower word not 0, then overflow
00:000111D8 66000158        	   938: 	BNE	QHOW		if overflow, say "How?"
00:000111DC D082            	   939: 	ADD.L	D2,D0		D0 now holds the product
00:000111DE 6B000152        	   940: 	BMI	QHOW		if sign bit set, it's an overflow
00:000111E2 4A84            	   941: 	TST.L	D4		were the signs the same?
00:000111E4 6A000004        	   942: 	BPL	MLTRET
00:000111E8 4480            	   943: 	NEG.L	D0		if not, make the result negative
00:000111EA 4E75            	   944: MLTRET	RTS
                            	   945: 
                            	   946: *
                            	   947: * ===== Divide the 32 bit value in D0 by the 32 bit value in D1.
                            	   948: *	Returns the 32 bit quotient in D0, remainder in D1.
                            	   949: *
00:000111EC 4A81            	   950: DIV32	TST.L	D1		check for divide-by-zero
00:000111EE 67000142        	   951: 	BEQ	QHOW		if so, say "How?"
00:000111F2 2401            	   952: 	MOVE.L	D1,D2
00:000111F4 2801            	   953: 	MOVE.L	D1,D4
00:000111F6 B184            	   954: 	EOR.L	D0,D4		see if the signs are the same
00:000111F8 4A80            	   955: 	TST.L	D0		take absolute value of D0
00:000111FA 6A000004        	   956: 	BPL	DIV1
00:000111FE 4480            	   957: 	NEG.L	D0
00:00011200 4A81            	   958: DIV1	TST.L	D1		take absolute value of D1
00:00011202 6A000004        	   959: 	BPL	DIV2
00:00011206 4481            	   960: 	NEG.L	D1
00:00011208 761F            	   961: DIV2	MOVEQ	#31,D3		iteration count for 32 bits
00:0001120A 2200            	   962: 	MOVE.L	D0,D1
00:0001120C 4280            	   963: 	CLR.L	D0
00:0001120E D281            	   964: DIV3	ADD.L	D1,D1		(This algorithm was translated from
00:00011210 D180            	   965: 	ADDX.L	D0,D0		the divide routine in Ron Cain's
00:00011212 6700000C        	   966: 	BEQ	DIV4		Small-C run time library.)
00:00011216 B082            	   967: 	CMP.L	D2,D0
00:00011218 6B000006        	   968: 	BMI	DIV4
00:0001121C 5281            	   969: 	ADDQ.L	#1,D1
00:0001121E 9082            	   970: 	SUB.L	D2,D0
00:00011220 51CBFFEC        	   971: DIV4	DBRA	D3,DIV3
00:00011224 C141            	   972: 	EXG	D0,D1		put rem. & quot. in proper registers
00:00011226 4A84            	   973: 	TST.L	D4		were the signs the same?
00:00011228 6A000006        	   974: 	BPL	DIVRT
00:0001122C 4480            	   975: 	NEG.L	D0		if not, results are negative
00:0001122E 4481            	   976: 	NEG.L	D1
00:00011230 4E75            	   977: DIVRT	RTS
                            	   978: 
                            	   979: *
                            	   980: * ===== The PEEK function returns the byte stored at the address
                            	   981: *	contained in the following expression.
                            	   982: *
00:00011232 6100FEFE        	   983: PEEK	BSR	PARN		get the memory address
00:00011236 2240            	   984: 	MOVE.L	D0,A1
00:00011238 4280            	   985: 	CLR.L	D0		upper 3 bytes will be zero
00:0001123A 1011            	   986: 	MOVE.B	(A1),D0 	get the addressed byte
00:0001123C 4E75            	   987: 	RTS			and return it
                            	   988: 
                            	   989: *
                            	   990: * ===== The RND function returns a random number from 1 to
                            	   991: *	the value of the following expression in D0.
                            	   992: *
00:0001123E 6100FEF2        	   993: RND	BSR	PARN		get the upper limit
00:00011242 4A80            	   994: 	TST.L	D0		it must be positive and non-zero
00:00011244 670000EC        	   995: 	BEQ	QHOW
00:00011248 6B0000E8        	   996: 	BMI	QHOW
00:0001124C 2200            	   997: 	MOVE.L	D0,D1
00:0001124E 22790000612A    	   998: 	MOVE.L	RANPNT,A1	get memory as a random number
00:00011254 B3FC0001171D    	   999: 	CMP.L	#LSTROM,A1
00:0001125A 65000008        	  1000: 	BCS	RA1
00:0001125E 43F90001095C    	  1001: 	LEA	START,A1	wrap around if end of program
00:00011264 2019            	  1002: RA1	MOVE.L	(A1)+,D0	get the slightly random number
00:00011266 0880001F        	  1003: 	BCLR	#31,D0		make sure it's positive
00:0001126A 23C90000612A    	  1004: 	MOVE.L	A1,RANPNT	(even I can do better than this!)
00:00011270 6100FF7A        	  1005: 	BSR	DIV32		RND(n)=MOD(number,n)+1
00:00011274 2001            	  1006: 	MOVE.L	D1,D0		MOD is the remainder of the div.
00:00011276 5280            	  1007: 	ADDQ.L	#1,D0
00:00011278 4E75            	  1008: 	RTS
                            	  1009: 
                            	  1010: *
                            	  1011: * ===== The ABS function returns an absolute value in D0.
                            	  1012: *
00:0001127A 6100FEB6        	  1013: ABS	BSR	PARN		get the following expr.'s value
00:0001127E 4A80            	  1014: 	TST.L	D0
00:00011280 6A000008        	  1015: 	BPL	ABSRT
00:00011284 4480            	  1016: 	NEG.L	D0		if negative, complement it
00:00011286 6B0000AA        	  1017: 	BMI	QHOW		if still negative, it was too big
00:0001128A 4E75            	  1018: ABSRT	RTS
                            	  1019: 
                            	  1020: *
                            	  1021: * ===== The SIZE function returns the size of free memory in D0.
                            	  1022: *
00:0001128C 203900006152    	  1023: SIZE	MOVE.L	VARBGN,D0	get the number of free bytes...
00:00011292 90B90000614E    	  1024: 	SUB.L	TXTUNF,D0	between 'TXTUNF' and 'VARBGN'
00:00011298 4E75            	  1025: 	RTS			return the number in D0
                            	  1026: 
                            	  1027: *
                            	  1028: *******************************************************************
                            	  1029: *
                            	  1030: * *** SETVAL *** FIN *** ENDCHK *** ERROR (& friends) ***
                            	  1031: *
                            	  1032: * 'SETVAL' expects a variable, followed by an equal sign and then
                            	  1033: * an expression.  It evaluates the expression and sets the variable
                            	  1034: * to that value.
                            	  1035: *
                            	  1036: * 'FIN' checks the end of a command.  If it ended with ":",
                            	  1037: * execution continues.	If it ended with a CR, it finds the
                            	  1038: * the next line and continues from there.
                            	  1039: *
                            	  1040: * 'ENDCHK' checks if a command is ended with a CR. This is
                            	  1041: * required in certain commands, such as GOTO, RETURN, STOP, etc.
                            	  1042: *
                            	  1043: * 'ERROR' prints the string pointed to by A0. It then prints the
                            	  1044: * line pointed to by CURRNT with a "?" inserted at where the
                            	  1045: * old text pointer (should be on top of the stack) points to.
                            	  1046: * Execution of Tiny BASIC is stopped and a warm start is done.
                            	  1047: * If CURRNT is zero (indicating a direct command), the direct
                            	  1048: * command is not printed. If CURRNT is -1 (indicating
                            	  1049: * 'INPUT' command in progress), the input line is not printed
                            	  1050: * and execution is not terminated but continues at 'INPERR'.
                            	  1051: *
                            	  1052: * Related to 'ERROR' are the following:
                            	  1053: * 'QWHAT' saves text pointer on stack and gets "What?" message.
                            	  1054: * 'AWHAT' just gets the "What?" message and jumps to 'ERROR'.
                            	  1055: * 'QSORRY' and 'ASORRY' do the same kind of thing.
                            	  1056: * 'QHOW' and 'AHOW' also do this for "How?".
                            	  1057: *
00:0001129A 6100FEAC        	  1058: SETVAL	BSR	TSTV		variable name?
00:0001129E 65000040        	  1059: 	BCS	QWHAT		if not, say "What?"
00:000112A2 2F00            	  1060: 	MOVE.L	D0,-(SP)	save the variable's address
00:000112A4 61000304        	  1061: 	BSR	TSTC		get past the "=" sign
00:000112A8 3D              	  1062: 	DC.B	'=',SV1-*
00:000112A9 0B
00:000112AA 6100FD66        	  1063: 	BSR	EXPR		evaluate the expression
00:000112AE 2C5F            	  1064: 	MOVE.L	(SP)+,A6
00:000112B0 2C80            	  1065: 	MOVE.L	D0,(A6) 	and save its value in the variable
00:000112B2 4E75            	  1066: 	RTS
00:000112B4 6000002A        	  1067: SV1	BRA	QWHAT		if no "=" sign
                            	  1068: 
00:000112B8 610002F0        	  1069: FIN	BSR	TSTC		*** FIN ***
00:000112BC 3A              	  1070: 	DC.B	':',FI1-*
00:000112BD 07
00:000112BE 588F            	  1071: 	ADDQ.L	#4,SP		if ":", discard return address
00:000112C0 6000F940        	  1072: 	BRA	RUNSML		continue on the same line
00:000112C4 610002E4        	  1073: FI1	BSR	TSTC		not ":", is it a CR?
00:000112C8 0A              	  1074: 	DC.B	LF,FI2-*
00:000112C9 07
00:000112CA 588F            	  1075: 	ADDQ.L	#4,SP		yes, purge return address
00:000112CC 6000F914        	  1076: 	BRA	RUNNXL		execute the next line
00:000112D0 4E75            	  1077: FI2	RTS			else return to the caller
                            	  1078: 
00:000112D2 61000330        	  1079: ENDCHK	BSR	IGNBLK
00:000112D6 0C10000A        	  1080: 	CMP.B	#LF,(A0)	does it end with a CR?
00:000112DA 66000004        	  1081: 	BNE	QWHAT		if not, say "WHAT?"
00:000112DE 4E75            	  1082: 	RTS
                            	  1083: 
00:000112E0 2F08            	  1084: QWHAT	MOVE.L	A0,-(SP)
00:000112E2 4DF90001170B    	  1085: AWHAT	LEA	WHTMSG,A6
00:000112E8 610003AA        	  1086: ERROR	BSR	PRMESG		display the error message
00:000112EC 205F            	  1087: 	MOVE.L	(SP)+,A0	restore the text pointer
00:000112EE 20390000612E    	  1088: 	MOVE.L	CURRNT,D0	get the current line number
00:000112F4 6700F6BE        	  1089: 	BEQ	WSTART		if zero, do a warm start
00:000112F8 B0BCFFFFFFFF    	  1090: 	CMP.L	#-1,D0		is the line no. pointer = -1?
00:000112FE 6700FB3A        	  1091: 	BEQ	INPERR		if so, redo input
00:00011302 1F10            	  1092: 	MOVE.B	(A0),-(SP)	save the char. pointed to
00:00011304 4210            	  1093: 	CLR.B	(A0)		put a zero where the error is
00:00011306 22790000612E    	  1094: 	MOVE.L	CURRNT,A1	point to start of current line
00:0001130C 61000280        	  1095: 	BSR	PRTLN		display the line in error up to the 0
00:00011310 109F            	  1096: 	MOVE.B	(SP)+,(A0)	restore the character
00:00011312 103C003F        	  1097: 	MOVE.B	#'?',D0         display a "?"
00:00011316 6100F64C        	  1098: 	BSR	GOOUT
00:0001131A 4240            	  1099: 	CLR	D0
00:0001131C 5389            	  1100: 	SUBQ.L	#1,A1		point back to the error char.
00:0001131E 61000186        	  1101: 	BSR	PRTSTG		display the rest of the line
00:00011322 6000F690        	  1102: 	BRA	WSTART		and do a warm start
00:00011326 2F08            	  1103: QSORRY	MOVE.L	A0,-(SP)
00:00011328 4DF900011713    	  1104: ASORRY	LEA	SRYMSG,A6
00:0001132E 6000FFB8        	  1105: 	BRA	ERROR
00:00011332 2F08            	  1106: QHOW	MOVE.L	A0,-(SP)	Error: "How?"
00:00011334 4DF900011704    	  1107: AHOW	LEA	HOWMSG,A6
00:0001133A 6000FFAC        	  1108: 	BRA	ERROR
                            	  1109: *
                            	  1110: *******************************************************************
                            	  1111: *
                            	  1112: * *** GETLN *** FNDLN (& friends) ***
                            	  1113: *
                            	  1114: * 'GETLN' reads in input line into 'BUFFER'. It first prompts with
                            	  1115: * the character in D0 (given by the caller), then it fills the
                            	  1116: * buffer and echos. It ignores LF's but still echos
                            	  1117: * them back. Control-H is used to delete the last character
                            	  1118: * entered (if there is one), and control-X is used to delete the
                            	  1119: * whole line and start over again. CR signals the end of a line,
                            	  1120: * and causes 'GETLN' to return.
                            	  1121: *
                            	  1122: * 'FNDLN' finds a line with a given line no. (in D1) in the
                            	  1123: * text save area.  A1 is used as the text pointer. If the line
                            	  1124: * is found, A1 will point to the beginning of that line
                            	  1125: * (i.e. the high byte of the line no.), and flags are NC & Z.
                            	  1126: * If that line is not there and a line with a higher line no.
                            	  1127: * is found, A1 points there and flags are NC & NZ. If we reached
                            	  1128: * the end of the text save area and cannot find the line, flags
                            	  1129: * are C & NZ.
                            	  1130: * 'FNDLN' will initialize A1 to the beginning of the text save
                            	  1131: * area to start the search. Some other entries of this routine
                            	  1132: * will not initialize A1 and do the search.
                            	  1133: * 'FNDLNP' will start with A1 and search for the line no.
                            	  1134: * 'FNDNXT' will bump A1 by 2, find a CR and then start search.
                            	  1135: * 'FNDSKP' uses A1 to find a CR, and then starts the search.
                            	  1136: *
00:0001133E 6100F624        	  1137: GETLN	BSR	GOOUT		display the prompt
00:00011342 103C0020        	  1138: 	MOVE.B	#' ',D0         and a space
00:00011346 6100F61C        	  1139: 	BSR	GOOUT
00:0001134A 41F90000615A    	  1140: 	LEA	BUFFER,A0	A0 is the buffer pointer
00:00011350 61000326        	  1141: GL1	BSR	CHKIO		check keyboard
00:00011354 6700FFFA        	  1142: 	BEQ	GL1		wait for a char. to come in
00:00011358 B03C0008        	  1143: 	CMP.B	#CTRLH,D0	delete last character?
00:0001135C 67000032        	  1144: 	BEQ	GL3		if so
00:00011360 B03C0018        	  1145: 	CMP.B	#CTRLX,D0	delete the whole line?
00:00011364 67000052        	  1146: 	BEQ	GL4		if so
00:00011368 B03C000A        	  1147: ja	CMP.B	#LF,D0		accept an LF
00:0001136C 6700000A        	  1148: 	BEQ	GL2
00:00011370 B03C0020        	  1149: 	CMP.B	#' ',D0         if other control char., discard it
00:00011374 6500FFDA        	  1150: 	BCS	GL1
00:00011378 10C0            	  1151: GL2	MOVE.B	D0,(A0)+	save the char.
00:0001137A 6100F5E8        	  1152: 	BSR	GOOUT		echo the char back out
00:0001137E B03C000A        	  1153: 	CMP.B	#LF,D0		if it's an LF, end the line
00:00011382 67000068        	  1154: 	BEQ	GL7
00:00011386 B1FC000061A9    	  1155: 	CMP.L	#(BUFFER+BUFLEN-1),A0	any more room?
00:0001138C 6500FFC2        	  1156: 	BCS	GL1		yes: get some more, else delete last char.
00:00011390 103C0008        	  1157: GL3	MOVE.B	#CTRLH,D0	delete a char. if possible
00:00011394 6100F5CE        	  1158: 	BSR	GOOUT
00:00011398 103C0020        	  1159: 	MOVE.B	#' ',D0
00:0001139C 6100F5C6        	  1160: 	BSR	GOOUT
00:000113A0 B1FC0000615A    	  1161: 	CMP.L	#BUFFER,A0	any char.'s left?
00:000113A6 6300FFA8        	  1162: 	BLS	GL1		if not
00:000113AA 103C0008        	  1163: 	MOVE.B	#CTRLH,D0	if so, finish the BS-space-BS sequence
00:000113AE 6100F5B4        	  1164: 	BSR	GOOUT
00:000113B2 5388            	  1165: 	SUBQ.L	#1,A0		decrement the text pointer
00:000113B4 6000FF9A        	  1166: 	BRA	GL1		back for more
00:000113B8 2208            	  1167: GL4	MOVE.L	A0,D1		delete the whole line
00:000113BA 92BC0000615A    	  1168: 	SUB.L	#BUFFER,D1	figure out how many backspaces we need
00:000113C0 67000020        	  1169: 	BEQ	GL6		if none needed, branch
00:000113C4 5341            	  1170: 	SUBQ	#1,D1		adjust for DBRA
00:000113C6 103C0008        	  1171: GL5	MOVE.B	#CTRLH,D0	and display BS-space-BS sequences
00:000113CA 6100F598        	  1172: 	BSR	GOOUT
00:000113CE 103C0020        	  1173: 	MOVE.B	#' ',D0
00:000113D2 6100F590        	  1174: 	BSR	GOOUT
00:000113D6 103C0008        	  1175: 	MOVE.B	#CTRLH,D0
00:000113DA 6100F588        	  1176: 	BSR	GOOUT
00:000113DE 51C9FFE6        	  1177: 	DBRA	D1,GL5
00:000113E2 41F90000615A    	  1178: GL6	LEA	BUFFER,A0	reinitialize the text pointer
00:000113E8 6000FF66        	  1179: 	BRA	GL1		and go back for more
00:000113EC 103C000A        	  1180: GL7	MOVE.B	#LF,D0		echo a LF for the CR
00:000113F0 6100F572        	  1181: 	BSR	GOOUT
00:000113F4 4E75            	  1182: 	RTS
                            	  1183: 
00:000113F6 B2BC0000FFFF    	  1184: FNDLN	CMP.L	#$FFFF,D1	line no. must be < 65535
00:000113FC 6400FF34        	  1185: 	BCC	QHOW
00:00011400 227900010978    	  1186: 	MOVE.L	TXTBGN,A1	init. the text save pointer
                            	  1187: 
00:00011406 24790000614E    	  1188: FNDLNP	MOVE.L	TXTUNF,A2	check if we passed the end
00:0001140C 538A            	  1189: 	SUBQ.L	#1,A2
00:0001140E B5C9            	  1190: 	CMP.L	A1,A2
00:00011410 65000010        	  1191: 	BCS	FNDRET		if so, return with Z=0 & C=1
00:00011414 1419            	  1192: 	MOVE.B	(A1)+,D2	if not, get a line no.
00:00011416 E14A            	  1193: 	LSL	#8,D2
00:00011418 1411            	  1194: 	MOVE.B	(A1),D2
00:0001141A 5389            	  1195: 	SUBQ.L	#1,A1
00:0001141C B481            	  1196: 	CMP.L	D1,D2		is this the line we want?
00:0001141E 65000004        	  1197: 	BCS	FNDNXT		no, not there yet
00:00011422 4E75            	  1198: FNDRET	RTS			return the cond. codes
                            	  1199: 
00:00011424 5489            	  1200: FNDNXT	ADDQ.L	#2,A1		find the next line
                            	  1201: 
00:00011426 0C19000A        	  1202: FNDSKP	CMP.B	#LF,(A1)+	try to find an LF
00:0001142A 6600FFFA        	  1203: 	BNE	FNDSKP		keep looking
00:0001142E 6000FFD6        	  1204: 	BRA	FNDLNP		check if end of text
                            	  1205: 
                            	  1206: *
                            	  1207: *******************************************************************
                            	  1208: *
                            	  1209: * *** MVUP *** MVDOWN *** POPA *** PUSHA ***
                            	  1210: *
                            	  1211: * 'MVUP' moves a block up from where A1 points to where A2 points
                            	  1212: * until A1=A3
                            	  1213: *
                            	  1214: * 'MVDOWN' moves a block down from where A1 points to where A3
                            	  1215: * points until A1=A2
                            	  1216: *
                            	  1217: * 'POPA' restores the 'FOR' loop variable save area from the stack
                            	  1218: *
                            	  1219: * 'PUSHA' stacks for 'FOR' loop variable save area onto the stack
                            	  1220: *
00:00011432 B7C9            	  1221: MVUP	CMP.L	A1,A3		see the above description
00:00011434 67000008        	  1222: 	BEQ	MVRET
