                            	  1526: * ===== Output character to the host (Port 2) from register D0
                            	  1527: *	(Preserves all registers.)
                            	  1528: *
                            	  1529: ;AUXOUT	BTST	#1,$10041	is port 2 ready for a character?
                            	  1530: ;	BEQ	AUXOUT		if not, wait for it
                            	  1531: ;	MOVE.B	D0,$10043	out it goes.
                            	  1532: ;	RTS
00:000116BC 48E7C0C0        	  1533: AUXOUT	movem.l	D0-D1/A0-A1,-(SP)
00:000116C0 1200            	  1534: 	move.b	D0,D1
00:000116C2 7001            	  1535: 	moveq	#1,D0
00:000116C4 4E4F            	  1536: 	trap	#15
00:000116C6 4CDF0303        	  1537: 	movem.l	(SP)+,D0-D1/A0-A1
