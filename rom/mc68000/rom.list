                            	   583: 
00:00010E4A 2F08            	   584: INPUT	MOVE.L	A0,-(SP)	save in case of error
00:00010E4C 61000678        	   585: 	BSR	QTSTG		is next item a string?
00:00010E50 600E            	   586: 	BRA.S	IP2		nope
00:00010E52 610002F4        	   587: 	BSR	TSTV		yes, but is it followed by a variable?
00:00010E56 6500005A        	   588: 	BCS	IP4		if not, branch
00:00010E5A 2440            	   589: 	MOVE.L	D0,A2		put away the variable's address
00:00010E5C 6000001C        	   590: 	BRA	IP3		if so, input to variable
00:00010E60 2F08            	   591: IP2	MOVE.L	A0,-(SP)	save for 'PRTSTG'
00:00010E62 610002E4        	   592: 	BSR	TSTV		must be a variable now
00:00010E66 65000478        	   593: 	BCS	QWHAT		"What?" it isn't?
00:00010E6A 2440            	   594: 	MOVE.L	D0,A2		put away the variable's address
00:00010E6C 1410            	   595: 	MOVE.B	(A0),D2 	get ready for 'PRTSTG'
00:00010E6E 4200            	   596: 	CLR.B	D0
00:00010E70 1080            	   597: 	MOVE.B	D0,(A0)
00:00010E72 225F            	   598: 	MOVE.L	(SP)+,A1
00:00010E74 61000630        	   599: 	BSR	PRTSTG		print string as prompt
00:00010E78 1082            	   600: 	MOVE.B	D2,(A0) 	restore text
00:00010E7A 2F08            	   601: IP3	MOVE.L	A0,-(SP)	save in case of error
