00:00002A32 9C98            	  5674: 	SUB.l		(a0)+,d6			* z = z - arctan(i)/2pi
00:00002A34 9083            	  5675: 	SUB.l		d3,d0				* x = x - y1
00:00002A36 D282            	  5676: 	ADD.l		d2,d1				* y = y + x1
