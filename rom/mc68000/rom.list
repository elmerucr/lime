                            	   718: *
                            	   719: *******************************************************************
                            	   720: *
                            	   721: * *** POKE *** & CALL ***
                            	   722: *
                            	   723: * 'POKE expr1,expr2' stores the byte from 'expr2' into the memory
                            	   724: * address specified by 'expr1'.
                            	   725: *
                            	   726: * 'CALL expr' jumps to the machine language subroutine whose
                            	   727: * starting address is specified by 'expr'.  The subroutine can use
                            	   728: * all registers but must leave the stack the way it found it.
                            	   729: * The subroutine returns to the interpreter by executing an RTS.
                            	   730: *
00:00010F9E 61000030        	   731: POKE	BSR	EXPR		get the memory address
00:00010FA2 610005C4        	   732: 	BSR	TSTC		it must be followed by a comma
00:00010FA6 2C              	   733: 	DC.B	',',PKER-*
00:00010FA7 0F
00:00010FA8 2F00            	   734: 	MOVE.L	D0,-(SP)	save the address
00:00010FAA 61000024        	   735: 	BSR	EXPR		get the byte to be POKE'd
00:00010FAE 225F            	   736: 	MOVE.L	(SP)+,A1	get the address back
00:00010FB0 1280            	   737: 	MOVE.B	D0,(A1) 	store the byte in memory
00:00010FB2 6000FCDA        	   738: 	BRA	FINISH
00:00010FB6 600002E6        	   739: PKER	BRA	QWHAT		if no comma, say "What?"
                            	   740: 
00:00010FBA 61000014        	   741: CALL	BSR	EXPR		get the subroutine's address
00:00010FBE 4A80            	   742: 	TST.L	D0		make sure we got a valid address
00:00010FC0 6700032E        	   743: 	BEQ	QHOW		if not, say "How?"
00:00010FC4 2F08            	   744: 	MOVE.L	A0,-(SP)	save the text pointer
00:00010FC6 2240            	   745: 	MOVE.L	D0,A1
00:00010FC8 4E91            	   746: 	JSR	(A1)		jump to the subroutine
00:00010FCA 205F            	   747: 	MOVE.L	(SP)+,A0	restore the text pointer
00:00010FCC 6000FCC0        	   748: 	BRA	FINISH
                            	   749: *
                            	   750: *******************************************************************
                            	   751: *
                            	   752: * *** EXPR ***
                            	   753: *
                            	   754: * 'EXPR' evaluates arithmetical or logical expressions.
                            	   755: * <EXPR>::=<EXPR2>
                            	   756: *	   <EXPR2><rel.op.><EXPR2>
                            	   757: * where <rel.op.> is one of the operators in TAB8 and the result
                            	   758: * of these operations is 1 if true and 0 if false.
                            	   759: * <EXPR2>::=(+ or -)<EXPR3>(+ or -)<EXPR3>(...
                            	   760: * where () are optional and (... are optional repeats.
                            	   761: * <EXPR3>::=<EXPR4>( <* or /><EXPR4> )(...
                            	   762: * <EXPR4>::=<variable>
                            	   763: *	    <function>
                            	   764: *	    (<EXPR>)
                            	   765: * <EXPR> is recursive so that the variable '@' can have an <EXPR>
                            	   766: * as an index, functions can have an <EXPR> as arguments, and
                            	   767: * <EXPR4> can be an <EXPR> in parenthesis.
                            	   768: *
00:00010FD0 6100007E        	   769: EXPR	BSR	EXPR2
00:00010FD4 2F00            	   770: 	MOVE.L	D0,-(SP)	save <EXPR2> value
00:00010FD6 43F900010A85    	   771: 	LEA	TAB8,A1 	look up a relational operator
00:00010FDC 45F900010B04    	   772: 	LEA	TAB8.1,A2
00:00010FE2 6000FB48        	   773: 	BRA	EXEC		go do it
                            	   774: 
00:00010FE6 61000056        	   775: XP11	BSR	XP18		is it ">="?
00:00010FEA 6D000046        	   776: 	BLT	XPRT0		no, return D0=0
00:00010FEE 60000046        	   777: 	BRA	XPRT1		else return D0=1
                            	   778: 
00:00010FF2 6100004A        	   779: XP12	BSR	XP18		is it "<>"?
00:00010FF6 6700003A        	   780: 	BEQ	XPRT0		no, return D0=0
00:00010FFA 6000003A        	   781: 	BRA	XPRT1		else return D0=1
                            	   782: 
00:00010FFE 6100003E        	   783: XP13	BSR	XP18		is it ">"?
00:00011002 6F00002E        	   784: 	BLE	XPRT0		no, return D0=0
00:00011006 6000002E        	   785: 	BRA	XPRT1		else return D0=1
                            	   786: 
00:0001100A 61000032        	   787: XP14	BSR	XP18		is it "<="?
00:0001100E 6E000022        	   788: 	BGT	XPRT0		no, return D0=0
00:00011012 60000022        	   789: 	BRA	XPRT1		else return D0=1
                            	   790: 
00:00011016 61000026        	   791: XP15	BSR	XP18		is it "="?
00:0001101A 66000016        	   792: 	BNE	XPRT0		if not, return D0=0
00:0001101E 60000016        	   793: 	BRA	XPRT1		else return D0=1
00:00011022 4E75            	   794: XP15RT	RTS
                            	   795: 
00:00011024 61000018        	   796: XP16	BSR	XP18		is it "<"?
00:00011028 6C000008        	   797: 	BGE	XPRT0		if not, return D0=0
00:0001102C 60000008        	   798: 	BRA	XPRT1		else return D0=1
00:00011030 4E75            	   799: XP16RT	RTS
                            	   800: 
00:00011032 4280            	   801: XPRT0	CLR.L	D0		return D0=0 (false)
00:00011034 4E75            	   802: 	RTS
                            	   803: 
