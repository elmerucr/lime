                            	   914: *
                            	   915: * ===== Multiplies the 32 bit values in D0 and D1, returning
                            	   916: *	the 32 bit result in D0.
                            	   917: *
00:0001118C 2801            	   918: MULT32	MOVE.L	D1,D4
00:0001118E B184            	   919: 	EOR.L	D0,D4		see if the signs are the same
00:00011190 4A80            	   920: 	TST.L	D0		take absolute value of D0
00:00011192 6A000004        	   921: 	BPL	MLT1
00:00011196 4480            	   922: 	NEG.L	D0
00:00011198 4A81            	   923: MLT1	TST.L	D1		take absolute value of D1
00:0001119A 6A000004        	   924: 	BPL	MLT2
00:0001119E 4481            	   925: 	NEG.L	D1
00:000111A0 B2BC0000FFFF    	   926: MLT2	CMP.L	#$FFFF,D1	is second argument <= 16 bits?
00:000111A6 6300000E        	   927: 	BLS	MLT3		OK, let it through
00:000111AA C141            	   928: 	EXG	D0,D1		else swap the two arguments
00:000111AC B2BC0000FFFF    	   929: 	CMP.L	#$FFFF,D1	and check 2nd argument again
00:000111B2 62000168        	   930: 	BHI	QHOW		one of them MUST be 16 bits
00:000111B6 3400            	   931: MLT3	MOVE	D0,D2		prepare for 32 bit X 16 bit multiply
00:000111B8 C4C1            	   932: 	MULU	D1,D2		multiply low word
00:000111BA 4840            	   933: 	SWAP	D0
00:000111BC C0C1            	   934: 	MULU	D1,D0		multiply high word
00:000111BE 4840            	   935: 	SWAP	D0
                            	   936: *** Rick Murray's bug correction follows:
00:000111C0 4A40            	   937: 	TST	D0		if lower word not 0, then overflow
00:000111C2 66000158        	   938: 	BNE	QHOW		if overflow, say "How?"
00:000111C6 D082            	   939: 	ADD.L	D2,D0		D0 now holds the product
00:000111C8 6B000152        	   940: 	BMI	QHOW		if sign bit set, it's an overflow
00:000111CC 4A84            	   941: 	TST.L	D4		were the signs the same?
00:000111CE 6A000004        	   942: 	BPL	MLTRET
00:000111D2 4480            	   943: 	NEG.L	D0		if not, make the result negative
00:000111D4 4E75            	   944: MLTRET	RTS
