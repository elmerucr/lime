                            	  5479: 							* if it went that far) need to be repeated
00:000028D8 7A03            	  5480: 	moveq		#3,d5				* 4 loops
00:000028DA 6136            	  5481: 	BSR.s		LAB_EXCC			* do loops 1 through 4
00:000028DC 5948            	  5482: 	SUBQ.w	#4,a0				* do table entry again
00:000028DE 5384            	  5483: 	SUBQ.l	#1,d4				* do shift count again
00:000028E0 7A09            	  5484: 	moveq		#9,d5				* 10 loops
00:000028E2 612E            	  5485: 	BSR.s		LAB_EXCC			* do loops 4 (again) through 13
00:000028E4 5948            	  5486: 	SUBQ.w	#4,a0				* do table entry again
00:000028E6 5384            	  5487: 	SUBQ.l	#1,d4				* do shift count again
00:000028E8 7A12            	  5488: 	moveq		#18,d5			* 19 loops
00:000028EA 6126            	  5489: 	BSR.s		LAB_EXCC			* do loops 13 (again) through 31
                            	  5490: 
                            	  5491: 							* now get the result
00:000028EC 4A2B05B4        	  5492: 	TST.b		cosout(a3)			* test sign flag
00:000028F0 6A06            	  5493: 	BPL.s		LAB_EXPL			* branch if +ve
                            	  5494: 
00:000028F2 4481            	  5495: 	NEG.l		d1				* do -y
00:000028F4 442B05D9        	  5496: 	NEG.b		tpower(a3)			* do -exp
                            	  5497: LAB_EXPL
00:000028F8 7083            	  5498: 	moveq		#$83-$100,d0		* set exponent
00:000028FA DC81            	  5499: 	ADD.l		d1,d6				* y = y +/- x
00:000028FC 6B06            	  5500: 	BMI.s		LAB_EXRN			* branch if result normal
                            	  5501: 
                            	  5502: LAB_EXNN
00:000028FE 5380            	  5503: 	SUBQ.l	#1,d0				* decrement exponent
00:00002900 DC86            	  5504: 	ADD.l		d6,d6				* shift mantissa
00:00002902 6AFA            	  5505: 	BPL.s		LAB_EXNN			* loop if not normal
                            	  5506: 
                            	  5507: LAB_EXRN
00:00002904 27460590        	  5508: 	move.l	d6,FAC1_m(a3)		* save exponent result
00:00002908 D02B05D9        	  5509: 	ADD.b		tpower(a3),d0		* add integer part
00:0000290C 17400594        	  5510: 	move.b	d0,FAC1_e(a3)		* save exponent
                            	  5511: **	movem.l	(sp)+,d1-d6/a0		* restore registers
00:00002910 4E75            	  5512: 	RTS
                            	  5513: 
                            	  5514: 							* cordic loop
                            	  5515: LAB_EXCC
00:00002912 5284            	  5516: 	ADDQ.l	#1,d4				* increment shift count
00:00002914 2406            	  5517: 	move.l	d6,d2				* x1 = x
00:00002916 E8A2            	  5518: 	ASR.l		d4,d2				* x1 >> n
00:00002918 2601            	  5519: 	move.l	d1,d3				* y1 = y
00:0000291A E8A3            	  5520: 	ASR.l		d4,d3				* y1 >> n
00:0000291C 4A80            	  5521: 	TST.l		d0				* test arg
00:0000291E 6B0C            	  5522: 	BMI.s		LAB_EXAD			* branch if -ve
                            	  5523: 
00:00002920 D282            	  5524: 	ADD.l		d2,d1				* y = y + x1
00:00002922 DC83            	  5525: 	ADD.l		d3,d6				* x = x + y1
00:00002924 9098            	  5526: 	SUB.l		(a0)+,d0			* arg = arg - atnh(a0)
00:00002926 51CDFFEA        	  5527: 	DBF		d5,LAB_EXCC			* decrement and loop if not done
                            	  5528: 
00:0000292A 4E75            	  5529: 	RTS
                            	  5530: 
                            	  5531: LAB_EXAD
00:0000292C 9282            	  5532: 	SUB.l		d2,d1				* y = y - x1
00:0000292E 9C83            	  5533: 	SUB.l		d3,d6				* x = x + y1
00:00002930 D098            	  5534: 	ADD.l		(a0)+,d0			* arg = arg + atnh(a0)
00:00002932 51CDFFDE        	  5535: 	DBF		d5,LAB_EXCC			* decrement and loop if not done
                            	  5536: 
00:00002936 4E75            	  5537: 	RTS
                            	  5538: 
                            	  5539: * RND(n), 32 bit Galois version. make n=0 for 19th next number in sequence or n<>0
                            	  5540: * to get 19th next number in sequence after seed n. This version of the PRNG uses
                            	  5541: * the Galois method and a sample of 65536 bytes produced gives the following values.
                            	  5542: 
                            	  5543: * Entropy = 7.997442 bits per byte
                            	  5544: * Optimum compression would reduce these 65536 bytes by 0 percent
                            	  5545: 
                            	  5546: * Chi square distribution for 65536 samples is 232.01, and
                            	  5547: * randomly would exceed this value 75.00 percent of the time
                            	  5548: 
                            	  5549: * Arithmetic mean value of data bytes is 127.6724, 127.5 would be random
                            	  5550: * Monte Carlo value for Pi is 3.122871269, error 0.60 percent
                            	  5551: * Serial correlation coefficient is -0.000370, totally uncorrelated would be 0.0
                            	  5552: 
                            	  5553: LAB_RND
00:00002938 4A2B0594        	  5554: 	TST.b		FAC1_e(a3)			* get FAC1 exponent
00:0000293C 6708            	  5555: 	BEQ.s		NextPRN			* do next random number if zero
                            	  5556: 
                            	  5557: 							* else get seed into random number store
00:0000293E 41EB05A0        	  5558: 	lea		PRNlword(a3),a0		* set PRNG pointer
00:00002942 6100FAA6        	  5559: 	BSR		LAB_2778			* pack FAC1 into (a0)
                            	  5560: NextPRN
00:00002946 72AF            	  5561: 	moveq		#$AF-$100,d1		* set EOR value
00:00002948 7412            	  5562: 	moveq		#18,d2			* do this 19 times
00:0000294A 202B05A0        	  5563: 	move.l	PRNlword(a3),d0		* get current
                            	  5564: Ninc0
00:0000294E D080            	  5565: 	ADD.l		d0,d0				* shift left 1 bit
00:00002950 6402            	  5566: 	BCC.s		Ninc1				* branch if bit 32 not set
                            	  5567: 
00:00002952 B300            	  5568: 	EOR.b		d1,d0				* do Galois LFSR feedback
                            	  5569: Ninc1
00:00002954 51CAFFF8        	  5570: 	DBF		d2,Ninc0			* loop
                            	  5571: 
00:00002958 274005A0        	  5572: 	move.l	d0,PRNlword(a3)		* save back to seed word
00:0000295C 27400590        	  5573: 	move.l	d0,FAC1_m(a3)		* copy to FAC1 mantissa
00:00002960 377C80000594    	  5574: 	MOVE.w	#$8000,FAC1_e(a3)		* set the exponent and clear the sign
00:00002966 6000F7DC        	  5575: 	BRA		LAB_24D5			* normalise FAC1 & return
                            	  5576: 
                            	  5577: * cordic TAN(x) routine, TAN(x) = SIN(x)/COS(x)
                            	  5578: * x = angle in radians
                            	  5579: 
                            	  5580: LAB_TAN
00:0000296A 6138            	  5581: 	BSR.s		LAB_SIN			* go do SIN/COS cordic compute
00:0000296C 376B0594059C    	  5582: 	MOVE.w	FAC1_e(a3),FAC2_e(a3)	* copy exponent & sign from FAC1 to FAC2
00:00002972 276B05900598    	  5583: 	move.l	FAC1_m(a3),FAC2_m(a3)	* copy FAC1 mantissa to FAC2 mantissa
00:00002978 27410590        	  5584: 	move.l	d1,FAC1_m(a3)		* get COS(x) mantissa
00:0000297C 17430594        	  5585: 	move.b	d3,FAC1_e(a3)		* get COS(x) exponent
00:00002980 6700E0B0        	  5586: 	BEQ		LAB_OFER			* do overflow if COS = 0
                            	  5587: 
00:00002984 6100F7BE        	  5588: 	BSR		LAB_24D5			* normalise FAC1
00:00002988 6000F974        	  5589: 	BRA		LAB_DIVIDE			* do FAC2/FAC1 and return, FAC_sc set by SIN
                            	  5590: 							* COS calculation
                            	  5591: 
                            	  5592: * cordic SIN(x), COS(x) routine
                            	  5593: * x = angle in radians
                            	  5594: 
                            	  5595: LAB_COS
00:0000298C 277CC90FDAA30598	  5596: 	move.l	#$C90FDAA3,FAC2_m(a3)	* pi/2 mantissa (LSB is rounded up so
                            	  5597: 							* COS(PI/2)=0)
00:00002994 377C8100059C    	  5598: 	MOVE.w	#$8100,FAC2_e(a3)		* pi/2 exponent and sign
00:0000299A 176B0595059E    	  5599: 	move.b	FAC1_s(a3),FAC_sc(a3)	* sign = FAC1 sign (b7)
00:000029A0 6100F726        	  5600: 	BSR		LAB_ADD			* add FAC2 to FAC1, adjust for COS(x)
                            	  5601: 
                            	  5602: * SIN/COS cordic calculator
                            	  5603: 
                            	  5604: LAB_SIN
00:000029A4 177C000005B4    	  5605: 	move.b	#0,cosout(a3)		* set needed result
                            	  5606: 
00:000029AA 277CA2F9836F0598	  5607: 	move.l	#$A2F9836F,FAC2_m(a3)	* 1/pi mantissa (LSB is rounded up so SIN(PI)=0)
00:000029B2 377C7F00059C    	  5608: 	MOVE.w	#$7F00,FAC2_e(a3)		* 1/pi exponent & sign
00:000029B8 176B0595059E    	  5609: 	move.b	FAC1_s(a3),FAC_sc(a3)	* sign = FAC1 sign (b7)
00:000029BE 6100F8AC        	  5610: 	BSR		LAB_MULTIPLY		* multiply by 1/pi
                            	  5611: 
00:000029C2 102B0594        	  5612: 	move.b	FAC1_e(a3),d0		* get FAC1 exponent
00:000029C6 67000022        	  5613: 	BEQ		LAB_SCZE			* branch if zero
                            	  5614: 
00:000029CA 41FA0804        	  5615: 	lea		(TAB_SNCO,PC),a0		* get pointer to constants table
00:000029CE 2C2B0590        	  5616: 	move.l	FAC1_m(a3),d6		* get FAC1 mantissa
00:000029D2 5300            	  5617: 	SUBQ.b	#1,d0				* 2 radians in 360 degrees so /2
00:000029D4 67000014        	  5618: 	BEQ		LAB_SCZE			* branch if zero
                            	  5619: 
00:000029D8 903C0080        	  5620: 	SUB.b		#$80,d0			* normalise exponent
00:000029DC 6B1A            	  5621: 	BMI.s		LAB_SCL0			* branch if < 1
                            	  5622: 
                            	  5623: 							* X is > 1
