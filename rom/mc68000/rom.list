                            	    51: ; ----------------------------------------------------------------------
                            	    52: ; Subroutine: b_get_number (number in decimal)
                            	    53: ; Inputs:     A0 points to text
                            	    54: ; Outputs:    D0.l contains the number (32 bits), D1 contains the number
                            	    55: ;             of digits (so is 0 when NAN)
                            	    56: ;             A0 remains (1) the same if NAN or (2) points to next char
                            	    57: ; ----------------------------------------------------------------------
                            	    58: b_get_number
00:0001092E 2F02            	    59: 	move.l	D2,-(SP)
00:00010930 4280            	    60: 	clr.l	D0		; will contain end result
00:00010932 4281            	    61: 	clr.l	D1		; is zero if NAN
00:00010934 0C100030        	    62: .start	cmp.b	#'0',(A0)
00:00010938 65000022        	    63: 	blo	.end
00:0001093C 0C100039        	    64: 	cmp.b	#'9',(A0)
00:00010940 6200001A        	    65: 	bhi	.end
