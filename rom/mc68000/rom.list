                            	   367: 
                            	   368: *##LAB_GMEM
00:0000098A 7000            	   369: 	moveq	#$00,d0			* clear d0
00:0000098C 174005E4        	   370: 	move.b	d0,Nullct(a3)		* default NULL count
00:00000990 174005E5        	   371: 	move.b	d0,TPos(a3)		* clear terminal position
