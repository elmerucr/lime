                            	  6402: LAB_CHX2
00:00002ED8 D281            	  6403: 	ADD.l		d1,d1				* shift mantissa
00:00002EDA 5BCBFFFC        	  6404: 	DBMI		d3,LAB_CHX2			* decrement & loop if not normalised
                            	  6405: 
