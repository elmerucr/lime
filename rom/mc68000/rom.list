                            	  1254: *
                            	  1255: *******************************************************************
                            	  1256: *
                            	  1257: * *** PRTSTG *** QTSTG *** PRTNUM *** PRTLN ***
                            	  1258: *
                            	  1259: * 'PRTSTG' prints a string pointed to by A1. It stops printing
                            	  1260: * and returns to the caller when either a CR is printed or when
                            	  1261: * the next byte is the same as what was passed in D0 by the
                            	  1262: * caller.
                            	  1263: *
                            	  1264: * 'QTSTG' looks for an underline (back-arrow on some systems),
                            	  1265: * single-quote, or double-quote.  If none of these are found, returns
                            	  1266: * to the caller.  If underline, outputs a CR without a LF.  If single
                            	  1267: * or double quote, prints the quoted string and demands a matching
                            	  1268: * end quote.  After the printing, the next 2 bytes of the caller are
                            	  1269: * skipped over (usually a short branch instruction).
                            	  1270: *
                            	  1271: * 'PRTNUM' prints the 32 bit number in D1, leading blanks are added if
                            	  1272: * needed to pad the number of spaces to the number in D4.
                            	  1273: * However, if the number of digits is larger than the no. in
                            	  1274: * D4, all digits are printed anyway. Negative sign is also
                            	  1275: * printed and counted in, positive sign is not.
                            	  1276: *
                            	  1277: * 'PRTLN' prints the saved text line pointed to by A1
                            	  1278: * with line no. and all.
                            	  1279: *
00:000114A8 1200            	  1280: PRTSTG	MOVE.B	D0,D1		save the stop character
00:000114AA 1019            	  1281: PS1	MOVE.B	(A1)+,D0	get a text character
00:000114AC B200            	  1282: 	CMP.B	D0,D1		same as stop character?
00:000114AE 67000016        	  1283: 	BEQ	PRTRET		if so, return
00:000114B2 6100F4B2        	  1284: 	BSR	GOOUT		display the char.
00:000114B6 B03C000A        	  1285: 	CMP.B	#LF,D0		is it a C.R.?
00:000114BA 6600FFEE        	  1286: 	BNE	PS1		no, go back for more
00:000114BE 103C000A        	  1287: 	MOVE.B	#LF,D0		yes, add a L.F.
00:000114C2 6100F4A2        	  1288: 	BSR	GOOUT
00:000114C6 4E75            	  1289: PRTRET	RTS			then return
                            	  1290: 
00:000114C8 610000E2        	  1291: QTSTG	BSR	TSTC		*** QTSTG ***
00:000114CC 22              	  1292: 	DC.B	'"',QT3-*
00:000114CD 1B
00:000114CE 103C0022        	  1293: 	MOVE.B	#'"',D0         it is a "
00:000114D2 2248            	  1294: QT1	MOVE.L	A0,A1
00:000114D4 6100FFD2        	  1295: 	BSR	PRTSTG		print until another
00:000114D8 2049            	  1296: 	MOVE.L	A1,A0
00:000114DA 225F            	  1297: 	MOVE.L	(SP)+,A1	pop return address
00:000114DC B03C000A        	  1298: 	CMP.B	#LF,D0		was last one a CR?
00:000114E0 6700F702        	  1299: 	BEQ	RUNNXL		if so, run next line
00:000114E4 5489            	  1300: QT2	ADDQ.L	#2,A1		skip 2 bytes on return
00:000114E6 4ED1            	  1301: 	JMP	(A1)		return
00:000114E8 610000C2        	  1302: QT3	BSR	TSTC		is it a single quote?
00:000114EC 27              	  1303: 	DC.B	'''',QT4-*
00:000114ED 09
00:000114EE 103C0027        	  1304: 	MOVE.B	#'''',D0        if so, do same as above
00:000114F2 6000FFDE        	  1305: 	BRA	QT1
00:000114F6 610000B4        	  1306: QT4	BSR	TSTC		is it an underline?
00:000114FA 5F              	  1307: 	DC.B	'_',QT5-*
00:000114FB 0F
00:000114FC 103C000D        	  1308: 	MOVE.B	#CR,D0		if so, output a CR without LF
00:00011500 6100F464        	  1309: 	BSR	GOOUT
00:00011504 225F            	  1310: 	MOVE.L	(SP)+,A1	pop return address
00:00011506 6000FFDC        	  1311: 	BRA	QT2
00:0001150A 4E75            	  1312: QT5	RTS			none of the above
                            	  1313: 
00:0001150C 2601            	  1314: PRTNUM	MOVE.L	D1,D3		save the number for later
00:0001150E 3F04            	  1315: 	MOVE	D4,-(SP)	save the width value
00:00011510 1F3C00FF        	  1316: 	MOVE.B	#$FF,-(SP)	flag for end of digit string
00:00011514 4A81            	  1317: 	TST.L	D1		is it negative?
00:00011516 6A000006        	  1318: 	BPL	PN1		if not
00:0001151A 4481            	  1319: 	NEG.L	D1		else make it positive
00:0001151C 5344            	  1320: 	SUBQ	#1,D4		one less for width count
00:0001151E 82FC000A        	  1321: PN1	DIVU	#10,D1		get the next digit
00:00011522 6900000E        	  1322: 	BVS	PNOV		overflow flag set?
00:00011526 2001            	  1323: 	MOVE.L	D1,D0		if not, save remainder
00:00011528 C2BC0000FFFF    	  1324: 	AND.L	#$FFFF,D1	strip the remainder
00:0001152E 6000001C        	  1325: 	BRA	TOASCII 	skip the overflow stuff
00:00011532 3001            	  1326: PNOV	MOVE	D1,D0		prepare for long word division
00:00011534 4241            	  1327: 	CLR.W	D1		zero out low word
00:00011536 4841            	  1328: 	SWAP	D1		high word into low
00:00011538 82FC000A        	  1329: 	DIVU	#10,D1		divide high word
00:0001153C 3401            	  1330: 	MOVE	D1,D2		save quotient
00:0001153E 3200            	  1331: 	MOVE	D0,D1		low word into low
00:00011540 82FC000A        	  1332: 	DIVU	#10,D1		divide low word
00:00011544 2001            	  1333: 	MOVE.L	D1,D0		D0 = remainder
00:00011546 4841            	  1334: 	SWAP	D1		R/Q becomes Q/R
00:00011548 3202            	  1335: 	MOVE	D2,D1		D1 is low/high
00:0001154A 4841            	  1336: 	SWAP	D1		D1 is finally high/low
00:0001154C 4840            	  1337: TOASCII SWAP	D0		get remainder
00:0001154E 1F00            	  1338: 	MOVE.B	D0,-(SP)	stack it as a digit
00:00011550 4840            	  1339: 	SWAP	D0
00:00011552 5344            	  1340: 	SUBQ	#1,D4		decrement width count
00:00011554 4A81            	  1341: 	TST.L	D1		if quotient is zero, we're done
00:00011556 6600FFC6        	  1342: 	BNE	PN1
00:0001155A 5344            	  1343: 	SUBQ	#1,D4		adjust padding count for DBRA
00:0001155C 6B00000E        	  1344: 	BMI	PN4		skip padding if not needed
00:00011560 103C0020        	  1345: PN3	MOVE.B	#' ',D0         display the required leading spaces
00:00011564 6100F400        	  1346: 	BSR	GOOUT
00:00011568 51CCFFF6        	  1347: 	DBRA	D4,PN3
00:0001156C 4A83            	  1348: PN4	TST.L	D3		is number negative?
00:0001156E 6A00000A        	  1349: 	BPL	PN5
00:00011572 103C002D        	  1350: 	MOVE.B	#'-',D0         if so, display the sign
00:00011576 6100F3EE        	  1351: 	BSR	GOOUT
00:0001157A 101F            	  1352: PN5	MOVE.B	(SP)+,D0	now unstack the digits and display
00:0001157C 6B00000E        	  1353: 	BMI	PNRET		until the flag code is reached
00:00011580 D03C0030        	  1354: 	ADD.B	#'0',D0         make into ASCII
00:00011584 6100F3E0        	  1355: 	BSR	GOOUT
00:00011588 6000FFF0        	  1356: 	BRA	PN5
00:0001158C 381F            	  1357: PNRET	MOVE	(SP)+,D4	restore width value
00:0001158E 4E75            	  1358: 	RTS
