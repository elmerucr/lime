00:00011116 6600002C        	   889: 	BNE	TV1		branch if not "@" array
00:0001111A 5248            	   890: 	ADDQ	#1,A0		If it is, it should be
00:0001111C 6100FFD2        	   891: 	BSR	PARN		followed by (EXPR) as its index.
00:00011120 D080            	   892: 	ADD.L	D0,D0
00:00011122 650001CC        	   893: 	BCS	QHOW		say "How?" if index is too big
00:00011126 D080            	   894: 	ADD.L	D0,D0
00:00011128 650001C6        	   895: 	BCS	QHOW
