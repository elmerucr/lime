00:000029E2 64000006        	  5625: 	BCC		LAB_SCZE			* may as well do zero
                            	  5626: 
00:000029E6 E1AE            	  5627: 	LSL.l		d0,d6				* shift out integer part bits
00:000029E8 6618            	  5628: 	BNE.s		LAB_CORD			* if fraction go test quadrant and adjust
                            	  5629: 
                            	  5630: 							* else no fraction so do zero
                            	  5631: LAB_SCZE
00:000029EA 7481            	  5632: 	moveq		#$81-$100,d2		* set exponent for 1.0
00:000029EC 7600            	  5633: 	moveq		#0,d3				* set exponent for 0.0
00:000029EE 203C80000000    	  5634: 	move.l	#$80000000,d0		* mantissa for 1.0
00:000029F4 2203            	  5635: 	move.l	d3,d1				* mantissa for 0.0
00:000029F6 6062            	  5636: 	BRA.s		outloop			* go output it
                            	  5637: 
                            	  5638: 							* x is < 1
                            	  5639: LAB_SCL0
00:000029F8 4400            	  5640: 	NEG.b		d0				* make +ve
00:000029FA B03C001E        	  5641: 	CMP.b		#$1E,d0			* is it <= 2^-30
00:000029FE 64EA            	  5642: 	BCC.s		LAB_SCZE			* may as well do zero
                            	  5643: 
00:00002A00 E0AE            	  5644: 	LSR.l		d0,d6				* shift out <= 2^-32 bits
                            	  5645: 
                            	  5646: * cordic calculator, argument in d6
                            	  5647: * table pointer in a0, returns in d0-d3
                            	  5648: 
                            	  5649: LAB_CORD
00:00002A02 176B0595059E    	  5650: 	move.b	FAC1_s(a3),FAC_sc(a3)	* copy as sign compare for TAN
00:00002A08 DC86            	  5651: 	ADD.l		d6,d6				* shift 0.5 bit into carry
00:00002A0A 6406            	  5652: 	BCC.s		LAB_LTPF			* branch if less than 0.5
                            	  5653: 
00:00002A0C 0A2B00FF0595    	  5654: 	EORI.b	#$FF,FAC1_s(a3)		* toggle result sign
                            	  5655: LAB_LTPF
00:00002A12 DC86            	  5656: 	ADD.l		d6,d6				* shift 0.25 bit into carry
00:00002A14 640C            	  5657: 	BCC.s		LAB_LTPT			* branch if less than 0.25
                            	  5658: 
00:00002A16 0A2B00FF05B4    	  5659: 	EORI.b	#$FF,cosout(a3)		* toggle needed result
00:00002A1C 0A2B00FF059E    	  5660: 	EORI.b	#$FF,FAC_sc(a3)		* toggle sign compare for TAN
                            	  5661: 
