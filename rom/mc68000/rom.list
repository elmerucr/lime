00:00002A26 7A01            	  5667: 	moveq		#1,d5				* set bit count
00:00002A28 2028FFFC        	  5668: 	move.l	-4(a0),d0			* get multiply constant (1st itteration d0)
00:00002A2C 2200            	  5669: 	move.l	d0,d1				* 1st itteration d1
00:00002A2E 9C98            	  5670: 	SUB.l		(a0)+,d6			* 1st always +ve so do 1st step
00:00002A30 6008            	  5671: 	BRA.s		mainloop			* jump into routine
                            	  5672: 
