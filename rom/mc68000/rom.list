                            	  1371: *
                            	  1372: * ===== Test text byte following the call to this subroutine. If it
                            	  1373: *	equals the byte pointed to by A0, return to the code following
                            	  1374: *	the call. If they are not equal, branch to the point
                            	  1375: *	indicated by the offset byte following the text byte.
                            	  1376: *
00:000115AC 61000058        	  1377: TSTC	BSR	IGNBLK		ignore leading blanks
00:000115B0 225F            	  1378: 	MOVE.L	(SP)+,A1	get the return address
00:000115B2 1219            	  1379: 	MOVE.B	(A1)+,D1	get the byte to compare
00:000115B4 B210            	  1380: 	CMP.B	(A0),D1 	is it = to what A0 points to?
00:000115B6 6700000A        	  1381: 	BEQ	TC1		if so
00:000115BA 4281            	  1382: 	CLR.L	D1		If not, add the second
00:000115BC 1211            	  1383: 	MOVE.B	(A1),D1 	byte following the call to
00:000115BE D3C1            	  1384: 	ADD.L	D1,A1		the return address.
00:000115C0 4ED1            	  1385: 	JMP	(A1)		jump to the routine
00:000115C2 5288            	  1386: TC1	ADDQ.L	#1,A0		if equal, bump text pointer
00:000115C4 5289            	  1387: 	ADDQ.L	#1,A1		Skip the 2 bytes following
00:000115C6 4ED1            	  1388: 	JMP	(A1)		the call and continue.
                            	  1389: 
                            	  1390: *
                            	  1391: * ===== See if the text pointed to by A0 is a number. If so,
                            	  1392: *	return the number in D1 and the number of digits in D2,
                            	  1393: *	else return zero in D1 and D2.
                            	  1394: *
00:000115C8 4281            	  1395: TSTNUM	CLR.L	D1		initialize return parameters
00:000115CA 4242            	  1396: 	CLR	D2
00:000115CC 61000038        	  1397: 	BSR	IGNBLK		skip over blanks
00:000115D0 0C100030        	  1398: TN1	CMP.B	#'0',(A0)       is it less than zero?
00:000115D4 6500002E        	  1399: 	BCS	TSNMRET 	if so, that's all
00:000115D8 0C100039        	  1400: 	CMP.B	#'9',(A0)       is it greater than nine?
00:000115DC 62000026        	  1401: 	BHI	TSNMRET 	if so, return
00:000115E0 B2BC0CCCCCCC    	  1402: 	CMP.L	#214748364,D1	see if there's room for new digit
00:000115E6 6400FD4C        	  1403: 	BCC	QHOW		if not, we've overflowd
00:000115EA 2001            	  1404: 	MOVE.L	D1,D0		quickly multiply result by 10
00:000115EC D281            	  1405: 	ADD.L	D1,D1
00:000115EE D281            	  1406: 	ADD.L	D1,D1
00:000115F0 D280            	  1407: 	ADD.L	D0,D1
00:000115F2 D281            	  1408: 	ADD.L	D1,D1
00:000115F4 1018            	  1409: 	MOVE.B	(A0)+,D0	add in the new digit
00:000115F6 C0BC0000000F    	  1410: 	AND.L	#$F,D0
00:000115FC D280            	  1411: 	ADD.L	D0,D1
00:000115FE 5242            	  1412: 	ADDQ	#1,D2		increment the no. of digits
00:00011600 6000FFCE        	  1413: 	BRA	TN1
00:00011604 4E75            	  1414: TSNMRET RTS
