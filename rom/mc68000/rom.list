                            	  1027: *
                            	  1028: *******************************************************************
                            	  1029: *
                            	  1030: * *** SETVAL *** FIN *** ENDCHK *** ERROR (& friends) ***
                            	  1031: *
                            	  1032: * 'SETVAL' expects a variable, followed by an equal sign and then
                            	  1033: * an expression.  It evaluates the expression and sets the variable
                            	  1034: * to that value.
                            	  1035: *
                            	  1036: * 'FIN' checks the end of a command.  If it ended with ":",
                            	  1037: * execution continues.	If it ended with a CR, it finds the
                            	  1038: * the next line and continues from there.
                            	  1039: *
                            	  1040: * 'ENDCHK' checks if a command is ended with a CR. This is
                            	  1041: * required in certain commands, such as GOTO, RETURN, STOP, etc.
                            	  1042: *
                            	  1043: * 'ERROR' prints the string pointed to by A0. It then prints the
                            	  1044: * line pointed to by CURRNT with a "?" inserted at where the
                            	  1045: * old text pointer (should be on top of the stack) points to.
                            	  1046: * Execution of Tiny BASIC is stopped and a warm start is done.
                            	  1047: * If CURRNT is zero (indicating a direct command), the direct
                            	  1048: * command is not printed. If CURRNT is -1 (indicating
                            	  1049: * 'INPUT' command in progress), the input line is not printed
                            	  1050: * and execution is not terminated but continues at 'INPERR'.
                            	  1051: *
                            	  1052: * Related to 'ERROR' are the following:
                            	  1053: * 'QWHAT' saves text pointer on stack and gets "What?" message.
                            	  1054: * 'AWHAT' just gets the "What?" message and jumps to 'ERROR'.
                            	  1055: * 'QSORRY' and 'ASORRY' do the same kind of thing.
                            	  1056: * 'QHOW' and 'AHOW' also do this for "How?".
                            	  1057: *
00:0001129C 6100FEAC        	  1058: SETVAL	BSR	TSTV		variable name?
00:000112A0 65000040        	  1059: 	BCS	QWHAT		if not, say "What?"
00:000112A4 2F00            	  1060: 	MOVE.L	D0,-(SP)	save the variable's address
00:000112A6 61000304        	  1061: 	BSR	TSTC		get past the "=" sign
00:000112AA 3D              	  1062: 	DC.B	'=',SV1-*
00:000112AB 0B
00:000112AC 6100FD66        	  1063: 	BSR	EXPR		evaluate the expression
00:000112B0 2C5F            	  1064: 	MOVE.L	(SP)+,A6
00:000112B2 2C80            	  1065: 	MOVE.L	D0,(A6) 	and save its value in the variable
00:000112B4 4E75            	  1066: 	RTS
00:000112B6 6000002A        	  1067: SV1	BRA	QWHAT		if no "=" sign
                            	  1068: 
00:000112BA 610002F0        	  1069: FIN	BSR	TSTC		*** FIN ***
00:000112BE 3A              	  1070: 	DC.B	':',FI1-*
00:000112BF 07
00:000112C0 588F            	  1071: 	ADDQ.L	#4,SP		if ":", discard return address
00:000112C2 6000F940        	  1072: 	BRA	RUNSML		continue on the same line
00:000112C6 610002E4        	  1073: FI1	BSR	TSTC		not ":", is it a CR?
00:000112CA 0A              	  1074: 	DC.B	LF,FI2-*
00:000112CB 07
00:000112CC 588F            	  1075: 	ADDQ.L	#4,SP		yes, purge return address
00:000112CE 6000F914        	  1076: 	BRA	RUNNXL		execute the next line
00:000112D2 4E75            	  1077: FI2	RTS			else return to the caller
                            	  1078: 
00:000112D4 61000330        	  1079: ENDCHK	BSR	IGNBLK
00:000112D8 0C10000A        	  1080: 	CMP.B	#LF,(A0)	does it end with a CR?
00:000112DC 66000004        	  1081: 	BNE	QWHAT		if not, say "WHAT?"
00:000112E0 4E75            	  1082: 	RTS
                            	  1083: 
00:000112E2 2F08            	  1084: QWHAT	MOVE.L	A0,-(SP)
00:000112E4 4DF90001170D    	  1085: AWHAT	LEA	WHTMSG,A6
00:000112EA 610003AA        	  1086: ERROR	BSR	PRMESG		display the error message
00:000112EE 205F            	  1087: 	MOVE.L	(SP)+,A0	restore the text pointer
00:000112F0 203900006126    	  1088: 	MOVE.L	CURRNT,D0	get the current line number
00:000112F6 6700F6BE        	  1089: 	BEQ	WSTART		if zero, do a warm start
00:000112FA B0BCFFFFFFFF    	  1090: 	CMP.L	#-1,D0		is the line no. pointer = -1?
00:00011300 6700FB3A        	  1091: 	BEQ	INPERR		if so, redo input
00:00011304 1F10            	  1092: 	MOVE.B	(A0),-(SP)	save the char. pointed to
00:00011306 4210            	  1093: 	CLR.B	(A0)		put a zero where the error is
00:00011308 227900006126    	  1094: 	MOVE.L	CURRNT,A1	point to start of current line
00:0001130E 61000280        	  1095: 	BSR	PRTLN		display the line in error up to the 0
00:00011312 109F            	  1096: 	MOVE.B	(SP)+,(A0)	restore the character
00:00011314 103C003F        	  1097: 	MOVE.B	#'?',D0         display a "?"
00:00011318 6100F64C        	  1098: 	BSR	GOOUT
00:0001131C 4240            	  1099: 	CLR	D0
00:0001131E 5389            	  1100: 	SUBQ.L	#1,A1		point back to the error char.
00:00011320 61000186        	  1101: 	BSR	PRTSTG		display the rest of the line
00:00011324 6000F690        	  1102: 	BRA	WSTART		and do a warm start
00:00011328 2F08            	  1103: QSORRY	MOVE.L	A0,-(SP)
00:0001132A 4DF900011715    	  1104: ASORRY	LEA	SRYMSG,A6
00:00011330 6000FFB8        	  1105: 	BRA	ERROR
00:00011334 2F08            	  1106: QHOW	MOVE.L	A0,-(SP)	Error: "How?"
00:00011336 4DF900011706    	  1107: AHOW	LEA	HOWMSG,A6
00:0001133C 6000FFAC        	  1108: 	BRA	ERROR
                            	  1109: *
                            	  1110: *******************************************************************
                            	  1111: *
                            	  1112: * *** GETLN *** FNDLN (& friends) ***
                            	  1113: *
                            	  1114: * 'GETLN' reads in input line into 'BUFFER'. It first prompts with
                            	  1115: * the character in D0 (given by the caller), then it fills the
                            	  1116: * buffer and echos. It ignores LF's but still echos
                            	  1117: * them back. Control-H is used to delete the last character
                            	  1118: * entered (if there is one), and control-X is used to delete the
                            	  1119: * whole line and start over again. CR signals the end of a line,
                            	  1120: * and causes 'GETLN' to return.
                            	  1121: *
                            	  1122: * 'FNDLN' finds a line with a given line no. (in D1) in the
                            	  1123: * text save area.  A1 is used as the text pointer. If the line
                            	  1124: * is found, A1 will point to the beginning of that line
                            	  1125: * (i.e. the high byte of the line no.), and flags are NC & Z.
                            	  1126: * If that line is not there and a line with a higher line no.
                            	  1127: * is found, A1 points there and flags are NC & NZ. If we reached
                            	  1128: * the end of the text save area and cannot find the line, flags
                            	  1129: * are C & NZ.
                            	  1130: * 'FNDLN' will initialize A1 to the beginning of the text save
                            	  1131: * area to start the search. Some other entries of this routine
                            	  1132: * will not initialize A1 and do the search.
                            	  1133: * 'FNDLNP' will start with A1 and search for the line no.
                            	  1134: * 'FNDNXT' will bump A1 by 2, find a CR and then start search.
                            	  1135: * 'FNDSKP' uses A1 to find a CR, and then starts the search.
                            	  1136: *
00:00011340 6100F624        	  1137: GETLN	BSR	GOOUT		display the prompt
00:00011344 103C0020        	  1138: 	MOVE.B	#' ',D0         and a space
00:00011348 6100F61C        	  1139: 	BSR	GOOUT
00:0001134C 41F900006152    	  1140: 	LEA	BUFFER,A0	A0 is the buffer pointer
00:00011352 61000326        	  1141: GL1	BSR	CHKIO		check keyboard
00:00011356 6700FFFA        	  1142: 	BEQ	GL1		wait for a char. to come in
00:0001135A B03C0008        	  1143: 	CMP.B	#CTRLH,D0	delete last character?
00:0001135E 67000032        	  1144: 	BEQ	GL3		if so
00:00011362 B03C0018        	  1145: 	CMP.B	#CTRLX,D0	delete the whole line?
00:00011366 67000052        	  1146: 	BEQ	GL4		if so
00:0001136A B03C000A        	  1147: ja	CMP.B	#LF,D0		accept an LF
00:0001136E 6700000A        	  1148: 	BEQ	GL2
00:00011372 B03C0020        	  1149: 	CMP.B	#' ',D0         if other control char., discard it
00:00011376 6500FFDA        	  1150: 	BCS	GL1
00:0001137A 10C0            	  1151: GL2	MOVE.B	D0,(A0)+	save the char.
00:0001137C 6100F5E8        	  1152: 	BSR	GOOUT		echo the char back out
00:00011380 B03C000A        	  1153: 	CMP.B	#LF,D0		if it's an LF, end the line
00:00011384 67000068        	  1154: 	BEQ	GL7
00:00011388 B1FC000061A1    	  1155: 	CMP.L	#(BUFFER+BUFLEN-1),A0	any more room?
00:0001138E 6500FFC2        	  1156: 	BCS	GL1		yes: get some more, else delete last char.
00:00011392 103C0008        	  1157: GL3	MOVE.B	#CTRLH,D0	delete a char. if possible
00:00011396 6100F5CE        	  1158: 	BSR	GOOUT
00:0001139A 103C0020        	  1159: 	MOVE.B	#' ',D0
00:0001139E 6100F5C6        	  1160: 	BSR	GOOUT
00:000113A2 B1FC00006152    	  1161: 	CMP.L	#BUFFER,A0	any char.'s left?
00:000113A8 6300FFA8        	  1162: 	BLS	GL1		if not
00:000113AC 103C0008        	  1163: 	MOVE.B	#CTRLH,D0	if so, finish the BS-space-BS sequence
00:000113B0 6100F5B4        	  1164: 	BSR	GOOUT
00:000113B4 5388            	  1165: 	SUBQ.L	#1,A0		decrement the text pointer
00:000113B6 6000FF9A        	  1166: 	BRA	GL1		back for more
00:000113BA 2208            	  1167: GL4	MOVE.L	A0,D1		delete the whole line
00:000113BC 92BC00006152    	  1168: 	SUB.L	#BUFFER,D1	figure out how many backspaces we need
00:000113C2 67000020        	  1169: 	BEQ	GL6		if none needed, branch
00:000113C6 5341            	  1170: 	SUBQ	#1,D1		adjust for DBRA
00:000113C8 103C0008        	  1171: GL5	MOVE.B	#CTRLH,D0	and display BS-space-BS sequences
00:000113CC 6100F598        	  1172: 	BSR	GOOUT
00:000113D0 103C0020        	  1173: 	MOVE.B	#' ',D0
00:000113D4 6100F590        	  1174: 	BSR	GOOUT
00:000113D8 103C0008        	  1175: 	MOVE.B	#CTRLH,D0
00:000113DC 6100F588        	  1176: 	BSR	GOOUT
00:000113E0 51C9FFE6        	  1177: 	DBRA	D1,GL5
00:000113E4 41F900006152    	  1178: GL6	LEA	BUFFER,A0	reinitialize the text pointer
00:000113EA 6000FF66        	  1179: 	BRA	GL1		and go back for more
00:000113EE 103C000A        	  1180: GL7	MOVE.B	#LF,D0		echo a LF for the CR
00:000113F2 6100F572        	  1181: 	BSR	GOOUT
00:000113F6 4E75            	  1182: 	RTS
                            	  1183: 
00:000113F8 B2BC0000FFFF    	  1184: FNDLN	CMP.L	#$FFFF,D1	line no. must be < 65535
00:000113FE 6400FF34        	  1185: 	BCC	QHOW
00:00011402 22790001097A    	  1186: 	MOVE.L	TXTBGN,A1	init. the text save pointer
                            	  1187: 
00:00011408 247900006146    	  1188: FNDLNP	MOVE.L	TXTUNF,A2	check if we passed the end
00:0001140E 538A            	  1189: 	SUBQ.L	#1,A2
00:00011410 B5C9            	  1190: 	CMP.L	A1,A2
00:00011412 65000010        	  1191: 	BCS	FNDRET		if so, return with Z=0 & C=1
00:00011416 1419            	  1192: 	MOVE.B	(A1)+,D2	if not, get a line no.
00:00011418 E14A            	  1193: 	LSL	#8,D2
00:0001141A 1411            	  1194: 	MOVE.B	(A1),D2
00:0001141C 5389            	  1195: 	SUBQ.L	#1,A1
00:0001141E B481            	  1196: 	CMP.L	D1,D2		is this the line we want?
00:00011420 65000004        	  1197: 	BCS	FNDNXT		no, not there yet
00:00011424 4E75            	  1198: FNDRET	RTS			return the cond. codes
                            	  1199: 
00:00011426 5489            	  1200: FNDNXT	ADDQ.L	#2,A1		find the next line
                            	  1201: 
00:00011428 0C19000A        	  1202: FNDSKP	CMP.B	#LF,(A1)+	try to find an LF
00:0001142C 6600FFFA        	  1203: 	BNE	FNDSKP		keep looking
00:00011430 6000FFD6        	  1204: 	BRA	FNDLNP		check if end of text
                            	  1205: 
                            	  1206: *
                            	  1207: *******************************************************************
                            	  1208: *
                            	  1209: * *** MVUP *** MVDOWN *** POPA *** PUSHA ***
                            	  1210: *
                            	  1211: * 'MVUP' moves a block up from where A1 points to where A2 points
                            	  1212: * until A1=A3
                            	  1213: *
                            	  1214: * 'MVDOWN' moves a block down from where A1 points to where A3
                            	  1215: * points until A1=A2
                            	  1216: *
                            	  1217: * 'POPA' restores the 'FOR' loop variable save area from the stack
                            	  1218: *
                            	  1219: * 'PUSHA' stacks for 'FOR' loop variable save area onto the stack
                            	  1220: *
00:00011434 B7C9            	  1221: MVUP	CMP.L	A1,A3		see the above description
00:00011436 67000008        	  1222: 	BEQ	MVRET
00:0001143A 14D9            	  1223: 	MOVE.B	(A1)+,(A2)+
00:0001143C 6000FFF6        	  1224: 	BRA	MVUP
00:00011440 4E75            	  1225: MVRET	RTS
                            	  1226: 
00:00011442 B5C9            	  1227: MVDOWN	CMP.L	A1,A2		see the above description
00:00011444 6700FFFA        	  1228: 	BEQ	MVRET
00:00011448 1721            	  1229: 	MOVE.B	-(A1),-(A3)
00:0001144A 6000FFF6        	  1230: 	BRA	MVDOWN
                            	  1231: 
00:0001144E 2C5F            	  1232: POPA	MOVE.L	(SP)+,A6	A6 = return address
00:00011450 23DF00006132    	  1233: 	MOVE.L	(SP)+,LOPVAR	restore LOPVAR, but zero means no more
00:00011456 6700001A        	  1234: 	BEQ	PP1
00:0001145A 23DF00006136    	  1235: 	MOVE.L	(SP)+,LOPINC	if not zero, restore the rest
