00:00010C96 24              	   381: 	DC.B	'$',PR4-*
00:00010C97 0D
00:00010C98 6100037A        	   382: 	BSR	EXPR		yep. Evaluate expression (MRL)
00:00010C9C 6100FCC8        	   383: 	BSR	GOOUT		print low byte (MRL)
00:00010CA0 60000008        	   384: 	BRA	PR3		look for more. (MRL)
00:00010CA4 61000822        	   385: PR4	BSR	QTSTG		is it a string?
00:00010CA8 6016            	   386: 	BRA.S	PR8		if not, must be an expression
00:00010CAA 61000900        	   387: PR3	BSR	TSTC		if ",", go find next
00:00010CAE 2C              	   388: 	DC.B	',',PR6-*
00:00010CAF 09
00:00010CB0 61000608        	   389: 	BSR	FIN		in the list.
00:00010CB4 6000FFCC        	   390: 	BRA	PR0
00:00010CB8 610009D6        	   391: PR6	BSR	CRLF		list ends here
00:00010CBC 60000014        	   392: 	BRA	FINISH
00:00010CC0 3F04            	   393: PR8	MOVE	D4,-(SP)	save the width value
00:00010CC2 61000350        	   394: 	BSR	EXPR		evaluate the expression
