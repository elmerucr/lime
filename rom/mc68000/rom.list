                            	  1425: *
                            	  1426: * ===== Convert the line of text in the input buffer to upper
                            	  1427: *	case (except for stuff between quotes).
                            	  1428: *
00:00011616 41F900006152    	  1429: TOUPBUF LEA	BUFFER,A0	set up text pointer
00:0001161C 4201            	  1430: 	CLR.B	D1		clear quote flag
00:0001161E 1018            	  1431: TOUPB1	MOVE.B	(A0)+,D0	get the next text char.
00:00011620 B03C000A        	  1432: 	CMP.B	#LF,D0		is it end of line?
00:00011624 67000024        	  1433: 	BEQ	TOUPBRT 	if so, return
00:00011628 B03C0022        	  1434: 	CMP.B	#'"',D0         a double quote?
00:0001162C 6700001E        	  1435: 	BEQ	DOQUO
00:00011630 B03C0027        	  1436: 	CMP.B	#'''',D0        or a single quote?
00:00011634 67000016        	  1437: 	BEQ	DOQUO
00:00011638 4A01            	  1438: 	TST.B	D1		inside quotes?
00:0001163A 6600FFE2        	  1439: 	BNE	TOUPB1		if so, do the next one
00:0001163E 61000024        	  1440: 	BSR	TOUPPER 	convert to upper case
00:00011642 1100            	  1441: 	MOVE.B	D0,-(A0)	store it
00:00011644 5288            	  1442: 	ADDQ.L	#1,A0
00:00011646 6000FFD6        	  1443: 	BRA	TOUPB1		and go back for more
00:0001164A 4E75            	  1444: TOUPBRT RTS
                            	  1445: 
00:0001164C 4A01            	  1446: DOQUO	TST.B	D1		are we inside quotes?
00:0001164E 66000008        	  1447: 	BNE	DOQUO1
00:00011652 1200            	  1448: 	MOVE.B	D0,D1		if not, toggle inside-quotes flag
00:00011654 6000FFC8        	  1449: 	BRA	TOUPB1
00:00011658 B200            	  1450: DOQUO1	CMP.B	D0,D1		make sure we're ending proper quote
00:0001165A 6600FFC2        	  1451: 	BNE	TOUPB1		if not, ignore it
00:0001165E 4201            	  1452: 	CLR.B	D1		else clear quote flag
00:00011660 6000FFBC        	  1453: 	BRA	TOUPB1
