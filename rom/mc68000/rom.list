                            	  1254: *
                            	  1255: *******************************************************************
                            	  1256: *
                            	  1257: * *** PRTSTG *** QTSTG *** PRTNUM *** PRTLN ***
                            	  1258: *
                            	  1259: * 'PRTSTG' prints a string pointed to by A1. It stops printing
                            	  1260: * and returns to the caller when either a CR is printed or when
                            	  1261: * the next byte is the same as what was passed in D0 by the
                            	  1262: * caller.
                            	  1263: *
                            	  1264: * 'QTSTG' looks for an underline (back-arrow on some systems),
                            	  1265: * single-quote, or double-quote.  If none of these are found, returns
                            	  1266: * to the caller.  If underline, outputs a CR without a LF.  If single
                            	  1267: * or double quote, prints the quoted string and demands a matching
                            	  1268: * end quote.  After the printing, the next 2 bytes of the caller are
                            	  1269: * skipped over (usually a short branch instruction).
                            	  1270: *
                            	  1271: * 'PRTNUM' prints the 32 bit number in D1, leading blanks are added if
                            	  1272: * needed to pad the number of spaces to the number in D4.
                            	  1273: * However, if the number of digits is larger than the no. in
                            	  1274: * D4, all digits are printed anyway. Negative sign is also
                            	  1275: * printed and counted in, positive sign is not.
                            	  1276: *
                            	  1277: * 'PRTLN' prints the saved text line pointed to by A1
                            	  1278: * with line no. and all.
                            	  1279: *
00:00011488 1200            	  1280: PRTSTG	MOVE.B	D0,D1		save the stop character
00:0001148A 1019            	  1281: PS1	MOVE.B	(A1)+,D0	get a text character
00:0001148C B200            	  1282: 	CMP.B	D0,D1		same as stop character?
00:0001148E 67000016        	  1283: 	BEQ	PRTRET		if so, return
00:00011492 6100F4B2        	  1284: 	BSR	GOOUT		display the char.
00:00011496 B03C000A        	  1285: 	CMP.B	#LF,D0		is it a C.R.?
00:0001149A 6600FFEE        	  1286: 	BNE	PS1		no, go back for more
00:0001149E 103C000A        	  1287: 	MOVE.B	#LF,D0		yes, add a L.F.
00:000114A2 6100F4A2        	  1288: 	BSR	GOOUT
00:000114A6 4E75            	  1289: PRTRET	RTS			then return
                            	  1290: 
00:000114A8 610000E2        	  1291: QTSTG	BSR	TSTC		*** QTSTG ***
00:000114AC 22              	  1292: 	DC.B	'"',QT3-*
00:000114AD 1B
00:000114AE 103C0022        	  1293: 	MOVE.B	#'"',D0         it is a "
00:000114B2 2248            	  1294: QT1	MOVE.L	A0,A1
00:000114B4 6100FFD2        	  1295: 	BSR	PRTSTG		print until another
00:000114B8 2049            	  1296: 	MOVE.L	A1,A0
00:000114BA 225F            	  1297: 	MOVE.L	(SP)+,A1	pop return address
00:000114BC B03C000A        	  1298: 	CMP.B	#LF,D0		was last one a CR?
00:000114C0 6700F702        	  1299: 	BEQ	RUNNXL		if so, run next line
00:000114C4 5489            	  1300: QT2	ADDQ.L	#2,A1		skip 2 bytes on return
00:000114C6 4ED1            	  1301: 	JMP	(A1)		return
00:000114C8 610000C2        	  1302: QT3	BSR	TSTC		is it a single quote?
00:000114CC 27              	  1303: 	DC.B	'''',QT4-*
00:000114CD 09
00:000114CE 103C0027        	  1304: 	MOVE.B	#'''',D0        if so, do same as above
00:000114D2 6000FFDE        	  1305: 	BRA	QT1
00:000114D6 610000B4        	  1306: QT4	BSR	TSTC		is it an underline?
00:000114DA 5F              	  1307: 	DC.B	'_',QT5-*
00:000114DB 0F
00:000114DC 103C000D        	  1308: 	MOVE.B	#CR,D0		if so, output a CR without LF
00:000114E0 6100F464        	  1309: 	BSR	GOOUT
00:000114E4 225F            	  1310: 	MOVE.L	(SP)+,A1	pop return address
00:000114E6 6000FFDC        	  1311: 	BRA	QT2
00:000114EA 4E75            	  1312: QT5	RTS			none of the above
                            	  1313: 
00:000114EC 2601            	  1314: PRTNUM	MOVE.L	D1,D3		save the number for later
00:000114EE 3F04            	  1315: 	MOVE	D4,-(SP)	save the width value
00:000114F0 1F3C00FF        	  1316: 	MOVE.B	#$FF,-(SP)	flag for end of digit string
00:000114F4 4A81            	  1317: 	TST.L	D1		is it negative?
00:000114F6 6A000006        	  1318: 	BPL	PN1		if not
00:000114FA 4481            	  1319: 	NEG.L	D1		else make it positive
00:000114FC 5344            	  1320: 	SUBQ	#1,D4		one less for width count
00:000114FE 82FC000A        	  1321: PN1	DIVU	#10,D1		get the next digit
00:00011502 6900000E        	  1322: 	BVS	PNOV		overflow flag set?
00:00011506 2001            	  1323: 	MOVE.L	D1,D0		if not, save remainder
00:00011508 C2BC0000FFFF    	  1324: 	AND.L	#$FFFF,D1	strip the remainder
00:0001150E 6000001C        	  1325: 	BRA	TOASCII 	skip the overflow stuff
00:00011512 3001            	  1326: PNOV	MOVE	D1,D0		prepare for long word division
00:00011514 4241            	  1327: 	CLR.W	D1		zero out low word
00:00011516 4841            	  1328: 	SWAP	D1		high word into low
00:00011518 82FC000A        	  1329: 	DIVU	#10,D1		divide high word
00:0001151C 3401            	  1330: 	MOVE	D1,D2		save quotient
00:0001151E 3200            	  1331: 	MOVE	D0,D1		low word into low
00:00011520 82FC000A        	  1332: 	DIVU	#10,D1		divide low word
00:00011524 2001            	  1333: 	MOVE.L	D1,D0		D0 = remainder
00:00011526 4841            	  1334: 	SWAP	D1		R/Q becomes Q/R
00:00011528 3202            	  1335: 	MOVE	D2,D1		D1 is low/high
00:0001152A 4841            	  1336: 	SWAP	D1		D1 is finally high/low
00:0001152C 4840            	  1337: TOASCII SWAP	D0		get remainder
00:0001152E 1F00            	  1338: 	MOVE.B	D0,-(SP)	stack it as a digit
00:00011530 4840            	  1339: 	SWAP	D0
00:00011532 5344            	  1340: 	SUBQ	#1,D4		decrement width count
00:00011534 4A81            	  1341: 	TST.L	D1		if quotient is zero, we're done
00:00011536 6600FFC6        	  1342: 	BNE	PN1
00:0001153A 5344            	  1343: 	SUBQ	#1,D4		adjust padding count for DBRA
00:0001153C 6B00000E        	  1344: 	BMI	PN4		skip padding if not needed
00:00011540 103C0020        	  1345: PN3	MOVE.B	#' ',D0         display the required leading spaces
00:00011544 6100F400        	  1346: 	BSR	GOOUT
00:00011548 51CCFFF6        	  1347: 	DBRA	D4,PN3
00:0001154C 4A83            	  1348: PN4	TST.L	D3		is number negative?
00:0001154E 6A00000A        	  1349: 	BPL	PN5
00:00011552 103C002D        	  1350: 	MOVE.B	#'-',D0         if so, display the sign
00:00011556 6100F3EE        	  1351: 	BSR	GOOUT
00:0001155A 101F            	  1352: PN5	MOVE.B	(SP)+,D0	now unstack the digits and display
00:0001155C 6B00000E        	  1353: 	BMI	PNRET		until the flag code is reached
00:00011560 D03C0030        	  1354: 	ADD.B	#'0',D0         make into ASCII
00:00011564 6100F3E0        	  1355: 	BSR	GOOUT
00:00011568 6000FFF0        	  1356: 	BRA	PN5
00:0001156C 381F            	  1357: PNRET	MOVE	(SP)+,D4	restore width value
00:0001156E 4E75            	  1358: 	RTS
                            	  1359: 
00:00011570 4281            	  1360: PRTLN	CLR.L	D1
00:00011572 1219            	  1361: 	MOVE.B	(A1)+,D1	get the binary line number
00:00011574 E149            	  1362: 	LSL	#8,D1
00:00011576 1219            	  1363: 	MOVE.B	(A1)+,D1
00:00011578 7805            	  1364: 	MOVEQ	#5,D4		display a 5 digit line no.
00:0001157A 6100FF70        	  1365: 	BSR	PRTNUM
00:0001157E 103C0020        	  1366: 	MOVE.B	#' ',D0         followed by a blank
00:00011582 6100F3C2        	  1367: 	BSR	GOOUT
00:00011586 4240            	  1368: 	CLR	D0		stop char. is a zero
00:00011588 6000FEFE        	  1369: 	BRA	PRTSTG		display the rest of the line
                            	  1370: 
                            	  1371: *
                            	  1372: * ===== Test text byte following the call to this subroutine. If it
                            	  1373: *	equals the byte pointed to by A0, return to the code following
                            	  1374: *	the call. If they are not equal, branch to the point
                            	  1375: *	indicated by the offset byte following the text byte.
                            	  1376: *
00:0001158C 61000058        	  1377: TSTC	BSR	IGNBLK		ignore leading blanks
00:00011590 225F            	  1378: 	MOVE.L	(SP)+,A1	get the return address
00:00011592 1219            	  1379: 	MOVE.B	(A1)+,D1	get the byte to compare
00:00011594 B210            	  1380: 	CMP.B	(A0),D1 	is it = to what A0 points to?
00:00011596 6700000A        	  1381: 	BEQ	TC1		if so
00:0001159A 4281            	  1382: 	CLR.L	D1		If not, add the second
00:0001159C 1211            	  1383: 	MOVE.B	(A1),D1 	byte following the call to
00:0001159E D3C1            	  1384: 	ADD.L	D1,A1		the return address.
00:000115A0 4ED1            	  1385: 	JMP	(A1)		jump to the routine
00:000115A2 5288            	  1386: TC1	ADDQ.L	#1,A0		if equal, bump text pointer
00:000115A4 5289            	  1387: 	ADDQ.L	#1,A1		Skip the 2 bytes following
00:000115A6 4ED1            	  1388: 	JMP	(A1)		the call and continue.
                            	  1389: 
                            	  1390: *
                            	  1391: * ===== See if the text pointed to by A0 is a number. If so,
                            	  1392: *	return the number in D1 and the number of digits in D2,
                            	  1393: *	else return zero in D1 and D2.
                            	  1394: *
00:000115A8 4281            	  1395: TSTNUM	CLR.L	D1		initialize return parameters
00:000115AA 4242            	  1396: 	CLR	D2
00:000115AC 61000038        	  1397: 	BSR	IGNBLK		skip over blanks
00:000115B0 0C100030        	  1398: TN1	CMP.B	#'0',(A0)       is it less than zero?
00:000115B4 6500002E        	  1399: 	BCS	TSNMRET 	if so, that's all
00:000115B8 0C100039        	  1400: 	CMP.B	#'9',(A0)       is it greater than nine?
00:000115BC 62000026        	  1401: 	BHI	TSNMRET 	if so, return
00:000115C0 B2BC0CCCCCCC    	  1402: 	CMP.L	#214748364,D1	see if there's room for new digit
00:000115C6 6400FD4C        	  1403: 	BCC	QHOW		if not, we've overflowd
00:000115CA 2001            	  1404: 	MOVE.L	D1,D0		quickly multiply result by 10
00:000115CC D281            	  1405: 	ADD.L	D1,D1
00:000115CE D281            	  1406: 	ADD.L	D1,D1
00:000115D0 D280            	  1407: 	ADD.L	D0,D1
00:000115D2 D281            	  1408: 	ADD.L	D1,D1
00:000115D4 1018            	  1409: 	MOVE.B	(A0)+,D0	add in the new digit
00:000115D6 C0BC0000000F    	  1410: 	AND.L	#$F,D0
00:000115DC D280            	  1411: 	ADD.L	D0,D1
00:000115DE 5242            	  1412: 	ADDQ	#1,D2		increment the no. of digits
00:000115E0 6000FFCE        	  1413: 	BRA	TN1
00:000115E4 4E75            	  1414: TSNMRET RTS
                            	  1415: 
                            	  1416: *
                            	  1417: * ===== Skip over blanks in the text pointed to by A0.
                            	  1418: *
00:000115E6 0C100020        	  1419: IGNBLK	CMP.B	#' ',(A0)       see if it's a space
00:000115EA 66000008        	  1420: 	BNE	IGBRET		if so, swallow it
00:000115EE 5288            	  1421: IGB1	ADDQ.L	#1,A0		increment the text pointer
00:000115F0 6000FFF4        	  1422: 	BRA	IGNBLK
00:000115F4 4E75            	  1423: IGBRET	RTS
