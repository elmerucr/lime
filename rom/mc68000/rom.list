00:00010948 D082            	    68: 	add.l	D2,D0		; now D0 is times 5
00:0001094A E380            	    69: 	asl.l	#1,D0		; double D0 (times 10)
00:0001094C 1418            	    70: 	move.b	(A0)+,D2
