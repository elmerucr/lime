                            	   546: 
00:000105B2 B03C000A        	   547: 	cmp.b	#$0a,D0			; check for linefeed
00:000105B6 6700004E        	   548: 	beq	.lf
00:000105BA B03C000D        	   549: 	cmp.b	#$0d,D0			; check for carriage return
00:000105BE 6700004A        	   550: 	beq	.cr
00:000105C2 B03C001D        	   551: 	cmp.b	#$1d,D0			; cursor right
00:000105C6 6700002E        	   552: 	beq	.right
00:000105CA B03C0011        	   553: 	cmp.b	#$11,D0			; cursor down
00:000105CE 6700005E        	   554: 	beq	.down
00:000105D2 B03C0091        	   555: 	cmp.b	#$91,D0			; cursor up
00:000105D6 67000060        	   556: 	beq	.up
00:000105DA B03C009D        	   557: 	cmp.b	#$9d,D0			; cursor left
00:000105DE 67000064        	   558: 	beq	.left
00:000105E2 B03C0008        	   559: 	cmp.b	#$08,D0			; backspace
00:000105E6 6700007A        	   560: 	beq	.bs
                            	   561: 
