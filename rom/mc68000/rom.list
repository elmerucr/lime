                            	    51: 
                            	    52: LAB_WARM	rs.w	1	; BASIC warm start entry point
                            	    53: Wrmjpv		rs.l	1	; BASIC warm start jump vector
                            	    54: 
                            	    55: Usrjmp		rs.w	1	; USR function JMP address
                            	    56: Usrjpv		rs.l	1	; USR function JMP vector
                            	    57: ; system dependant i/o vectors
                            	    58: ; these are in RAM and are set at start-up
                            	    59: 
                            	    60: V_INPT	rs.w	1		* non halting scan input device entry point
                            	    61: V_INPTv	rs.l	1		* non halting scan input device jump vector
                            	    62: 
                            	    63: V_OUTP	rs.w	1		* send byte to output device entry point
                            	    64: V_OUTPv	rs.l	1		* send byte to output device jump vector
                            	    65: 
                            	    66: V_LOAD	rs.w	1		* load BASIC program entry point
                            	    67: V_LOADv	rs.l	1		* load BASIC program jump vector
                            	    68: 
                            	    69: V_SAVE	rs.w	1		* save BASIC program entry point
                            	    70: V_SAVEv	rs.l	1		* save BASIC program jump vector
                            	    71: 
                            	    72: V_CTLC	rs.w	1		* save CTRL-C check entry point
                            	    73: V_CTLCv	rs.l	1		* save CTRL-C check jump vector
                            	    74: 
                            	    75: Itemp	rs.l	1		* temporary integer	(for GOTO etc)
                            	    76: 
                            	    77: Smeml	rs.l	1		* start of memory	(start of program)
                            	    78: Sfncl	rs.l	1		* start of functions	(end of Program)
                            	    79: Svarl	rs.l	1		* start of variables	(end of functions)
                            	    80: Sstrl	rs.l	1		* start of strings	(end of variables)
                            	    81: Sarryl	rs.l	1		* start of arrays	(end of strings)
                            	    82: Earryl	rs.l	1		* end of arrays		(start of free mem)
                            	    83: Sstorl	rs.l	1		* string storage	(moving down)
                            	    84: Ememl	rs.l	1		* end of memory		(upper bound of RAM)
                            	    85: Sutill	rs.l	1		* string utility ptr
                            	    86: Clinel	rs.l	1		* current line		(Basic line number)
                            	    87: Blinel	rs.l	1		* break line		(Basic line number)
