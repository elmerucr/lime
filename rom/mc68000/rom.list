00:00002D6A 907C0080        	  6121: 	SUB.w		#$80,d0			* normalise
00:00002D6E E248            	  6122: 	LSR.w		#1,d0				* /2
00:00002D70 6402            	  6123: 	BCC.s		LAB_SQNA			* skip increment if carry clear
                            	  6124: 
00:00002D72 5240            	  6125: 	ADDQ.w	#1,d0				* add bit zero back in (allow for half shift)
                            	  6126: LAB_SQNA
00:00002D74 D07C0080        	  6127: 	ADD.w		#$80,d0			* re-bias to $80
00:00002D78 17400594        	  6128: 	move.b	d0,FAC1_e(a3)		* save it
00:00002D7C 4CDF001E        	  6129: 	movem.l	(sp)+,d1-d4			* restore registers
