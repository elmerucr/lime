                            	   323: *
                            	   324: *******************************************************************
                            	   325: *
                            	   326: * *** LIST *** PRINT ***
                            	   327: *
                            	   328: * LIST has two forms:
                            	   329: * 'LIST<CR>' lists all saved lines
                            	   330: * 'LIST #<CR>' starts listing at the line #
                            	   331: * Control-S pauses the listing, control-C stops it.
                            	   332: *
                            	   333: * PRINT command is 'PRINT ....:' or 'PRINT ....<CR>'
                            	   334: * where '....' is a list of expressions, formats, back-arrows,
                            	   335: * and strings.	These items a separated by commas.
                            	   336: *
                            	   337: * A format is a pound sign followed by a number.  It controls
                            	   338: * the number of spaces the value of an expression is going to
                            	   339: * be printed in.  It stays effective for the rest of the print
                            	   340: * command unless changed by another format.  If no format is
                            	   341: * specified, 11 positions will be used.
                            	   342: *
                            	   343: * A string is quoted in a pair of single- or double-quotes.
                            	   344: *
                            	   345: * An underline (back-arrow) means generate a <CR> without a <LF>
                            	   346: *
                            	   347: * A <CR LF> is generated after the entire list has been printed
                            	   348: * or if the list is empty.  If the list ends with a semicolon,
                            	   349: * however, no <CR LF> is generated.
                            	   350: *
                            	   351: 
00:00010BEA 61000998        	   352: LIST	BSR	TSTNUM		see if there's a line no.
00:00010BEE 610006A0        	   353: 	BSR	ENDCHK		if not, we get a zero
00:00010BF2 610007C0        	   354: 	BSR	FNDLN		find this or next line
00:00010BF6 6500FD7A        	   355: LS1	BCS	WSTART		warm start if we passed the end
00:00010BFA 61000950        	   356: 	BSR	PRTLN		print the line
00:00010BFE 61000A36        	   357: 	BSR	CHKIO		check for listing halt request
00:00010C02 67000012        	   358: 	BEQ	LS3
00:00010C06 B03C0013        	   359: 	CMP.B	#CTRLS,D0	pause the listing?
00:00010C0A 6600000A        	   360: 	BNE	LS3
00:00010C0E 61000A26        	   361: LS2	BSR	CHKIO		if so, wait for another keypress
00:00010C12 6700FFFA        	   362: 	BEQ	LS2
00:00010C16 610007AC        	   363: LS3	BSR	FNDLNP		find the next line
00:00010C1A 6000FFDA        	   364: 	BRA	LS1
                            	   365: 
00:00010C1E 383C000B        	   366: PRINT	MOVE	#11,D4		D4 = number of print spaces
00:00010C22 61000944        	   367: 	BSR	TSTC		if null list and ":"
00:00010C26 3A              	   368: 	DC.B	':',PR2-*
00:00010C27 09
