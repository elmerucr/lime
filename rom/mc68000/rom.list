00:00002DB6 377C83000594    	  6159: 	MOVE.w	#$8300,FAC1_e(a3)		* 2pi exponent and sign
00:00002DBC 4E75            	  6160: 	RTS
                            	  6161: 
                            	  6162: * get ASCII string equivalent into FAC1 as integer32 or float
                            	  6163: 
                            	  6164: * entry is with a5 pointing to the first character of the string
                            	  6165: * exit with a5 pointing to the first character after the string
                            	  6166: 
                            	  6167: * d0 is character
                            	  6168: * d1 is mantissa
                            	  6169: * d2 is partial and table mantissa
                            	  6170: * d3 is mantissa exponent (decimal & binary)
                            	  6171: * d4 is decimal exponent
                            	  6172: 
                            	  6173: * get FAC1 from string
                            	  6174: * this routine now handles hex and binary values from strings
                            	  6175: * starting with "$" and "%" respectively
                            	  6176: 
                            	  6177: LAB_2887
00:00002DBE 48E77C00        	  6178: 	movem.l	d1-d5,-(sp)			* save registers
00:00002DC2 7200            	  6179: 	moveq		#$00,d1			* clear temp accumulator
00:00002DC4 2601            	  6180: 	move.l	d1,d3				* set mantissa decimal exponent count
00:00002DC6 2801            	  6181: 	move.l	d1,d4				* clear decimal exponent
00:00002DC8 17410595        	  6182: 	move.b	d1,FAC1_s(a3)		* clear sign byte
00:00002DCC 174105B5        	  6183: 	move.b	d1,Dtypef(a3)		* set float data type
00:00002DD0 174105AF        	  6184: 	move.b	d1,expneg(a3)		* clear exponent sign
00:00002DD4 6100E816        	  6185: 	BSR		LAB_GBYT			* get first byte back
00:00002DD8 653C            	  6186: 	BCS.s		LAB_28FE			* go get floating if 1st character numeric
                            	  6187: 
00:00002DDA B03C002D        	  6188: 	CMP.b		#'-',d0			* or is it -ve number
00:00002DDE 6608            	  6189: 	BNE.s		LAB_289A			* branch if not
                            	  6190: 
00:00002DE0 177C00FF0595    	  6191: 	move.b	#$FF,FAC1_s(a3)		* set sign byte
00:00002DE6 6006            	  6192: 	BRA.s		LAB_289C			* now go scan & check for hex/bin/int
                            	  6193: 
                            	  6194: LAB_289A
                            	  6195: 							* first character wasn't numeric or -
00:00002DE8 B03C002B        	  6196: 	CMP.b		#'+',d0			* compare with '+'
00:00002DEC 6606            	  6197: 	BNE.s		LAB_289D			* branch if not '+' (go check for '.'/hex/binary
                            	  6198: 							* /integer)
                            	  6199: 
                            	  6200: LAB_289C
                            	  6201: 							* was "+" or "-" to start, so get next character
00:00002DEE 6100E7FA        	  6202: 	BSR		LAB_IGBY			* increment & scan memory
00:00002DF2 6522            	  6203: 	BCS.s		LAB_28FE			* branch if numeric character
                            	  6204: 
                            	  6205: LAB_289D
00:00002DF4 B03C002E        	  6206: 	CMP.b		#'.',d0			* else compare with '.'
00:00002DF8 67000094        	  6207: 	BEQ		LAB_2904			* branch if '.'
                            	  6208: 
                            	  6209: 							* code here for hex/binary/integer numbers
00:00002DFC B03C0024        	  6210: 	CMP.b		#'$',d0			* compare with '$'
00:00002E00 6700010C        	  6211: 	BEQ		LAB_CHEX			* branch if '$'
                            	  6212: 
00:00002E04 B03C0025        	  6213: 	CMP.b		#'%',d0			* else compare with '%'
00:00002E08 67000166        	  6214: 	BEQ		LAB_CBIN			* branch if '%'
                            	  6215: 
00:00002E0C 6000008E        	  6216: 	BRA		LAB_2Y01			* not #.$%& so return 0
                            	  6217: 
                            	  6218: LAB_28FD
00:00002E10 6100E7D8        	  6219: 	BSR		LAB_IGBY			* get next character
00:00002E14 646E            	  6220: 	BCC.s		LAB_2902			* exit loop if not a digit
                            	  6221: 
                            	  6222: LAB_28FE
00:00002E16 610001AA        	  6223: 	BSR		d1x10				* multiply d1 by 10 and add character
00:00002E1A 64F4            	  6224: 	BCC.s		LAB_28FD			* loop for more if no overflow
                            	  6225: 
                            	  6226: LAB_28FF
                            	  6227: 							* overflowed mantissa, count 10s exponent
00:00002E1C 5283            	  6228: 	ADDQ.l	#1,d3				* increment mantissa decimal exponent count
00:00002E1E 6100E7CA        	  6229: 	BSR		LAB_IGBY			* get next character
00:00002E22 65F8            	  6230: 	BCS.s		LAB_28FF			* loop while numeric character
                            	  6231: 
                            	  6232: 							* done overflow, now flush fraction or do E
00:00002E24 B03C002E        	  6233: 	CMP.b		#'.',d0			* else compare with '.'
00:00002E28 6608            	  6234: 	BNE.s		LAB_2901			* branch if not '.'
                            	  6235: 
                            	  6236: LAB_2900
                            	  6237: 							* flush remaining fractional digits
00:00002E2A 6100E7BE        	  6238: 	BSR		LAB_IGBY			* get next character
00:00002E2E 6500FFFA        	  6239: 	BCS		LAB_2900			* loop while numeric character
                            	  6240: 
                            	  6241: LAB_2901
                            	  6242: 							* done number, only (possible) exponent remains
00:00002E32 B03C0045        	  6243: 	CMP.b		#'E',d0			* else compare with 'E'
00:00002E36 6664            	  6244: 	BNE.s		LAB_2Y01			* if not 'E' all done, go evaluate
                            	  6245: 
                            	  6246: 							* process exponent
00:00002E38 6100E7B0        	  6247: 	BSR		LAB_IGBY			* get next character
00:00002E3C 6528            	  6248: 	BCS.s		LAB_2X04			* branch if digit
                            	  6249: 
00:00002E3E B03C002D        	  6250: 	CMP.b		#'-',d0			* or is it -ve number
00:00002E42 6706            	  6251: 	BEQ.s		LAB_2X01			* branch if so
                            	  6252: 
00:00002E44 B03C00B2        	  6253: 	CMP.b		#TK_MINUS,d0		* or is it -ve number
00:00002E48 6608            	  6254: 	BNE.s		LAB_2X02			* branch if not
                            	  6255: 
                            	  6256: LAB_2X01
00:00002E4A 177C00FF05AF    	  6257: 	move.b	#$FF,expneg(a3)		* set exponent sign
00:00002E50 600E            	  6258: 	BRA.s		LAB_2X03			* now go scan & check exponent
                            	  6259: 
