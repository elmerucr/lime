00:00011236 2200            	   997: 	MOVE.L	D0,D1
00:00011238 227900006122    	   998: 	MOVE.L	RANPNT,A1	get memory as a random number
00:0001123E B3FC00011707    	   999: 	CMP.L	#LSTROM,A1
00:00011244 65000008        	  1000: 	BCS	RA1
00:00011248 43F900010946    	  1001: 	LEA	START,A1	wrap around if end of program
00:0001124E 2019            	  1002: RA1	MOVE.L	(A1)+,D0	get the slightly random number
00:00011250 0880001F        	  1003: 	BCLR	#31,D0		make sure it's positive
00:00011254 23C900006122    	  1004: 	MOVE.L	A1,RANPNT	(even I can do better than this!)
00:0001125A 6100FF7A        	  1005: 	BSR	DIV32		RND(n)=MOD(number,n)+1
00:0001125E 2001            	  1006: 	MOVE.L	D1,D0		MOD is the remainder of the div.
00:00011260 5280            	  1007: 	ADDQ.L	#1,D0
00:00011262 4E75            	  1008: 	RTS
