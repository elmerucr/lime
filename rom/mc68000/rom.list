                            	  1207: *******************************************************************
                            	  1208: *
                            	  1209: * *** MVUP *** MVDOWN *** POPA *** PUSHA ***
                            	  1210: *
                            	  1211: * 'MVUP' moves a block up from where A1 points to where A2 points
                            	  1212: * until A1=A3
                            	  1213: *
                            	  1214: * 'MVDOWN' moves a block down from where A1 points to where A3
                            	  1215: * points until A1=A2
                            	  1216: *
                            	  1217: * 'POPA' restores the 'FOR' loop variable save area from the stack
                            	  1218: *
                            	  1219: * 'PUSHA' stacks for 'FOR' loop variable save area onto the stack
                            	  1220: *
00:00011414 B7C9            	  1221: MVUP	CMP.L	A1,A3		see the above description
00:00011416 67000008        	  1222: 	BEQ	MVRET
00:0001141A 14D9            	  1223: 	MOVE.B	(A1)+,(A2)+
00:0001141C 6000FFF6        	  1224: 	BRA	MVUP
00:00011420 4E75            	  1225: MVRET	RTS
                            	  1226: 
00:00011422 B5C9            	  1227: MVDOWN	CMP.L	A1,A2		see the above description
