00:00011224 4A80            	   994: 	TST.L	D0		it must be positive and non-zero
00:00011226 670000EC        	   995: 	BEQ	QHOW
00:0001122A 6B0000E8        	   996: 	BMI	QHOW
00:0001122E 2200            	   997: 	MOVE.L	D0,D1
00:00011230 227900006126    	   998: 	MOVE.L	RANPNT,A1	get memory as a random number
00:00011236 B3FC000116FF    	   999: 	CMP.L	#LSTROM,A1
00:0001123C 65000008        	  1000: 	BCS	RA1
00:00011240 43F90001093E    	  1001: 	LEA	START,A1	wrap around if end of program
00:00011246 2019            	  1002: RA1	MOVE.L	(A1)+,D0	get the slightly random number
00:00011248 0880001F        	  1003: 	BCLR	#31,D0		make sure it's positive
00:0001124C 23C900006126    	  1004: 	MOVE.L	A1,RANPNT	(even I can do better than this!)
00:00011252 6100FF7A        	  1005: 	BSR	DIV32		RND(n)=MOD(number,n)+1
00:00011256 2001            	  1006: 	MOVE.L	D1,D0		MOD is the remainder of the div.
00:00011258 5280            	  1007: 	ADDQ.L	#1,D0
00:0001125A 4E75            	  1008: 	RTS
