00:00010920 B03C0020        	    44: 	cmp.b	#' ',D0
00:00010924 6702            	    45: 	beq.s	.next		; it is a space
00:00010926 4E75            	    46: 	rts
00:00010928 5288            	    47: .next	addq.l	#1,A0
