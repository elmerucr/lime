                            	   253: *
                            	   254: *******************************************************************
                            	   255: *
                            	   256: * What follows is the code to execute direct and statement
                            	   257: * commands. Control is transferred to these points via the command
                            	   258: * table lookup code of 'DIRECT' and 'EXEC' in the last section.
                            	   259: * After the command is executed, control is transferred to other
                            	   260: * sections as follows:
                            	   261: *
                            	   262: * For 'LIST', 'NEW', and 'STOP': go back to the warm start point.
                            	   263: * For 'RUN': go execute the first stored line if any; else go
                            	   264: * back to the warm start point.
                            	   265: * For 'GOTO' and 'GOSUB': go execute the target line.
                            	   266: * For 'RETURN' and 'NEXT'; go back to saved return line.
                            	   267: * For all others: if 'CURRNT' is 0, go to warm start; else go
                            	   268: * execute next command. (This is done in 'FINISH'.)
                            	   269: *
                            	   270: *******************************************************************
                            	   271: *
                            	   272: * *** NEW *** STOP *** RUN (& friends) *** GOTO ***
                            	   273: *
                            	   274: * 'NEW<CR>' sets TXTUNF to point to TXTBGN
                            	   275: *
                            	   276: * 'STOP<CR>' goes back to WSTART
                            	   277: *
                            	   278: * 'RUN<CR>' finds the first stored line, stores its address
                            	   279: * in CURRNT, and starts executing it. Note that only those
                            	   280: * commands in TAB2 are legal for a stored program.
                            	   281: *
                            	   282: * There are 3 more entries in 'RUN':
                            	   283: * 'RUNNXL' finds next line, stores it's address and executes it.
                            	   284: * 'RUNTSL' stores the address of this line and executes it.
                            	   285: * 'RUNSML' continues the execution on same line.
                            	   286: *
                            	   287: * 'GOTO expr<CR>' evaluates the expression, finds the target
                            	   288: * line, and jumps to 'RUNTSL' to do it.
                            	   289: *
00:00010BBE 61000714        	   290: NEW	BSR	ENDCHK
00:00010BC2 23F90001097A0000	   291: 	MOVE.L	TXTBGN,TXTUNF	set the end pointer
00:00010BCA 6146
                            	   292: 
00:00010BCC 61000706        	   293: STOP	BSR	ENDCHK
00:00010BD0 6000FDE4        	   294: 	BRA	WSTART
                            	   295: 
00:00010BD4 610006FE        	   296: RUN	BSR	ENDCHK
00:00010BD8 20790001097A    	   297: 	MOVE.L	TXTBGN,A0	set pointer to beginning
00:00010BDE 23C800006126    	   298: 	MOVE.L	A0,CURRNT
                            	   299: 
00:00010BE4 4AB900006126    	   300: RUNNXL	TST.L	CURRNT		executing a program?
00:00010BEA 6700FDCA        	   301: 	BEQ	WSTART		if not, we've finished a direct stat.
00:00010BEE 4281            	   302: 	CLR.L	D1		else find the next line number
00:00010BF0 2248            	   303: 	MOVE.L	A0,A1
00:00010BF2 61000814        	   304: 	BSR	FNDLNP
00:00010BF6 6500FDBE        	   305: 	BCS	WSTART		if we've fallen off the end, stop
                            	   306: 
00:00010BFA 23C900006126    	   307: RUNTSL	MOVE.L	A1,CURRNT	set CURRNT to point to the line no.
00:00010C00 2049            	   308: 	MOVE.L	A1,A0		set the text pointer to
00:00010C02 5488            	   309: 	ADDQ.L	#2,A0		the start of the line text
                            	   310: 
00:00010C04 61000A74        	   311: RUNSML	BSR	CHKIO		see if a control-C was pressed
00:00010C08 43F900010A7A    	   312: 	LEA	TAB2,A1 	find command in TAB2
00:00010C0E 45F900010AE8    	   313: 	LEA	TAB2.1,A2
00:00010C14 6000FF5A        	   314: 	BRA	EXEC		and execute it
                            	   315: 
00:00010C18 610003FA        	   316: GOTO	BSR	EXPR		evaluate the following expression
00:00010C1C 610006B6        	   317: 	BSR	ENDCHK		must find end of line
00:00010C20 2200            	   318: 	MOVE.L	D0,D1
00:00010C22 610007D4        	   319: 	BSR	FNDLN		find the target line
00:00010C26 6600070C        	   320: 	BNE	QHOW		no such line no.
00:00010C2A 6000FFCE        	   321: 	BRA	RUNTSL		go do it
                            	   322: 
                            	   323: *
                            	   324: *******************************************************************
                            	   325: *
                            	   326: * *** LIST *** PRINT ***
                            	   327: *
                            	   328: * LIST has two forms:
                            	   329: * 'LIST<CR>' lists all saved lines
                            	   330: * 'LIST #<CR>' starts listing at the line #
                            	   331: * Control-S pauses the listing, control-C stops it.
                            	   332: *
                            	   333: * PRINT command is 'PRINT ....:' or 'PRINT ....<CR>'
                            	   334: * where '....' is a list of expressions, formats, back-arrows,
                            	   335: * and strings.	These items a separated by commas.
                            	   336: *
                            	   337: * A format is a pound sign followed by a number.  It controls
                            	   338: * the number of spaces the value of an expression is going to
                            	   339: * be printed in.  It stays effective for the rest of the print
                            	   340: * command unless changed by another format.  If no format is
                            	   341: * specified, 11 positions will be used.
                            	   342: *
                            	   343: * A string is quoted in a pair of single- or double-quotes.
                            	   344: *
                            	   345: * An underline (back-arrow) means generate a <CR> without a <LF>
                            	   346: *
                            	   347: * A <CR LF> is generated after the entire list has been printed
                            	   348: * or if the list is empty.  If the list ends with a semicolon,
                            	   349: * however, no <CR LF> is generated.
                            	   350: *
                            	   351: 
00:00010C2E 61000998        	   352: LIST	BSR	TSTNUM		see if there's a line no.
00:00010C32 610006A0        	   353: 	BSR	ENDCHK		if not, we get a zero
00:00010C36 610007C0        	   354: 	BSR	FNDLN		find this or next line
00:00010C3A 6500FD7A        	   355: LS1	BCS	WSTART		warm start if we passed the end
00:00010C3E 61000950        	   356: 	BSR	PRTLN		print the line
00:00010C42 61000A36        	   357: 	BSR	CHKIO		check for listing halt request
00:00010C46 67000012        	   358: 	BEQ	LS3
00:00010C4A B03C0013        	   359: 	CMP.B	#CTRLS,D0	pause the listing?
00:00010C4E 6600000A        	   360: 	BNE	LS3
00:00010C52 61000A26        	   361: LS2	BSR	CHKIO		if so, wait for another keypress
00:00010C56 6700FFFA        	   362: 	BEQ	LS2
00:00010C5A 610007AC        	   363: LS3	BSR	FNDLNP		find the next line
00:00010C5E 6000FFDA        	   364: 	BRA	LS1
                            	   365: 
00:00010C62 383C000B        	   366: PRINT	MOVE	#11,D4		D4 = number of print spaces
00:00010C66 61000944        	   367: 	BSR	TSTC		if null list and ":"
00:00010C6A 3A              	   368: 	DC.B	':',PR2-*
00:00010C6B 09
00:00010C6C 61000A22        	   369: 	BSR	CRLF		give CR-LF and continue
00:00010C70 6000FF92        	   370: 	BRA	RUNSML		execution on the same line
00:00010C74 61000936        	   371: PR2	BSR	TSTC		if null list and <CR>
00:00010C78 0D              	   372: 	DC.B	CR,PR0-*
00:00010C79 09
00:00010C7A 61000A14        	   373: 	BSR	CRLF		also give CR-LF and
00:00010C7E 6000FF64        	   374: 	BRA	RUNNXL		execute the next line
00:00010C82 61000928        	   375: PR0	BSR	TSTC		else is it a format?
00:00010C86 23              	   376: 	DC.B	'#',PR1-*
00:00010C87 0B
00:00010C88 6100038A        	   377: 	BSR	EXPR		yes, evaluate expression
00:00010C8C 3800            	   378: 	MOVE	D0,D4		and save it as print width
00:00010C8E 6000001A        	   379: 	BRA	PR3		look for more to print
