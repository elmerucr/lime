                            	   946: *
                            	   947: * ===== Divide the 32 bit value in D0 by the 32 bit value in D1.
                            	   948: *	Returns the 32 bit quotient in D0, remainder in D1.
                            	   949: *
00:000111AA 4A81            	   950: DIV32	TST.L	D1		check for divide-by-zero
00:000111AC 67000142        	   951: 	BEQ	QHOW		if so, say "How?"
00:000111B0 2401            	   952: 	MOVE.L	D1,D2
00:000111B2 2801            	   953: 	MOVE.L	D1,D4
00:000111B4 B184            	   954: 	EOR.L	D0,D4		see if the signs are the same
00:000111B6 4A80            	   955: 	TST.L	D0		take absolute value of D0
00:000111B8 6A000004        	   956: 	BPL	DIV1
00:000111BC 4480            	   957: 	NEG.L	D0
00:000111BE 4A81            	   958: DIV1	TST.L	D1		take absolute value of D1
00:000111C0 6A000004        	   959: 	BPL	DIV2
00:000111C4 4481            	   960: 	NEG.L	D1
00:000111C6 761F            	   961: DIV2	MOVEQ	#31,D3		iteration count for 32 bits
00:000111C8 2200            	   962: 	MOVE.L	D0,D1
00:000111CA 4280            	   963: 	CLR.L	D0
00:000111CC D281            	   964: DIV3	ADD.L	D1,D1		(This algorithm was translated from
00:000111CE D180            	   965: 	ADDX.L	D0,D0		the divide routine in Ron Cain's
00:000111D0 6700000C        	   966: 	BEQ	DIV4		Small-C run time library.)
00:000111D4 B082            	   967: 	CMP.L	D2,D0
00:000111D6 6B000006        	   968: 	BMI	DIV4
00:000111DA 5281            	   969: 	ADDQ.L	#1,D1
00:000111DC 9082            	   970: 	SUB.L	D2,D0
00:000111DE 51CBFFEC        	   971: DIV4	DBRA	D3,DIV3
00:000111E2 C141            	   972: 	EXG	D0,D1		put rem. & quot. in proper registers
00:000111E4 4A84            	   973: 	TST.L	D4		were the signs the same?
00:000111E6 6A000006        	   974: 	BPL	DIVRT
00:000111EA 4480            	   975: 	NEG.L	D0		if not, results are negative
00:000111EC 4481            	   976: 	NEG.L	D1
00:000111EE 4E75            	   977: DIVRT	RTS
                            	   978: 
                            	   979: *
                            	   980: * ===== The PEEK function returns the byte stored at the address
                            	   981: *	contained in the following expression.
                            	   982: *
00:000111F0 6100FEFE        	   983: PEEK	BSR	PARN		get the memory address
00:000111F4 2240            	   984: 	MOVE.L	D0,A1
00:000111F6 4280            	   985: 	CLR.L	D0		upper 3 bytes will be zero
00:000111F8 1011            	   986: 	MOVE.B	(A1),D0 	get the addressed byte
00:000111FA 4E75            	   987: 	RTS			and return it
                            	   988: 
                            	   989: *
                            	   990: * ===== The RND function returns a random number from 1 to
                            	   991: *	the value of the following expression in D0.
                            	   992: *
00:000111FC 6100FEF2        	   993: RND	BSR	PARN		get the upper limit
00:00011200 4A80            	   994: 	TST.L	D0		it must be positive and non-zero
00:00011202 670000EC        	   995: 	BEQ	QHOW
00:00011206 6B0000E8        	   996: 	BMI	QHOW
00:0001120A 2200            	   997: 	MOVE.L	D0,D1
00:0001120C 22790000611E    	   998: 	MOVE.L	RANPNT,A1	get memory as a random number
00:00011212 B3FC000116DB    	   999: 	CMP.L	#LSTROM,A1
00:00011218 65000008        	  1000: 	BCS	RA1
00:0001121C 43F90001091A    	  1001: 	LEA	START,A1	wrap around if end of program
00:00011222 2019            	  1002: RA1	MOVE.L	(A1)+,D0	get the slightly random number
00:00011224 0880001F        	  1003: 	BCLR	#31,D0		make sure it's positive
00:00011228 23C90000611E    	  1004: 	MOVE.L	A1,RANPNT	(even I can do better than this!)
00:0001122E 6100FF7A        	  1005: 	BSR	DIV32		RND(n)=MOD(number,n)+1
00:00011232 2001            	  1006: 	MOVE.L	D1,D0		MOD is the remainder of the div.
00:00011234 5280            	  1007: 	ADDQ.L	#1,D0
00:00011236 4E75            	  1008: 	RTS
