00:00011698 6700000A        	  1488: 	BEQ	PRMRET		if it's zero, we're done
00:0001169C 6100F2C8        	  1489: 	BSR	GOOUT		else display it
00:000116A0 6000FFF4        	  1490: 	BRA	PRMESG
00:000116A4 4E75            	  1491: PRMRET	RTS
