                            	   718: *
                            	   719: *******************************************************************
                            	   720: *
                            	   721: * *** POKE *** & CALL ***
                            	   722: *
                            	   723: * 'POKE expr1,expr2' stores the byte from 'expr2' into the memory
                            	   724: * address specified by 'expr1'.
                            	   725: *
                            	   726: * 'CALL expr' jumps to the machine language subroutine whose
                            	   727: * starting address is specified by 'expr'.  The subroutine can use
                            	   728: * all registers but must leave the stack the way it found it.
                            	   729: * The subroutine returns to the interpreter by executing an RTS.
                            	   730: *
00:00010FCA 61000030        	   731: POKE	BSR	EXPR		get the memory address
00:00010FCE 610005C4        	   732: 	BSR	TSTC		it must be followed by a comma
00:00010FD2 2C              	   733: 	DC.B	',',PKER-*
00:00010FD3 0F
00:00010FD4 2F00            	   734: 	MOVE.L	D0,-(SP)	save the address
00:00010FD6 61000024        	   735: 	BSR	EXPR		get the byte to be POKE'd
00:00010FDA 225F            	   736: 	MOVE.L	(SP)+,A1	get the address back
00:00010FDC 1280            	   737: 	MOVE.B	D0,(A1) 	store the byte in memory
00:00010FDE 6000FCDA        	   738: 	BRA	FINISH
00:00010FE2 600002E6        	   739: PKER	BRA	QWHAT		if no comma, say "What?"
                            	   740: 
00:00010FE6 61000014        	   741: CALL	BSR	EXPR		get the subroutine's address
00:00010FEA 4A80            	   742: 	TST.L	D0		make sure we got a valid address
00:00010FEC 6700032E        	   743: 	BEQ	QHOW		if not, say "How?"
00:00010FF0 2F08            	   744: 	MOVE.L	A0,-(SP)	save the text pointer
00:00010FF2 2240            	   745: 	MOVE.L	D0,A1
00:00010FF4 4E91            	   746: 	JSR	(A1)		jump to the subroutine
00:00010FF6 205F            	   747: 	MOVE.L	(SP)+,A0	restore the text pointer
00:00010FF8 6000FCC0        	   748: 	BRA	FINISH
                            	   749: *
                            	   750: *******************************************************************
                            	   751: *
                            	   752: * *** EXPR ***
                            	   753: *
                            	   754: * 'EXPR' evaluates arithmetical or logical expressions.
                            	   755: * <EXPR>::=<EXPR2>
                            	   756: *	   <EXPR2><rel.op.><EXPR2>
                            	   757: * where <rel.op.> is one of the operators in TAB8 and the result
                            	   758: * of these operations is 1 if true and 0 if false.
                            	   759: * <EXPR2>::=(+ or -)<EXPR3>(+ or -)<EXPR3>(...
                            	   760: * where () are optional and (... are optional repeats.
                            	   761: * <EXPR3>::=<EXPR4>( <* or /><EXPR4> )(...
                            	   762: * <EXPR4>::=<variable>
                            	   763: *	    <function>
                            	   764: *	    (<EXPR>)
                            	   765: * <EXPR> is recursive so that the variable '@' can have an <EXPR>
                            	   766: * as an index, functions can have an <EXPR> as arguments, and
                            	   767: * <EXPR4> can be an <EXPR> in parenthesis.
                            	   768: *
00:00010FFC 6100007E        	   769: EXPR	BSR	EXPR2
00:00011000 2F00            	   770: 	MOVE.L	D0,-(SP)	save <EXPR2> value
00:00011002 43F900010AB1    	   771: 	LEA	TAB8,A1 	look up a relational operator
00:00011008 45F900010B30    	   772: 	LEA	TAB8.1,A2
00:0001100E 6000FB48        	   773: 	BRA	EXEC		go do it
                            	   774: 
00:00011012 61000056        	   775: XP11	BSR	XP18		is it ">="?
00:00011016 6D000046        	   776: 	BLT	XPRT0		no, return D0=0
00:0001101A 60000046        	   777: 	BRA	XPRT1		else return D0=1
                            	   778: 
00:0001101E 6100004A        	   779: XP12	BSR	XP18		is it "<>"?
00:00011022 6700003A        	   780: 	BEQ	XPRT0		no, return D0=0
00:00011026 6000003A        	   781: 	BRA	XPRT1		else return D0=1
                            	   782: 
00:0001102A 6100003E        	   783: XP13	BSR	XP18		is it ">"?
00:0001102E 6F00002E        	   784: 	BLE	XPRT0		no, return D0=0
00:00011032 6000002E        	   785: 	BRA	XPRT1		else return D0=1
                            	   786: 
00:00011036 61000032        	   787: XP14	BSR	XP18		is it "<="?
00:0001103A 6E000022        	   788: 	BGT	XPRT0		no, return D0=0
00:0001103E 60000022        	   789: 	BRA	XPRT1		else return D0=1
                            	   790: 
00:00011042 61000026        	   791: XP15	BSR	XP18		is it "="?
00:00011046 66000016        	   792: 	BNE	XPRT0		if not, return D0=0
00:0001104A 60000016        	   793: 	BRA	XPRT1		else return D0=1
00:0001104E 4E75            	   794: XP15RT	RTS
                            	   795: 
00:00011050 61000018        	   796: XP16	BSR	XP18		is it "<"?
00:00011054 6C000008        	   797: 	BGE	XPRT0		if not, return D0=0
00:00011058 60000008        	   798: 	BRA	XPRT1		else return D0=1
00:0001105C 4E75            	   799: XP16RT	RTS
                            	   800: 
00:0001105E 4280            	   801: XPRT0	CLR.L	D0		return D0=0 (false)
00:00011060 4E75            	   802: 	RTS
                            	   803: 
00:00011062 7001            	   804: XPRT1	MOVEQ	#1,D0		return D0=1 (true)
00:00011064 4E75            	   805: 	RTS
                            	   806: 
00:00011066 201F            	   807: XP17	MOVE.L	(SP)+,D0	it's not a rel. operator
00:00011068 4E75            	   808: 	RTS			return D0=<EXPR2>
                            	   809: 
00:0001106A 201F            	   810: XP18	MOVE.L	(SP)+,D0	reverse the top two stack items
00:0001106C 221F            	   811: 	MOVE.L	(SP)+,D1
00:0001106E 2F00            	   812: 	MOVE.L	D0,-(SP)
00:00011070 2F01            	   813: 	MOVE.L	D1,-(SP)
00:00011072 61000008        	   814: 	BSR	EXPR2		do second <EXPR2>
00:00011076 221F            	   815: 	MOVE.L	(SP)+,D1
00:00011078 B280            	   816: 	CMP.L	D0,D1		compare with the first result
00:0001107A 4E75            	   817: 	RTS			return the result
                            	   818: 
00:0001107C 61000516        	   819: EXPR2	BSR	TSTC		negative sign?
00:00011080 2D              	   820: 	DC.B	'-',XP21-*
00:00011081 07
00:00011082 4280            	   821: 	CLR.L	D0		yes, fake '0-'
00:00011084 6000002A        	   822: 	BRA	XP26
00:00011088 6100050A        	   823: XP21	BSR	TSTC		positive sign? ignore it
00:0001108C 2B              	   824: 	DC.B	'+',XP22-*
00:0001108D 01
00:0001108E 6100002E        	   825: XP22	BSR	EXPR3		first <EXPR3>
00:00011092 61000500        	   826: XP23	BSR	TSTC		add?
00:00011096 2B              	   827: 	DC.B	'+',XP25-*
00:00011097 13
00:00011098 2F00            	   828: 	MOVE.L	D0,-(SP)	yes, save the value
00:0001109A 61000022        	   829: 	BSR	EXPR3		get the second <EXPR3>
00:0001109E 221F            	   830: XP24	MOVE.L	(SP)+,D1
00:000110A0 D081            	   831: 	ADD.L	D1,D0		add it to the first <EXPR3>
00:000110A2 69000278        	   832: 	BVS	QHOW		branch if there's an overflow
00:000110A6 6000FFEA        	   833: 	BRA	XP23		else go back for more operations
00:000110AA 610004E8        	   834: XP25	BSR	TSTC		subtract?
00:000110AE 2D              	   835: 	DC.B	'-',XP42-*
00:000110AF 7D
00:000110B0 2F00            	   836: XP26	MOVE.L	D0,-(SP)	yes, save the result of 1st <EXPR3>
00:000110B2 6100000A        	   837: 	BSR	EXPR3		get second <EXPR3>
00:000110B6 4480            	   838: 	NEG.L	D0		change its sign
00:000110B8 4EF90001109E    	   839: 	JMP	XP24		and do an addition
                            	   840: 
00:000110BE 61000030        	   841: EXPR3	BSR	EXPR4		get first <EXPR4>
00:000110C2 610004D0        	   842: XP31	BSR	TSTC		multiply?
00:000110C6 2A              	   843: 	DC.B	'*',XP34-*
00:000110C7 11
00:000110C8 2F00            	   844: 	MOVE.L	D0,-(SP)	yes, save that first result
00:000110CA 61000024        	   845: 	BSR	EXPR4		get second <EXPR4>
00:000110CE 221F            	   846: 	MOVE.L	(SP)+,D1
00:000110D0 610000BA        	   847: 	BSR	MULT32		multiply the two
00:000110D4 6000FFEC        	   848: 	BRA	XP31		then look for more terms
00:000110D8 610004BA        	   849: XP34	BSR	TSTC		divide?
00:000110DC 2F              	   850: 	DC.B	'/',XP42-*
00:000110DD 4F
00:000110DE 2F00            	   851: 	MOVE.L	D0,-(SP)	save result of 1st <EXPR4>
00:000110E0 6100000E        	   852: 	BSR	EXPR4		get second <EXPR4>
00:000110E4 221F            	   853: 	MOVE.L	(SP)+,D1
00:000110E6 C141            	   854: 	EXG	D0,D1
00:000110E8 610000EC        	   855: 	BSR	DIV32		do the division
