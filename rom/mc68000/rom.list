                            	  6304: 							* now evaluate result
00:00002E9C 4A2B05AF        	  6305: 	TST.b		expneg(a3)			* test exponent sign
00:00002EA0 6A02            	  6306: 	BPL.s		LAB_2Y02			* branch if sign positive
                            	  6307: 
00:00002EA2 4484            	  6308: 	NEG.l		d4				* negate decimal exponent
                            	  6309: LAB_2Y02
00:00002EA4 D883            	  6310: 	ADD.l		d3,d4				* add mantissa decimal exponent
00:00002EA6 7620            	  6311: 	moveq		#32,d3			* set up max binary exponent
00:00002EA8 4A81            	  6312: 	TST.l		d1				* test mantissa
00:00002EAA 6752            	  6313: 	BEQ.s		LAB_rtn0			* if mantissa=0 return 0
                            	  6314: 
00:00002EAC 6B08            	  6315: 	BMI.s		LAB_2Y04			* branch if already mormalised
                            	  6316: 
00:00002EAE 5383            	  6317: 	SUBQ.l	#1,d3				* decrement bianry exponent for DBMI loop
                            	  6318: LAB_2Y03
00:00002EB0 D281            	  6319: 	ADD.l		d1,d1				* shift mantissa
00:00002EB2 5BCBFFFC        	  6320: 	DBMI		d3,LAB_2Y03			* decrement & loop if not normalised
                            	  6321: 
                            	  6322: 							* ensure not too big or small
                            	  6323: LAB_2Y04
00:00002EB6 B8BC00000026    	  6324: 	CMP.l		#38,d4			* compare decimal exponent with max exponent
00:00002EBC 6E00DB74        	  6325: 	BGT		LAB_OFER			* if greater do overflow error and warm start
                            	  6326: 
00:00002EC0 B8BCFFFFFFDA    	  6327: 	CMP.l		#-38,d4			* compare decimal exponent with min exponent
00:00002EC6 6D34            	  6328: 	BLT.s		LAB_ret0			* if less just return zero
                            	  6329: 
00:00002EC8 4484            	  6330: 	NEG.l		d4				* negate decimal exponent to go right way
00:00002ECA C9FC0006        	  6331: 	MULS		#6,d4				* 6 bytes per entry
00:00002ECE 2F08            	  6332: 	move.l	a0,-(sp)			* save register
00:00002ED0 41FA0210        	  6333: 	lea		(LAB_P_10,PC),a0		* point to table
00:00002ED4 17704001059C    	  6334: 	move.b	1(a0,d4.w),FAC2_e(a3)	* copy exponent for multiply
00:00002EDA 277040020598    	  6335: 	move.l	2(a0,d4.w),FAC2_m(a3)	* copy table mantissa
00:00002EE0 205F            	  6336: 	move.l	(sp)+,a0			* restore register
                            	  6337: 
00:00002EE2 0A030080        	  6338: 	EORI.b	#$80,d3			* normalise input exponent
00:00002EE6 27410590        	  6339: 	move.l	d1,FAC1_m(a3)		* save input mantissa
00:00002EEA 17430594        	  6340: 	move.b	d3,FAC1_e(a3)		* save input exponent
00:00002EEE 176B0595059E    	  6341: 	move.b	FAC1_s(a3),FAC_sc(a3)	* set sign as sign compare
                            	  6342: 
00:00002EF4 4CDF003E        	  6343: 	movem.l	(sp)+,d1-d5			* restore registers
00:00002EF8 6000F372        	  6344: 	BRA		LAB_MULTIPLY		* go multiply input by table
                            	  6345: 
