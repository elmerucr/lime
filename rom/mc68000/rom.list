                            	  6237: 							* flush remaining fractional digits
00:00002DAA 6100E7BE        	  6238: 	BSR		LAB_IGBY			* get next character
00:00002DAE 6500FFFA        	  6239: 	BCS		LAB_2900			* loop while numeric character
                            	  6240: 
