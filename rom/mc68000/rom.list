                            	  1480: * ===== Display a CR-LF sequence
                            	  1481: *
00:00011678 4DF900011703    	  1482: CRLF	LEA	CLMSG,A6
                            	  1483: 
                            	  1484: *
                            	  1485: * ===== Display a zero-ended string pointed to by register A6
                            	  1486: *
00:0001167E 101E            	  1487: PRMESG	MOVE.B	(A6)+,D0	get the char.
00:00011680 6700000A        	  1488: 	BEQ	PRMRET		if it's zero, we're done
00:00011684 6100F2C8        	  1489: 	BSR	GOOUT		else display it
00:00011688 6000FFF4        	  1490: 	BRA	PRMESG
00:0001168C 4E75            	  1491: PRMRET	RTS
