                            	   279: ****************************************************************************************
                            	   280: ****************************************************************************************
                            	   281: ****************************************************************************************
                            	   282: ****************************************************************************************
                            	   283: *
                            	   284: * Register use :- (must improve this !!)
                            	   285: *
                            	   286: *	a6 -	temp Bpntr				* temporary BASIC execute pointer
                            	   287: *	a5 -	Bpntr					* BASIC execute (get byte) pointer
                            	   288: *	a4 -	des_sk				* descriptor stack pointer
                            	   289: *	a3 -	ram_strt				* start of RAM. all RAM references are offsets
                            	   290: *							* from this value
                            	   291: *	a2 -	general purpose
                            	   292: *	a1 -	general purpose
                            	   293: *	a0 -	general purpose
                            	   294: *
                            	   295: *	d7 -	FAC1 mantissa			* to do
                            	   296: *	d6 -	FAC1 sign & exponent		* to do
                            	   297: *	d5 -	FAC2 mantissa			* to do
                            	   298: *	d4 -	FAC2 sign & exponent		* to do
                            	   299: *	d3 -	BASIC got byte			* to do
                            	   300: *	d2 -
                            	   301: *	d1 -	general purpose
                            	   302: *	d0 -	general purpose
                            	   303: *
                            	   304: 
                            	   305: * turn off simulator key echo
                            	   306: 
                            	   307: code_start
                            	   308: 	;moveq		#12,d0			* keyboard echo
                            	   309: 	;moveq		#0,d1			* turn off echo
                            	   310: 	;trap		#15			* do I/O function
                            	   311: 
                            	   312: * end of simulator specific code
                            	   313: 
                            	   314: * BASIC cold start entry point. assume entry with RAM address in a0 and RAM length
                            	   315: * in d0, for now we fake that with these extra move instructions
                            	   316: 
00:00000928 207C00040000    	   317: 	MOVEA.l	#$40000,a0			* tell BASIC where RAM is
00:0000092E 203C00040000    	   318: 	move.l	#ram_top,d0			* tell BASIC how big RAM is
                            	   319: 
                            	   320: LAB_COLD
00:00000934 B0BC00004000    	   321: 	CMP.l		#$4000,d0			* compare size with 16k
00:0000093A 6C04            	   322: 	BGE.s		LAB_sizok			* branch if >= 16k
                            	   323: 
00:0000093C 7005            	   324: 	moveq		#5,d0				* error 5 - not enough RAM
00:0000093E 4E75            	   325: 	RTS						* just exit. this as stands will never execute
                            	   326: 							* but could be used to exit to an OS
                            	   327: 
                            	   328: LAB_sizok
00:00000940 2648            	   329: 	MOVEA.l	a0,a3				* copy RAM base to a3
00:00000942 D1C0            	   330: 	ADDA.l	d0,a0				* a0 is top of RAM
00:00000944 2748044A        	   331: 	move.l	a0,Ememl(a3)		* set end of mem
00:00000948 4FEB0400        	   332: 	lea		ram_base(a3),sp		* set stack to RAM start + 1k
                            	   333: 
00:0000094C 303C4EF9        	   334: 	MOVE.w	#$4EF9,d0			* JMP opcode
00:00000950 204F            	   335: 	MOVEA.l	sp,a0				* point to start of vector table
                            	   336: 
00:00000952 30C0            	   337: 	MOVE.w	d0,(a0)+			* LAB_WARM
00:00000954 43FAFFDE        	   338: 	lea		(LAB_COLD,PC),a1		* initial warm start vector
00:00000958 20C9            	   339: 	move.l	a1,(a0)+			* set vector
                            	   340: 
00:0000095A 30C0            	   341: 	MOVE.w	d0,(a0)+			* Usrjmp
00:0000095C 43FA00D8        	   342: 	lea		(LAB_FCER,PC),a1		* initial user function vector
                            	   343: 							* "Function call" error
00:00000960 20C9            	   344: 	move.l	a1,(a0)+			* set vector
                            	   345: 
00:00000962 30C0            	   346: 	MOVE.w	d0,(a0)+			* V_INPT JMP opcode
00:00000964 43FAFE1A        	   347: 	lea	(VEC_IN,PC),a1			* get byte from input device vector
00:00000968 20C9            	   348: 	move.l	a1,(a0)+			* set vector
                            	   349: 
00:0000096A 30C0            	   350: 	MOVE.w	d0,(a0)+			* V_OUTP JMP opcode
00:0000096C 43FAFE02        	   351: 	lea		(VEC_OUT,PC),a1		* send byte to output device vector
00:00000970 20C9            	   352: 	move.l	a1,(a0)+			* set vector
                            	   353: 
00:00000972 30C0            	   354: 	MOVE.w	d0,(a0)+			* V_LOAD JMP opcode
00:00000974 43FAFE2E        	   355: 	lea		(VEC_LD,PC),a1		* load BASIC program vector
00:00000978 20C9            	   356: 	move.l	a1,(a0)+			* set vector
                            	   357: 
00:0000097A 30C0            	   358: 	MOVE.w	d0,(a0)+			* V_SAVE JMP opcode
00:0000097C 43FAFEE4        	   359: 	lea		(VEC_SV,PC),a1		* save BASIC program vector
00:00000980 20C9            	   360: 	move.l	a1,(a0)+			* set vector
                            	   361: 
00:00000982 30C0            	   362: 	MOVE.w	d0,(a0)+			* V_CTLC JMP opcode
00:00000984 43FA2268        	   363: 	lea		(VEC_CC,PC),a1		* save CTRL-C check vector
00:00000988 20C9            	   364: 	move.l	a1,(a0)+			* set vector
                            	   365: 
