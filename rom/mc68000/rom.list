00:00002D3C 4E75            	  6160: 	RTS
                            	  6161: 
                            	  6162: * get ASCII string equivalent into FAC1 as integer32 or float
                            	  6163: 
                            	  6164: * entry is with a5 pointing to the first character of the string
                            	  6165: * exit with a5 pointing to the first character after the string
                            	  6166: 
                            	  6167: * d0 is character
                            	  6168: * d1 is mantissa
                            	  6169: * d2 is partial and table mantissa
                            	  6170: * d3 is mantissa exponent (decimal & binary)
                            	  6171: * d4 is decimal exponent
                            	  6172: 
                            	  6173: * get FAC1 from string
                            	  6174: * this routine now handles hex and binary values from strings
                            	  6175: * starting with "$" and "%" respectively
                            	  6176: 
                            	  6177: LAB_2887
00:00002D3E 48E77C00        	  6178: 	movem.l	d1-d5,-(sp)			* save registers
00:00002D42 7200            	  6179: 	moveq		#$00,d1			* clear temp accumulator
00:00002D44 2601            	  6180: 	move.l	d1,d3				* set mantissa decimal exponent count
00:00002D46 2801            	  6181: 	move.l	d1,d4				* clear decimal exponent
00:00002D48 17410595        	  6182: 	move.b	d1,FAC1_s(a3)		* clear sign byte
00:00002D4C 174105B5        	  6183: 	move.b	d1,Dtypef(a3)		* set float data type
00:00002D50 174105AF        	  6184: 	move.b	d1,expneg(a3)		* clear exponent sign
00:00002D54 6100E816        	  6185: 	BSR		LAB_GBYT			* get first byte back
00:00002D58 653C            	  6186: 	BCS.s		LAB_28FE			* go get floating if 1st character numeric
                            	  6187: 
00:00002D5A B03C002D        	  6188: 	CMP.b		#'-',d0			* or is it -ve number
00:00002D5E 6608            	  6189: 	BNE.s		LAB_289A			* branch if not
                            	  6190: 
00:00002D60 177C00FF0595    	  6191: 	move.b	#$FF,FAC1_s(a3)		* set sign byte
00:00002D66 6006            	  6192: 	BRA.s		LAB_289C			* now go scan & check for hex/bin/int
                            	  6193: 
                            	  6194: LAB_289A
                            	  6195: 							* first character wasn't numeric or -
00:00002D68 B03C002B        	  6196: 	CMP.b		#'+',d0			* compare with '+'
