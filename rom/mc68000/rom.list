00:0001143A 6000FFF6        	  1224: 	BRA	MVUP
00:0001143E 4E75            	  1225: MVRET	RTS
                            	  1226: 
00:00011440 B5C9            	  1227: MVDOWN	CMP.L	A1,A2		see the above description
00:00011442 6700FFFA        	  1228: 	BEQ	MVRET
00:00011446 1721            	  1229: 	MOVE.B	-(A1),-(A3)
00:00011448 6000FFF6        	  1230: 	BRA	MVDOWN
                            	  1231: 
