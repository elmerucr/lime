                            	    44: 
                            	    45: 	section	code
                            	    46: 	;org	$020000			* past the vectors in a real system
                            	    47: 
                            	    48: * the following code is simulator specific, change to suit your system
                            	    49: 
                            	    50: * output character to the console from register D0
                            	    51: 
                            	    52: VEC_OUT
00:00000770 48E7C000        	    53: 	movem.l	D0-D1,-(SP)	* save D0, D1
00:00000774 1200            	    54: 	move.b	D0,D1		* copy character
00:00000776 7001            	    55: 	moveq	#1,D0		* character out (function one in trap #15)
00:00000778 4E4F            	    56: 	trap	#15		* do I/O function
