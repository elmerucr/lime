00:00010C0C 45F900010AE6    	   313: 	LEA	TAB2.1,A2
00:00010C12 6000FF5A        	   314: 	BRA	EXEC		and execute it
                            	   315: 
00:00010C16 610003FA        	   316: GOTO	BSR	EXPR		evaluate the following expression
