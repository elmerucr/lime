                            	   629: *
                            	   630: *******************************************************************
                            	   631: *
                            	   632: * *** LOAD *** & SAVE ***
                            	   633: *
                            	   634: * These two commands transfer a program to/from an auxiliary
                            	   635: * device such as a cassette, another computer, etc.  The program
                            	   636: * is converted to an easily-stored format: each line starts with
                            	   637: * a colon, the line no. as 4 hex digits, and the rest of the line.
                            	   638: * At the end, a line starting with an '@' sign is sent.  This
                            	   639: * format can be read back with a minimum of processing time by
                            	   640: * the 68000.
                            	   641: *
00:00010EDE 20790001097A    	   642: LOAD	MOVE.L	TXTBGN,A0	set pointer to start of prog. area
00:00010EE4 103C000D        	   643: 	MOVE.B	#CR,D0		For a CP/M host, tell it we're ready...
00:00010EE8 6100FA84        	   644: 	BSR	GOAUXO		by sending a CR to finish PIP command.
00:00010EEC 6100FA84        	   645: LOD1	BSR	GOAUXI		look for start of line
00:00010EF0 6700FFFA        	   646: 	BEQ	LOD1
00:00010EF4 B03C0040        	   647: 	CMP.B	#'@',D0         end of program?
00:00010EF8 6700002C        	   648: 	BEQ	LODEND
