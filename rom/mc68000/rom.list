00:00002D6E 6100E7FA        	  6202: 	BSR		LAB_IGBY			* increment & scan memory
00:00002D72 6522            	  6203: 	BCS.s		LAB_28FE			* branch if numeric character
                            	  6204: 
                            	  6205: LAB_289D
00:00002D74 B03C002E        	  6206: 	CMP.b		#'.',d0			* else compare with '.'
00:00002D78 67000094        	  6207: 	BEQ		LAB_2904			* branch if '.'
                            	  6208: 
                            	  6209: 							* code here for hex/binary/integer numbers
00:00002D7C B03C0024        	  6210: 	CMP.b		#'$',d0			* compare with '$'
00:00002D80 6700010C        	  6211: 	BEQ		LAB_CHEX			* branch if '$'
                            	  6212: 
00:00002D84 B03C0025        	  6213: 	CMP.b		#'%',d0			* else compare with '%'
