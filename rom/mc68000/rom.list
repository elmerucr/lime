                            	     6: ;-----------------------------------------------------------------------
                            	     7: ; Calling convention:
                            	     8: ; - D0-D1/A0-A1 are scratch registers, and need to be caller saved
                            	     9: ;   when to be kept
                            	    10: ; - Calling a trap is an exception, but otherwise works the same as
                            	    11: ;   a conventional function / routine (scratch registers)
                            	    12: ; - Other (real) exceptions will save and restore all registers
                            	    13: ; - Tab size: 8
                            	    14: ;-----------------------------------------------------------------------
