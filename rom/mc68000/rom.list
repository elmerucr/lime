                            	   541: ; ----------------------------------------------------------------------
                            	   542: terminal_putchar
00:00010594 20790000600A    	   543: 	movea.l	terminal_chars,A0
00:0001059A 22790000600E    	   544: 	movea.l	terminal_colors,A1
00:000105A0 323900006006    	   545: 	move.w	cursor_pos,D1
                            	   546: 
00:000105A6 B03C000A        	   547: 	cmp.b	#$0a,D0			; check for linefeed
00:000105AA 6700004E        	   548: 	beq	.lf
00:000105AE B03C000D        	   549: 	cmp.b	#$0d,D0			; check for carriage return
00:000105B2 6700004A        	   550: 	beq	.cr
00:000105B6 B03C001D        	   551: 	cmp.b	#$1d,D0			; cursor right
00:000105BA 6700002E        	   552: 	beq	.right
00:000105BE B03C0011        	   553: 	cmp.b	#$11,D0			; cursor down
00:000105C2 6700005E        	   554: 	beq	.down
00:000105C6 B03C0091        	   555: 	cmp.b	#$91,D0			; cursor up
00:000105CA 67000060        	   556: 	beq	.up
00:000105CE B03C009D        	   557: 	cmp.b	#$9d,D0			; cursor left
00:000105D2 67000064        	   558: 	beq	.left
00:000105D6 B03C0008        	   559: 	cmp.b	#$08,D0			; backspace
00:000105DA 6700007A        	   560: 	beq	.bs
                            	   561: 
