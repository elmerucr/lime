00:00010E92 2F0A            	   605: 	MOVE.L	A2,-(SP)	save the variable address
00:00010E94 103C003A        	   606: 	MOVE.B	#':',D0         print a colon first
00:00010E98 610004A4        	   607: 	BSR	GETLN		then get an input line
00:00010E9C 41F90000615A    	   608: 	LEA	BUFFER,A0	point to the buffer
00:00010EA2 6100016E        	   609: 	BSR	EXPR		evaluate the input
00:00010EA6 245F            	   610: 	MOVE.L	(SP)+,A2	restore the variable address
00:00010EA8 2480            	   611: 	MOVE.L	D0,(A2) 	save value in variable
00:00010EAA 23DF0000612E    	   612: 	MOVE.L	(SP)+,CURRNT	restore old 'CURRNT'
00:00010EB0 205F            	   613: 	MOVE.L	(SP)+,A0	and the old text pointer
00:00010EB2 588F            	   614: IP4	ADDQ.L	#4,SP		clean up the stack
00:00010EB4 610006F4        	   615: 	BSR	TSTC		is the next thing a comma?
00:00010EB8 2C              	   616: 	DC.B	',',IP5-*
00:00010EB9 05
00:00010EBA 6000FF8E        	   617: 	BRA	INPUT		yes, more items
00:00010EBE 6000FE10        	   618: IP5	BRA	FINISH
                            	   619: 
00:00010EC2 0C10000A        	   620: DEFLT	CMP.B	#LF,(A0)	empty line is OK
00:00010EC6 67000010        	   621: 	BEQ	LT1		else it is 'LET'
                            	   622: 
00:00010ECA 610003CE        	   623: LET	BSR	SETVAL		do the assignment
00:00010ECE 610006DA        	   624: 	BSR	TSTC		check for more 'LET' items
00:00010ED2 2C              	   625: 	DC.B	',',LT1-*
00:00010ED3 05
00:00010ED4 6000FFF4        	   626: 	BRA	LET
