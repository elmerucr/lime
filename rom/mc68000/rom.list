                            	     1: *****************************************************************
                            	     2: *								*
                            	     3: *	Enhanced BASIC for the Motorola MC680xx			*
                            	     4: *								*
                            	     5: * 	Derived from EhBASIC for the 6502 and adapted by:	*
                            	     6: * 	Lee Davison						*
                            	     7: *								*
                            	     8: *	mail : leeedavison@lycos.co.uk				*
                            	     9: *								*
                            	    10: *	This is the generic version with I/O and LOAD/SAVE	*
                            	    11: *	example code for the EASy68k editor/simulator.		*
                            	    12: *	2002/3/4/5.						*
                            	    13: *								*
                            	    14: *****************************************************************
                            	    15: *								*
                            	    16: *	Copyright (C) 2002/3/4/5 by Lee Davison. This program	*
                            	    17: *	may be freely distributed for personal use only.	*
                            	    18: *	All commercial rights are reserved.			*
                            	    19: *								*
                            	    20: *****************************************************************
                            	    21: *								*
                            	    22: *	The choice of memory areas in this code is set to	*
                            	    23: *	reflect the actual memory present on a 68008 SBC	*
                            	    24: *	that I have.						*
                            	    25: *								*
                            	    26: *	Memory map:						*
                            	    27: *								*
                            	    28: *	ROM	$000000 - $00FFFF				*
                            	    29: *	RAM	$040000 - $048000 ($050000 optional)		*
                            	    30: *								*
                            	    31: *****************************************************************
                            	    32: 
                            	    33: * Ver 3.21
                            	    34: 
                            	    35: * Version 3.xx replaces the fixed RAM addressing from previous versions with a RAM
                            	    36: * pointer in a3. this means that this could now be run as a task on a multitasking
                            	    37: * system where memory resources may change.
                            	    38: 
                            	    39: * $3D04 $37B6 $3784 $3670
                            	    40: 
                            	    41: ;	OPT	CRE
                            	    42: 
                            	    43: 	include	"ehbasicm68k.inc"	* RAM offset definitions

Source: "ehbasicm68k.inc"
