00:00002856 277CB8AA3B290598	  5426: 	move.l	#$B8AA3B29,FAC2_m(a3)	* 1/LOG(2) mantissa
00:0000285E 377C8100059C    	  5427: 	MOVE.w	#$8100,FAC2_e(a3)		* 1/LOG(2) exponent & sign
00:00002864 177C0000059E    	  5428: 	move.b	#0,FAC_sc(a3)		* we know they're both +ve
00:0000286A 6100FA00        	  5429: 	BSR		LAB_MULTIPLY		* effectively divide by log(2)
                            	  5430: 
