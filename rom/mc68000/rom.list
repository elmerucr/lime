00:00002E00 65FA            	  6281: 	BCS.s		LAB_2X05			* loop while numeric digit
                            	  6282: 
00:00002E02 6018            	  6283: 	BRA.s		LAB_2Y01			* all done, go evaluate
                            	  6284: 
