00:0001148A 2F390000614A    	  1247: 	MOVE.L	LOPPT,-(SP)	else save all the others
00:00011490 2F3900006146    	  1248: 	MOVE.L	LOPLN,-(SP)
00:00011496 2F3900006142    	  1249: 	MOVE.L	LOPLMT,-(SP)
00:0001149C 2F390000613E    	  1250: 	MOVE.L	LOPINC,-(SP)
