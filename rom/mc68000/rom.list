00:0000296E 203C80000000    	  5634: 	move.l	#$80000000,d0		* mantissa for 1.0
00:00002974 2203            	  5635: 	move.l	d3,d1				* mantissa for 0.0
00:00002976 6062            	  5636: 	BRA.s		outloop			* go output it
                            	  5637: 
