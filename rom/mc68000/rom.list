00:00002CAE 67F0            	  6087: 	BEQ.s		RTS_023			* exit if zero
                            	  6088: 
00:00002CB0 48E77800        	  6089: 	movem.l	d1-d4,-(sp)			* save registers
00:00002CB4 202B0590        	  6090: 	move.l	FAC1_m(a3),d0		* copy FAC1
00:00002CB8 7400            	  6091: 	moveq		#0,d2				* clear remainder
