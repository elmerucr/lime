00:00002888 DC7C0020        	  5444: 	ADD.w		#32,d6			* is now 32-d6
00:0000288C ECA9            	  5445: 	LSR.l		d6,d1				* just integer bits
00:0000288E 174105D9        	  5446: 	move.b	d1,tpower(a3)		* set exponent add byte
                            	  5447: 
00:00002892 EBA8            	  5448: 	LSL.l		d5,d0				* shift out integer bits
00:00002894 6700FF68        	  5449: 	BEQ		LAB_EXOF			* fraction is zero so do 2^n
                            	  5450: 
