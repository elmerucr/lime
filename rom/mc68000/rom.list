00:00011064 221F            	   811: 	MOVE.L	(SP)+,D1
00:00011066 2F00            	   812: 	MOVE.L	D0,-(SP)
00:00011068 2F01            	   813: 	MOVE.L	D1,-(SP)
00:0001106A 61000008        	   814: 	BSR	EXPR2		do second <EXPR2>
00:0001106E 221F            	   815: 	MOVE.L	(SP)+,D1
00:00011070 B280            	   816: 	CMP.L	D0,D1		compare with the first result
00:00011072 4E75            	   817: 	RTS			return the result
