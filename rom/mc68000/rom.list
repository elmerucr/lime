                            	  1493: ******************************************************
                            	  1494: * The following routines are the only ones that need *
                            	  1495: * to be changed for a different I/O environment.     *
                            	  1496: ******************************************************
                            	  1497: 
                            	  1498: *
                            	  1499: * ===== Output character to the console (Port 1) from register D0
                            	  1500: *	(Preserves all registers.)
                            	  1501: *
                            	  1502: ;OUTC	BTST	#1,$10040	is port 1 ready for a character?
                            	  1503: ;	BEQ	OUTC		if not, wait for it
                            	  1504: ;	MOVE.B	D0,$10042	out it goes.
                            	  1505: ;	RTS
00:000116A4 48E7C0C0        	  1506: OUTC	movem.l	D0-D1/A0-A1,-(SP)
00:000116A8 1200            	  1507: 	move.b	D0,D1
00:000116AA 7001            	  1508: 	moveq	#1,D0
00:000116AC 4E4F            	  1509: 	trap	#15
00:000116AE 4CDF0303        	  1510: 	movem.l	(SP)+,D0-D1/A0-A1
00:000116B2 4E75            	  1511: 	rts
                            	  1512: 
                            	  1513: *
                            	  1514: * ===== Input a character from the console into register D0 (or
                            	  1515: *	return Zero status if there's no character available).
                            	  1516: *
                            	  1517: ;INC	BTST	#0,$10040	is character ready?
                            	  1518: ;	BEQ	INCRET		if not, return Zero status
                            	  1519: ;	MOVE.B	$10042,D0	else get the character
                            	  1520: ;	AND.B	#$7F,D0 	zero out the high bit
                            	  1521: ;INCRET	RTS
00:000116B4 10380606        	  1522: INC	move.b	$606.w,D0
00:000116B8 4E75            	  1523: 	rts
                            	  1524: 
                            	  1525: *
                            	  1526: * ===== Output character to the host (Port 2) from register D0
                            	  1527: *	(Preserves all registers.)
                            	  1528: *
                            	  1529: ;AUXOUT	BTST	#1,$10041	is port 2 ready for a character?
                            	  1530: ;	BEQ	AUXOUT		if not, wait for it
                            	  1531: ;	MOVE.B	D0,$10043	out it goes.
                            	  1532: ;	RTS
00:000116BA 48E7C0C0        	  1533: AUXOUT	movem.l	D0-D1/A0-A1,-(SP)
00:000116BE 1200            	  1534: 	move.b	D0,D1
00:000116C0 7001            	  1535: 	moveq	#1,D0
00:000116C2 4E4F            	  1536: 	trap	#15
00:000116C4 4CDF0303        	  1537: 	movem.l	(SP)+,D0-D1/A0-A1
00:000116C8 4E75            	  1538: 	rts
                            	  1539: 
                            	  1540: 
                            	  1541: *
                            	  1542: * ===== Input a character from the host into register D0 (or
                            	  1543: *	return Zero status if there's no character available).
                            	  1544: *
                            	  1545: ;AUXIN	BTST	#0,$10041	is character ready?
                            	  1546: ;	BEQ	AXIRET		if not, return Zero status
                            	  1547: ;	MOVE.B	$10043,D0	else get the character
                            	  1548: ;	AND.B	#$7F,D0 	zero out the high bit
                            	  1549: ;AXIRET	RTS
00:000116CA 10380606        	  1550: AUXIN	move.b	$606.w,D0
00:000116CE 4E75            	  1551: 	rts
                            	  1552: 
                            	  1553: *
                            	  1554: * ===== Return to the resident monitor, operating system, etc.
                            	  1555: *
00:000116D0 1E3C00E4        	  1556: BYEBYE	MOVE.B	#228,D7 	return to Tutor
00:000116D4 4E4E            	  1557: 	TRAP	#14
