00:00010EE8 6600FFEA        	   650: 	BNE	LOD1		if not, wait for it
00:00010EEC 6100002A        	   651: 	BSR	GBYTE		get first byte of line no.
00:00010EF0 10C1            	   652: 	MOVE.B	D1,(A0)+	store it
00:00010EF2 61000024        	   653: 	BSR	GBYTE		get 2nd bye of line no.
