                            	   946: *
                            	   947: * ===== Divide the 32 bit value in D0 by the 32 bit value in D1.
                            	   948: *	Returns the 32 bit quotient in D0, remainder in D1.
                            	   949: *
00:000111D6 4A81            	   950: DIV32	TST.L	D1		check for divide-by-zero
00:000111D8 67000142        	   951: 	BEQ	QHOW		if so, say "How?"
00:000111DC 2401            	   952: 	MOVE.L	D1,D2
00:000111DE 2801            	   953: 	MOVE.L	D1,D4
00:000111E0 B184            	   954: 	EOR.L	D0,D4		see if the signs are the same
00:000111E2 4A80            	   955: 	TST.L	D0		take absolute value of D0
00:000111E4 6A000004        	   956: 	BPL	DIV1
00:000111E8 4480            	   957: 	NEG.L	D0
00:000111EA 4A81            	   958: DIV1	TST.L	D1		take absolute value of D1
00:000111EC 6A000004        	   959: 	BPL	DIV2
00:000111F0 4481            	   960: 	NEG.L	D1
00:000111F2 761F            	   961: DIV2	MOVEQ	#31,D3		iteration count for 32 bits
00:000111F4 2200            	   962: 	MOVE.L	D0,D1
00:000111F6 4280            	   963: 	CLR.L	D0
