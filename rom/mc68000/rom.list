                            	  7644: 
                            	  7645: *************************************************************************************
                            	  7646: * EhBASIC keywords quick reference list								*
                            	  7647: *************************************************************************************
                            	  7648: 
                            	  7649: * glossary
                            	  7650: 
                            	  7651: *		<.>		  required
                            	  7652: *		{.|.}		  one of required
                            	  7653: *		[.]		  optional
                            	  7654: *		...		  may repeat as last
                            	  7655: 
                            	  7656: *		any		= anything
                            	  7657: *		num		= number
                            	  7658: *		state		= statement
                            	  7659: *		pint		= positive integer
                            	  7660: *		str		= string
                            	  7661: *		var		= variable
                            	  7662: *		nvar		= numeric variable
                            	  7663: *		svar		= string variable
                            	  7664: *		expr		= expression
                            	  7665: *		nexpr		= numeric expression
                            	  7666: *		sexpr		= string expression
                            	  7667: 
                            	  7668: * statement separator
                            	  7669: 
                            	  7670: * :		. [state] : [state]						* done
                            	  7671: 
                            	  7672: * number bases
                            	  7673: 
                            	  7674: * %		. %<binary num>							* done
                            	  7675: * $		. $<hex num>							* done
                            	  7676: 
                            	  7677: * commands
                            	  7678: 
                            	  7679: * END		. END									* done
                            	  7680: * FOR		. FOR <nvar>=<nexpr> TO <nexpr> [STEP <nexpr>]		* done
                            	  7681: * NEXT	. NEXT [<nvar>[,<nvar>]...]					* done
                            	  7682: * DATA	. DATA [{num|["]str["]}[,{num|["]str["]}]...]		* done
                            	  7683: * INPUT	. INPUT [<">str<">;] <var>[,<var>[,<var>]...]		* done
                            	  7684: * DIM		. DIM <var>(<nexpr>[,<nexpr>[,<nexpr>]])			* done
                            	  7685: * READ	. READ <var>[,<var>[,<var>]...]				* done
                            	  7686: * LET		. [LET] <var>=<expr>						* done
                            	  7687: * DEC		. DEC <nvar>[,<nvar>[,<nvar>]...]				* done
                            	  7688: * GOTO	. GOTO <pint>							* done
                            	  7689: * RUN		. RUN [pint]							* done
                            	  7690: * IF		. IF <nexpr> {THEN {pint|state}|GOTO <pint>}		* done
                            	  7691: * RESTORE	. RESTORE [pint]							* done
                            	  7692: * GOSUB	. GOSUB <pint>							* done
                            	  7693: * RETURN	. RETURN								* done
                            	  7694: * REM		. REM [any]								* done
                            	  7695: * STOP	. STOP								* done
                            	  7696: * ON		. ON <nexpr> {GOTO|GOSUB} <pint>[,<pint>[,<pint>]...]	* done
                            	  7697: * NULL	. NULL <nexpr>							* done
                            	  7698: * INC		. INC <nvar>[,<nvar>[,<nvar>]...]				* done
                            	  7699: * WAIT	. WAIT <nexpr>,<nexpr>[,<nexpr>]				* done
                            	  7700: * LOAD	. LOAD <sexpr>							* done for simulator
                            	  7701: * SAVE	. SAVE <sexpr>							* done for simulator
                            	  7702: * DEF		. DEF FN<var>(<var>)=<expr>					* done
                            	  7703: * POKE	. POKE <nexpr>,<nexpr>						* done
                            	  7704: * DOKE	. DOKE <nexpr>,<nexpr>					 	* done
                            	  7705: * LOKE	. LOKE <nexpr>,<nexpr>					 	* done
                            	  7706: * CALL	. CALL <nexpr>							* done
                            	  7707: * DO		. DO									* done
                            	  7708: * LOOP	. LOOP [{WHILE|UNTIL}<nexpr>]					* done
                            	  7709: * PRINT	. PRINT [{;|,}][expr][{;|,}[expr][{;|,}[expr]]...]	* done
                            	  7710: * CONT	. CONT								* done
                            	  7711: * LIST	. LIST [pint][-pint]						* done
                            	  7712: * CLEAR	. CLEAR								* done
                            	  7713: * NEW		. NEW									* done
                            	  7714: * WIDTH	. WIDTH [<pint>][,<pint>]					* done
                            	  7715: * GET		. GET <var>								* done
                            	  7716: * SWAP	. SWAP <var>,<var>						* done
                            	  7717: * BITSET	. BITSET <nexpr>,<nexpr>					* done
                            	  7718: * BITCLR	. BITCLR <nexpr>,<nexpr>					* done
                            	  7719: 
                            	  7720: * sub commands (may not start a statement)
                            	  7721: 
                            	  7722: * TAB		. TAB(<nexpr>)							* done
                            	  7723: * TO		. FOR <nvar>=<nexpr> TO <nexpr> [STEP <nexpr>]		* done
                            	  7724: * FN		. FN<var>(<expr>)							* done
                            	  7725: * SPC		. SPC(<nexpr>)							* done
                            	  7726: * THEN	. IF <nexpr> {THEN {pint|comm}|GOTO <pint>}		* done
                            	  7727: * NOT		. NOT <nexpr>							* done
                            	  7728: * STEP	. FOR <nvar>=<nexpr> TO <nexpr> [STEP <nexpr>]		* done
                            	  7729: * UNTIL	. LOOP [{WHILE|UNTIL}<nexpr>]					* done
                            	  7730: * WHILE	. LOOP [{WHILE|UNTIL}<nexpr>]					* done
                            	  7731: 
                            	  7732: * operators
                            	  7733: 
                            	  7734: * +		. [expr] + <expr>							* done
                            	  7735: * -		. [nexpr] - <nexpr>						* done
                            	  7736: * *		. <nexpr> * <nexpr>						* done fast hardware
                            	  7737: * /		. <nexpr> / <nexpr>						* done fast hardware
                            	  7738: * ^		. <nexpr> ^ <nexpr>						* done
                            	  7739: * AND		. <nexpr> AND <nexpr>						* done
                            	  7740: * EOR		. <nexpr> EOR <nexpr>						* done
                            	  7741: * OR		. <nexpr> OR <nexpr>						* done
                            	  7742: * >>		. <nexpr> >> <nexpr>						* done
                            	  7743: * <<		. <nexpr> << <nexpr>						* done
                            	  7744: 
                            	  7745: * compare functions
                            	  7746: 
                            	  7747: * <		. <expr> < <expr>							* done
                            	  7748: * =		. <expr> = <expr>							* done
                            	  7749: * >		. <expr> > <expr>							* done
                            	  7750: 
                            	  7751: * functions
                            	  7752: 
                            	  7753: * SGN		. SGN(<nexpr>)							* done
                            	  7754: * INT		. INT(<nexpr>)							* done
                            	  7755: * ABS		. ABS(<nexpr>)							* done
                            	  7756: * USR		. USR(<expr>)							* done
                            	  7757: * FRE		. FRE(<expr>)							* done
                            	  7758: * POS		. POS(<expr>)							* done
                            	  7759: * SQR		. SQR(<nexpr>)							* done fast shift/sub
                            	  7760: * RND		. RND(<nexpr>)							* done 32 bit PRNG
                            	  7761: * LOG		. LOG(<nexpr>)							* done fast cordic
                            	  7762: * EXP		. EXP(<nexpr>)							* done fast cordic
                            	  7763: * COS		. COS(<nexpr>)							* done fast cordic
                            	  7764: * SIN		. SIN(<nexpr>)							* done fast cordic
                            	  7765: * TAN		. TAN(<nexpr>)							* done fast cordic
                            	  7766: * ATN		. ATN(<nexpr>)							* done fast cordic
                            	  7767: * PEEK	. PEEK(<nexpr>)							* done
                            	  7768: * DEEK	. DEEK(<nexpr>)							* done
                            	  7769: * LEEK	. LEEK(<nexpr>)							* done
                            	  7770: * LEN		. LEN(<sexpr>)							* done
                            	  7771: * STR$	. STR$(<nexpr>)							* done
                            	  7772: * VAL		. VAL(<sexpr>)							* done
                            	  7773: * ASC		. ASC(<sexpr>)							* done
                            	  7774: * UCASE$	. UCASE$(<sexpr>)							* done
                            	  7775: * LCASE$	. LCASE$(<sexpr>)							* done
                            	  7776: * CHR$	. CHR$(<nexpr>)							* done
                            	  7777: * HEX$	. HEX$(<nexpr>)							* done
                            	  7778: * BIN$	. BIN$(<nexpr>)							* done
                            	  7779: * BTST	. BTST(<nexpr>,<nexpr>)						* done
                            	  7780: * MAX		. MAX(<nexpr>[,<nexpr>[,<nexpr>]...])			* done
                            	  7781: * MIN		. MIN(<nexpr>[,<nexpr>[,<nexpr>]...])			* done
                            	  7782: * PI		. PI									* done
                            	  7783: * TWOPI	. TWOPI								* done
                            	  7784: * VARPTR	. VARPTR(<var>)							* done
                            	  7785: * SADD	. SADD(<svar>)							* done
                            	  7786: * LEFT$	. LEFT$(<sexpr>,<nexpr>)					* done
                            	  7787: * RIGHT$	. RIGHT$(<sexpr>,<nexpr>)					* done
                            	  7788: * MID$	. MID$(<sexpr>,<nexpr>[,<nexpr>])				* done
