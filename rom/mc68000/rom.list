                            	  1027: *
                            	  1028: *******************************************************************
                            	  1029: *
                            	  1030: * *** SETVAL *** FIN *** ENDCHK *** ERROR (& friends) ***
                            	  1031: *
                            	  1032: * 'SETVAL' expects a variable, followed by an equal sign and then
                            	  1033: * an expression.  It evaluates the expression and sets the variable
                            	  1034: * to that value.
                            	  1035: *
                            	  1036: * 'FIN' checks the end of a command.  If it ended with ":",
                            	  1037: * execution continues.	If it ended with a CR, it finds the
                            	  1038: * the next line and continues from there.
                            	  1039: *
                            	  1040: * 'ENDCHK' checks if a command is ended with a CR. This is
                            	  1041: * required in certain commands, such as GOTO, RETURN, STOP, etc.
                            	  1042: *
                            	  1043: * 'ERROR' prints the string pointed to by A0. It then prints the
                            	  1044: * line pointed to by CURRNT with a "?" inserted at where the
                            	  1045: * old text pointer (should be on top of the stack) points to.
                            	  1046: * Execution of Tiny BASIC is stopped and a warm start is done.
                            	  1047: * If CURRNT is zero (indicating a direct command), the direct
                            	  1048: * command is not printed. If CURRNT is -1 (indicating
                            	  1049: * 'INPUT' command in progress), the input line is not printed
                            	  1050: * and execution is not terminated but continues at 'INPERR'.
                            	  1051: *
                            	  1052: * Related to 'ERROR' are the following:
                            	  1053: * 'QWHAT' saves text pointer on stack and gets "What?" message.
                            	  1054: * 'AWHAT' just gets the "What?" message and jumps to 'ERROR'.
                            	  1055: * 'QSORRY' and 'ASORRY' do the same kind of thing.
                            	  1056: * 'QHOW' and 'AHOW' also do this for "How?".
                            	  1057: *
00:0001127C 6100FEAC        	  1058: SETVAL	BSR	TSTV		variable name?
00:00011280 65000040        	  1059: 	BCS	QWHAT		if not, say "What?"
00:00011284 2F00            	  1060: 	MOVE.L	D0,-(SP)	save the variable's address
00:00011286 61000304        	  1061: 	BSR	TSTC		get past the "=" sign
00:0001128A 3D              	  1062: 	DC.B	'=',SV1-*
00:0001128B 0B
00:0001128C 6100FD66        	  1063: 	BSR	EXPR		evaluate the expression
00:00011290 2C5F            	  1064: 	MOVE.L	(SP)+,A6
00:00011292 2C80            	  1065: 	MOVE.L	D0,(A6) 	and save its value in the variable
00:00011294 4E75            	  1066: 	RTS
00:00011296 6000002A        	  1067: SV1	BRA	QWHAT		if no "=" sign
                            	  1068: 
00:0001129A 610002F0        	  1069: FIN	BSR	TSTC		*** FIN ***
00:0001129E 3A              	  1070: 	DC.B	':',FI1-*
00:0001129F 07
00:000112A0 588F            	  1071: 	ADDQ.L	#4,SP		if ":", discard return address
00:000112A2 6000F940        	  1072: 	BRA	RUNSML		continue on the same line
00:000112A6 610002E4        	  1073: FI1	BSR	TSTC		not ":", is it a CR?
00:000112AA 0A              	  1074: 	DC.B	LF,FI2-*
00:000112AB 07
00:000112AC 588F            	  1075: 	ADDQ.L	#4,SP		yes, purge return address
00:000112AE 6000F914        	  1076: 	BRA	RUNNXL		execute the next line
00:000112B2 4E75            	  1077: FI2	RTS			else return to the caller
                            	  1078: 
00:000112B4 61000330        	  1079: ENDCHK	BSR	IGNBLK
00:000112B8 0C10000A        	  1080: 	CMP.B	#LF,(A0)	does it end with a CR?
00:000112BC 66000004        	  1081: 	BNE	QWHAT		if not, say "WHAT?"
00:000112C0 4E75            	  1082: 	RTS
                            	  1083: 
00:000112C2 2F08            	  1084: QWHAT	MOVE.L	A0,-(SP)
00:000112C4 4DF9000116ED    	  1085: AWHAT	LEA	WHTMSG,A6
00:000112CA 610003AA        	  1086: ERROR	BSR	PRMESG		display the error message
00:000112CE 205F            	  1087: 	MOVE.L	(SP)+,A0	restore the text pointer
00:000112D0 20390000612A    	  1088: 	MOVE.L	CURRNT,D0	get the current line number
00:000112D6 6700F6BE        	  1089: 	BEQ	WSTART		if zero, do a warm start
00:000112DA B0BCFFFFFFFF    	  1090: 	CMP.L	#-1,D0		is the line no. pointer = -1?
00:000112E0 6700FB3A        	  1091: 	BEQ	INPERR		if so, redo input
00:000112E4 1F10            	  1092: 	MOVE.B	(A0),-(SP)	save the char. pointed to
00:000112E6 4210            	  1093: 	CLR.B	(A0)		put a zero where the error is
00:000112E8 22790000612A    	  1094: 	MOVE.L	CURRNT,A1	point to start of current line
00:000112EE 61000280        	  1095: 	BSR	PRTLN		display the line in error up to the 0
00:000112F2 109F            	  1096: 	MOVE.B	(SP)+,(A0)	restore the character
00:000112F4 103C003F        	  1097: 	MOVE.B	#'?',D0         display a "?"
00:000112F8 6100F64C        	  1098: 	BSR	GOOUT
00:000112FC 4240            	  1099: 	CLR	D0
00:000112FE 5389            	  1100: 	SUBQ.L	#1,A1		point back to the error char.
00:00011300 61000186        	  1101: 	BSR	PRTSTG		display the rest of the line
00:00011304 6000F690        	  1102: 	BRA	WSTART		and do a warm start
00:00011308 2F08            	  1103: QSORRY	MOVE.L	A0,-(SP)
00:0001130A 4DF9000116F5    	  1104: ASORRY	LEA	SRYMSG,A6
00:00011310 6000FFB8        	  1105: 	BRA	ERROR
00:00011314 2F08            	  1106: QHOW	MOVE.L	A0,-(SP)	Error: "How?"
00:00011316 4DF9000116E6    	  1107: AHOW	LEA	HOWMSG,A6
00:0001131C 6000FFAC        	  1108: 	BRA	ERROR
                            	  1109: *
                            	  1110: *******************************************************************
                            	  1111: *
                            	  1112: * *** GETLN *** FNDLN (& friends) ***
                            	  1113: *
                            	  1114: * 'GETLN' reads in input line into 'BUFFER'. It first prompts with
                            	  1115: * the character in D0 (given by the caller), then it fills the
                            	  1116: * buffer and echos. It ignores LF's but still echos
                            	  1117: * them back. Control-H is used to delete the last character
                            	  1118: * entered (if there is one), and control-X is used to delete the
                            	  1119: * whole line and start over again. CR signals the end of a line,
                            	  1120: * and causes 'GETLN' to return.
                            	  1121: *
                            	  1122: * 'FNDLN' finds a line with a given line no. (in D1) in the
                            	  1123: * text save area.  A1 is used as the text pointer. If the line
                            	  1124: * is found, A1 will point to the beginning of that line
                            	  1125: * (i.e. the high byte of the line no.), and flags are NC & Z.
                            	  1126: * If that line is not there and a line with a higher line no.
                            	  1127: * is found, A1 points there and flags are NC & NZ. If we reached
                            	  1128: * the end of the text save area and cannot find the line, flags
                            	  1129: * are C & NZ.
                            	  1130: * 'FNDLN' will initialize A1 to the beginning of the text save
                            	  1131: * area to start the search. Some other entries of this routine
                            	  1132: * will not initialize A1 and do the search.
                            	  1133: * 'FNDLNP' will start with A1 and search for the line no.
                            	  1134: * 'FNDNXT' will bump A1 by 2, find a CR and then start search.
                            	  1135: * 'FNDSKP' uses A1 to find a CR, and then starts the search.
                            	  1136: *
00:00011320 6100F624        	  1137: GETLN	BSR	GOOUT		display the prompt
00:00011324 103C0020        	  1138: 	MOVE.B	#' ',D0         and a space
00:00011328 6100F61C        	  1139: 	BSR	GOOUT
00:0001132C 41F900006156    	  1140: 	LEA	BUFFER,A0	A0 is the buffer pointer
00:00011332 61000326        	  1141: GL1	BSR	CHKIO		check keyboard
00:00011336 6700FFFA        	  1142: 	BEQ	GL1		wait for a char. to come in
00:0001133A B03C0008        	  1143: 	CMP.B	#CTRLH,D0	delete last character?
00:0001133E 67000032        	  1144: 	BEQ	GL3		if so
00:00011342 B03C0018        	  1145: 	CMP.B	#CTRLX,D0	delete the whole line?
00:00011346 67000052        	  1146: 	BEQ	GL4		if so
00:0001134A B03C000A        	  1147: ja	CMP.B	#LF,D0		accept an LF
00:0001134E 6700000A        	  1148: 	BEQ	GL2
00:00011352 B03C0020        	  1149: 	CMP.B	#' ',D0         if other control char., discard it
00:00011356 6500FFDA        	  1150: 	BCS	GL1
00:0001135A 10C0            	  1151: GL2	MOVE.B	D0,(A0)+	save the char.
00:0001135C 6100F5E8        	  1152: 	BSR	GOOUT		echo the char back out
00:00011360 B03C000A        	  1153: 	CMP.B	#LF,D0		if it's an LF, end the line
00:00011364 67000068        	  1154: 	BEQ	GL7
00:00011368 B1FC000061A5    	  1155: 	CMP.L	#(BUFFER+BUFLEN-1),A0	any more room?
00:0001136E 6500FFC2        	  1156: 	BCS	GL1		yes: get some more, else delete last char.
00:00011372 103C0008        	  1157: GL3	MOVE.B	#CTRLH,D0	delete a char. if possible
00:00011376 6100F5CE        	  1158: 	BSR	GOOUT
00:0001137A 103C0020        	  1159: 	MOVE.B	#' ',D0
00:0001137E 6100F5C6        	  1160: 	BSR	GOOUT
00:00011382 B1FC00006156    	  1161: 	CMP.L	#BUFFER,A0	any char.'s left?
00:00011388 6300FFA8        	  1162: 	BLS	GL1		if not
00:0001138C 103C0008        	  1163: 	MOVE.B	#CTRLH,D0	if so, finish the BS-space-BS sequence
00:00011390 6100F5B4        	  1164: 	BSR	GOOUT
00:00011394 5388            	  1165: 	SUBQ.L	#1,A0		decrement the text pointer
00:00011396 6000FF9A        	  1166: 	BRA	GL1		back for more
00:0001139A 2208            	  1167: GL4	MOVE.L	A0,D1		delete the whole line
00:0001139C 92BC00006156    	  1168: 	SUB.L	#BUFFER,D1	figure out how many backspaces we need
00:000113A2 67000020        	  1169: 	BEQ	GL6		if none needed, branch
00:000113A6 5341            	  1170: 	SUBQ	#1,D1		adjust for DBRA
00:000113A8 103C0008        	  1171: GL5	MOVE.B	#CTRLH,D0	and display BS-space-BS sequences
00:000113AC 6100F598        	  1172: 	BSR	GOOUT
00:000113B0 103C0020        	  1173: 	MOVE.B	#' ',D0
00:000113B4 6100F590        	  1174: 	BSR	GOOUT
00:000113B8 103C0008        	  1175: 	MOVE.B	#CTRLH,D0
00:000113BC 6100F588        	  1176: 	BSR	GOOUT
00:000113C0 51C9FFE6        	  1177: 	DBRA	D1,GL5
00:000113C4 41F900006156    	  1178: GL6	LEA	BUFFER,A0	reinitialize the text pointer
00:000113CA 6000FF66        	  1179: 	BRA	GL1		and go back for more
00:000113CE 103C000A        	  1180: GL7	MOVE.B	#LF,D0		echo a LF for the CR
00:000113D2 6100F572        	  1181: 	BSR	GOOUT
00:000113D6 4E75            	  1182: 	RTS
                            	  1183: 
00:000113D8 B2BC0000FFFF    	  1184: FNDLN	CMP.L	#$FFFF,D1	line no. must be < 65535
00:000113DE 6400FF34        	  1185: 	BCC	QHOW
00:000113E2 22790001095A    	  1186: 	MOVE.L	TXTBGN,A1	init. the text save pointer
                            	  1187: 
00:000113E8 24790000614A    	  1188: FNDLNP	MOVE.L	TXTUNF,A2	check if we passed the end
00:000113EE 538A            	  1189: 	SUBQ.L	#1,A2
00:000113F0 B5C9            	  1190: 	CMP.L	A1,A2
00:000113F2 65000010        	  1191: 	BCS	FNDRET		if so, return with Z=0 & C=1
00:000113F6 1419            	  1192: 	MOVE.B	(A1)+,D2	if not, get a line no.
00:000113F8 E14A            	  1193: 	LSL	#8,D2
00:000113FA 1411            	  1194: 	MOVE.B	(A1),D2
00:000113FC 5389            	  1195: 	SUBQ.L	#1,A1
00:000113FE B481            	  1196: 	CMP.L	D1,D2		is this the line we want?
00:00011400 65000004        	  1197: 	BCS	FNDNXT		no, not there yet
00:00011404 4E75            	  1198: FNDRET	RTS			return the cond. codes
                            	  1199: 
00:00011406 5489            	  1200: FNDNXT	ADDQ.L	#2,A1		find the next line
                            	  1201: 
00:00011408 0C19000A        	  1202: FNDSKP	CMP.B	#LF,(A1)+	try to find an LF
00:0001140C 6600FFFA        	  1203: 	BNE	FNDSKP		keep looking
00:00011410 6000FFD6        	  1204: 	BRA	FNDLNP		check if end of text
