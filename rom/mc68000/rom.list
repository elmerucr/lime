                            	   629: *
                            	   630: *******************************************************************
                            	   631: *
                            	   632: * *** LOAD *** & SAVE ***
                            	   633: *
                            	   634: * These two commands transfer a program to/from an auxiliary
                            	   635: * device such as a cassette, another computer, etc.  The program
                            	   636: * is converted to an easily-stored format: each line starts with
                            	   637: * a colon, the line no. as 4 hex digits, and the rest of the line.
                            	   638: * At the end, a line starting with an '@' sign is sent.  This
                            	   639: * format can be read back with a minimum of processing time by
                            	   640: * the 68000.
                            	   641: *
00:00010EDC 207900010978    	   642: LOAD	MOVE.L	TXTBGN,A0	set pointer to start of prog. area
00:00010EE2 103C000D        	   643: 	MOVE.B	#CR,D0		For a CP/M host, tell it we're ready...
00:00010EE6 6100FA84        	   644: 	BSR	GOAUXO		by sending a CR to finish PIP command.
00:00010EEA 6100FA84        	   645: LOD1	BSR	GOAUXI		look for start of line
00:00010EEE 6700FFFA        	   646: 	BEQ	LOD1
00:00010EF2 B03C0040        	   647: 	CMP.B	#'@',D0         end of program?
00:00010EF6 6700002C        	   648: 	BEQ	LODEND
00:00010EFA B03C003A        	   649: 	CMP.B	#':',D0         if not, is it start of line?
00:00010EFE 6600FFEA        	   650: 	BNE	LOD1		if not, wait for it
00:00010F02 6100002A        	   651: 	BSR	GBYTE		get first byte of line no.
00:00010F06 10C1            	   652: 	MOVE.B	D1,(A0)+	store it
00:00010F08 61000024        	   653: 	BSR	GBYTE		get 2nd bye of line no.
00:00010F0C 10C1            	   654: 	MOVE.B	D1,(A0)+	store that, too
00:00010F0E 6100FA60        	   655: LOD2	BSR	GOAUXI		get another text char.
00:00010F12 6700FFFA        	   656: 	BEQ	LOD2
00:00010F16 10C0            	   657: 	MOVE.B	D0,(A0)+	store it
00:00010F18 B03C000D        	   658: 	CMP.B	#CR,D0		is it the end of the line?
00:00010F1C 6600FFF0        	   659: 	BNE	LOD2		if not, go back for more
00:00010F20 6000FFC8        	   660: 	BRA	LOD1		if so, start a new line
00:00010F24 23C80000614E    	   661: LODEND	MOVE.L	A0,TXTUNF	set end-of program pointer
00:00010F2A 6000FA88        	   662: 	BRA	WSTART		back to direct mode
                            	   663: 
00:00010F2E 7401            	   664: GBYTE	MOVEQ	#1,D2		get two hex characters from auxiliary
00:00010F30 4241            	   665: 	CLR	D1		and store them as a byte in D1
00:00010F32 6100FA3C        	   666: GBYTE1	BSR	GOAUXI		get a char.
00:00010F36 6700FFFA        	   667: 	BEQ	GBYTE1
00:00010F3A B03C0041        	   668: 	CMP.B	#'A',D0
00:00010F3E 65000004        	   669: 	BCS	GBYTE2
00:00010F42 5F00            	   670: 	SUBQ.B	#7,D0		if greater than 9, adjust
00:00010F44 C03C000F        	   671: GBYTE2	AND.B	#$F,D0		strip ASCII
00:00010F48 E909            	   672: 	LSL.B	#4,D1		put nybble into the result
00:00010F4A 8200            	   673: 	OR.B	D0,D1
00:00010F4C 51CAFFE4        	   674: 	DBRA	D2,GBYTE1	get another char.
00:00010F50 4E75            	   675: 	RTS
                            	   676: 
00:00010F52 207900010978    	   677: SAVE	MOVE.L	TXTBGN,A0	set pointer to start of prog. area
00:00010F58 22790000614E    	   678: 	MOVE.L	TXTUNF,A1	set pointer to end of prog. area
00:00010F5E 103C000D        	   679: SAVE1	MOVE.B	#CR,D0		send out a CR & LF (CP/M likes this)
00:00010F62 6100FA08        	   680: 	BSR	GOAUXO
00:00010F66 103C000A        	   681: 	MOVE.B	#LF,D0
00:00010F6A 6100FA00        	   682: 	BSR	GOAUXO
00:00010F6E B3C8            	   683: 	CMP.L	A0,A1		are we finished?
00:00010F70 63000028        	   684: 	BLS	SAVEND
00:00010F74 103C003A        	   685: 	MOVE.B	#':',D0         if not, start a line
00:00010F78 6100F9F2        	   686: 	BSR	GOAUXO
00:00010F7C 1218            	   687: 	MOVE.B	(A0)+,D1	send first half of line no.
00:00010F7E 6100003E        	   688: 	BSR	PBYTE
00:00010F82 1218            	   689: 	MOVE.B	(A0)+,D1	and send 2nd half
00:00010F84 61000038        	   690: 	BSR	PBYTE
00:00010F88 1018            	   691: SAVE2	MOVE.B	(A0)+,D0	get a text char.
00:00010F8A B03C000D        	   692: 	CMP.B	#CR,D0		is it the end of the line?
00:00010F8E 6700FFCE        	   693: 	BEQ	SAVE1		if so, send CR & LF and start new line
00:00010F92 6100F9D8        	   694: 	BSR	GOAUXO		send it out
00:00010F96 6000FFF0        	   695: 	BRA	SAVE2		go back for more text
00:00010F9A 103C0040        	   696: SAVEND	MOVE.B	#'@',D0         send end-of-program indicator
00:00010F9E 6100F9CC        	   697: 	BSR	GOAUXO
00:00010FA2 103C000D        	   698: 	MOVE.B	#CR,D0		followed by a CR & LF
00:00010FA6 6100F9C4        	   699: 	BSR	GOAUXO
00:00010FAA 103C000A        	   700: 	MOVE.B	#LF,D0
00:00010FAE 6100F9BC        	   701: 	BSR	GOAUXO
00:00010FB2 103C001A        	   702: 	MOVE.B	#$1A,D0 	and a control-Z to end the CP/M file
00:00010FB6 6100F9B4        	   703: 	BSR	GOAUXO
00:00010FBA 6000F9F8        	   704: 	BRA	WSTART		then go do a warm start
                            	   705: 
00:00010FBE 7401            	   706: PBYTE	MOVEQ	#1,D2		send two hex characters from D1's low byte
00:00010FC0 E919            	   707: PBYTE1	ROL.B	#4,D1		get the next nybble
00:00010FC2 1001            	   708: 	MOVE.B	D1,D0
00:00010FC4 C03C000F        	   709: 	AND.B	#$F,D0		strip off garbage
00:00010FC8 D03C0030        	   710: 	ADD.B	#'0',D0         make it into ASCII
00:00010FCC B03C0039        	   711: 	CMP.B	#'9',D0
00:00010FD0 63000004        	   712: 	BLS	PBYTE2
00:00010FD4 5E00            	   713: 	ADDQ.B	#7,D0		adjust if greater than 9
00:00010FD6 6100F994        	   714: PBYTE2	BSR	GOAUXO		send it out
00:00010FDA 51CAFFE4        	   715: 	DBRA	D2,PBYTE1	then send the next nybble
00:00010FDE 4E75            	   716: 	RTS
