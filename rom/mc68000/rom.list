                            	  6434: LAB_CBX1
00:00002F0A 5283            	  6435: 	ADDQ.l	#1,d3				* increment mantissa exponent count
00:00002F0C 6900DAA4        	  6436: 	BVS		LAB_OFER			* do overflow error if overflowed
                            	  6437: 
00:00002F10 6100E658        	  6438: 	BSR		LAB_IGBY			* get next character
00:00002F14 64BA            	  6439: 	BCC.s		LAB_CHX3			* if not numeric character go return value
                            	  6440: 
00:00002F16 B03C0032        	  6441: 	CMP.b		#'2',d0			* compare with "2" (max+1)
00:00002F1A 65EE            	  6442: 	BCS.s		LAB_CBX1			* loop if <"2"
                            	  6443: 
