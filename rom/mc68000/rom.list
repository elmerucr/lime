00:00011428 1721            	  1229: 	MOVE.B	-(A1),-(A3)
00:0001142A 6000FFF6        	  1230: 	BRA	MVDOWN
                            	  1231: 
00:0001142E 2C5F            	  1232: POPA	MOVE.L	(SP)+,A6	A6 = return address
00:00011430 23DF00006136    	  1233: 	MOVE.L	(SP)+,LOPVAR	restore LOPVAR, but zero means no more
00:00011436 6700001A        	  1234: 	BEQ	PP1
00:0001143A 23DF0000613A    	  1235: 	MOVE.L	(SP)+,LOPINC	if not zero, restore the rest
00:00011440 23DF0000613E    	  1236: 	MOVE.L	(SP)+,LOPLMT
00:00011446 23DF00006142    	  1237: 	MOVE.L	(SP)+,LOPLN
00:0001144C 23DF00006146    	  1238: 	MOVE.L	(SP)+,LOPPT
00:00011452 4ED6            	  1239: PP1	JMP	(A6)		return
