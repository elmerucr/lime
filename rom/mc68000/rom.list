00:0001144E 23DF0000613A    	  1233: 	MOVE.L	(SP)+,LOPVAR	restore LOPVAR, but zero means no more
00:00011454 6700001A        	  1234: 	BEQ	PP1
00:00011458 23DF0000613E    	  1235: 	MOVE.L	(SP)+,LOPINC	if not zero, restore the rest
00:0001145E 23DF00006142    	  1236: 	MOVE.L	(SP)+,LOPLMT
00:00011464 23DF00006146    	  1237: 	MOVE.L	(SP)+,LOPLN
00:0001146A 23DF0000614A    	  1238: 	MOVE.L	(SP)+,LOPPT
00:00011470 4ED6            	  1239: PP1	JMP	(A6)		return
                            	  1240: 
00:00011472 223900006156    	  1241: PUSHA	MOVE.L	STKLMT,D1	Are we running out of stack room?
00:00011478 928F            	  1242: 	SUB.L	SP,D1
