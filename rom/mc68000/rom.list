00:00011132 903C0040        	   887: 	SUB.B	#'@',D0
00:00011136 6500004A        	   888: 	BCS	TSTVRT		C=1: not a variable
00:0001113A 6600002C        	   889: 	BNE	TV1		branch if not "@" array
00:0001113E 5248            	   890: 	ADDQ	#1,A0		If it is, it should be
