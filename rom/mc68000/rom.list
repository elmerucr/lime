00:00002EF0 177C004005B5    	  6420: 	move.b	#$40,Dtypef(a3)		* set integer numeric data type
00:00002EF6 7620            	  6421: 	moveq		#32,d3			* set up max binary exponent
                            	  6422: LAB_CBXN
00:00002EF8 6100E670        	  6423: 	BSR		LAB_IGBY			* increment & scan memory
00:00002EFC 64D2            	  6424: 	BCC.s		LAB_CHX3			* if not numeric character go return value
                            	  6425: 
00:00002EFE B03C0032        	  6426: 	CMP.b		#'2',d0			* compare with "2" (max+1)
00:00002F02 64CC            	  6427: 	BCC.s		LAB_CHX3			* if >="2" go return value
                            	  6428: 
