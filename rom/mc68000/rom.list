                            	  6215: 
00:00002D8C 6000008E        	  6216: 	BRA		LAB_2Y01			* not #.$%& so return 0
                            	  6217: 
                            	  6218: LAB_28FD
00:00002D90 6100E7D8        	  6219: 	BSR		LAB_IGBY			* get next character
00:00002D94 646E            	  6220: 	BCC.s		LAB_2902			* exit loop if not a digit
                            	  6221: 
                            	  6222: LAB_28FE
00:00002D96 610001AA        	  6223: 	BSR		d1x10				* multiply d1 by 10 and add character
00:00002D9A 64F4            	  6224: 	BCC.s		LAB_28FD			* loop for more if no overflow
                            	  6225: 
                            	  6226: LAB_28FF
                            	  6227: 							* overflowed mantissa, count 10s exponent
