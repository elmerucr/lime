00:00010C53 09
00:00010C54 61000A22        	   369: 	BSR	CRLF		give CR-LF and continue
00:00010C58 6000FF92        	   370: 	BRA	RUNSML		execution on the same line
00:00010C5C 61000936        	   371: PR2	BSR	TSTC		if null list and <CR>
00:00010C60 0D              	   372: 	DC.B	CR,PR0-*
00:00010C61 09
00:00010C62 61000A14        	   373: 	BSR	CRLF		also give CR-LF and
00:00010C66 6000FF64        	   374: 	BRA	RUNNXL		execute the next line
00:00010C6A 61000928        	   375: PR0	BSR	TSTC		else is it a format?
00:00010C6E 23              	   376: 	DC.B	'#',PR1-*
00:00010C6F 0B
