                            	   879: *
                            	   880: * ===== Test for a valid variable name.  Returns Carry=1 if not
                            	   881: *	found, else returns Carry=0 and the address of the
                            	   882: *	variable in D0.
                            	   883: 
00:00011132 610004BA        	   884: TSTV	BSR	IGNBLK
00:00011136 4280            	   885: 	CLR.L	D0
00:00011138 1010            	   886: 	MOVE.B	(A0),D0 	look at the program text
00:0001113A 903C0040        	   887: 	SUB.B	#'@',D0
00:0001113E 6500004A        	   888: 	BCS	TSTVRT		C=1: not a variable
00:00011142 6600002C        	   889: 	BNE	TV1		branch if not "@" array
00:00011146 5248            	   890: 	ADDQ	#1,A0		If it is, it should be
00:00011148 6100FFD2        	   891: 	BSR	PARN		followed by (EXPR) as its index.
00:0001114C D080            	   892: 	ADD.L	D0,D0
00:0001114E 650001CC        	   893: 	BCS	QHOW		say "How?" if index is too big
00:00011152 D080            	   894: 	ADD.L	D0,D0
00:00011154 650001C6        	   895: 	BCS	QHOW
00:00011158 2F00            	   896: 	MOVE.L	D0,-(SP)	save the index
00:0001115A 6100011A        	   897: 	BSR	SIZE		get amount of free memory
00:0001115E 221F            	   898: 	MOVE.L	(SP)+,D1	get back the index
00:00011160 B081            	   899: 	CMP.L	D1,D0		see if there's enough memory
00:00011162 630001AC        	   900: 	BLS	QSORRY		if not, say "Sorry"
00:00011166 20390000614A    	   901: 	MOVE.L	VARBGN,D0	put address of array element...
00:0001116C 9081            	   902: 	SUB.L	D1,D0		into D0
00:0001116E 4E75            	   903: 	RTS
00:00011170 B03C001B        	   904: TV1	CMP.B	#27,D0		if not @, is it A through Z?
00:00011174 0A3C0001        	   905: 	EOR	#1,CCR
00:00011178 65000010        	   906: 	BCS	TSTVRT		if not, set Carry and return
00:0001117C 5248            	   907: 	ADDQ	#1,A0		else bump the text pointer
