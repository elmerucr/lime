00:00002290 6768            	  4577: 	BEQ.s		LAB_DIV0			* if zero return zero
                            	  4578: 
00:00002292 9042            	  4579: 	SUB.w		d2,d0				* get result exponent by subtracting
00:00002294 D07C0080        	  4580: 	ADD.w		#$80,d0			* correct 16 bit exponent result
