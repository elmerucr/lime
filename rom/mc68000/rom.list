00:000111A2 C141            	   928: 	EXG	D0,D1		else swap the two arguments
00:000111A4 B2BC0000FFFF    	   929: 	CMP.L	#$FFFF,D1	and check 2nd argument again
00:000111AA 62000168        	   930: 	BHI	QHOW		one of them MUST be 16 bits
00:000111AE 3400            	   931: MLT3	MOVE	D0,D2		prepare for 32 bit X 16 bit multiply
00:000111B0 C4C1            	   932: 	MULU	D1,D2		multiply low word
00:000111B2 4840            	   933: 	SWAP	D0
00:000111B4 C0C1            	   934: 	MULU	D1,D0		multiply high word
00:000111B6 4840            	   935: 	SWAP	D0
                            	   936: *** Rick Murray's bug correction follows:
00:000111B8 4A40            	   937: 	TST	D0		if lower word not 0, then overflow
00:000111BA 66000158        	   938: 	BNE	QHOW		if overflow, say "How?"
00:000111BE D082            	   939: 	ADD.L	D2,D0		D0 now holds the product
00:000111C0 6B000152        	   940: 	BMI	QHOW		if sign bit set, it's an overflow
00:000111C4 4A84            	   941: 	TST.L	D4		were the signs the same?
00:000111C6 6A000004        	   942: 	BPL	MLTRET
00:000111CA 4480            	   943: 	NEG.L	D0		if not, make the result negative
00:000111CC 4E75            	   944: MLTRET	RTS
