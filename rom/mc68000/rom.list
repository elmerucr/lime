00:00011454 223900006152    	  1241: PUSHA	MOVE.L	STKLMT,D1	Are we running out of stack room?
00:0001145A 928F            	  1242: 	SUB.L	SP,D1
00:0001145C 6400FEAA        	  1243: 	BCC	QSORRY		if so, say we're sorry
00:00011460 2C5F            	  1244: 	MOVE.L	(SP)+,A6	else get the return address
00:00011462 223900006136    	  1245: 	MOVE.L	LOPVAR,D1	save loop variables
00:00011468 6700001A        	  1246: 	BEQ	PU1		if LOPVAR is zero, that's all
00:0001146C 2F3900006146    	  1247: 	MOVE.L	LOPPT,-(SP)	else save all the others
00:00011472 2F3900006142    	  1248: 	MOVE.L	LOPLN,-(SP)
00:00011478 2F390000613E    	  1249: 	MOVE.L	LOPLMT,-(SP)
00:0001147E 2F390000613A    	  1250: 	MOVE.L	LOPINC,-(SP)
00:00011484 2F01            	  1251: PU1	MOVE.L	D1,-(SP)
00:00011486 4ED6            	  1252: 	JMP	(A6)		return
