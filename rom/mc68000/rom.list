00:000028B6 4E75            	  5537: 	RTS
                            	  5538: 
                            	  5539: * RND(n), 32 bit Galois version. make n=0 for 19th next number in sequence or n<>0
                            	  5540: * to get 19th next number in sequence after seed n. This version of the PRNG uses
                            	  5541: * the Galois method and a sample of 65536 bytes produced gives the following values.
                            	  5542: 
                            	  5543: * Entropy = 7.997442 bits per byte
                            	  5544: * Optimum compression would reduce these 65536 bytes by 0 percent
                            	  5545: 
                            	  5546: * Chi square distribution for 65536 samples is 232.01, and
                            	  5547: * randomly would exceed this value 75.00 percent of the time
                            	  5548: 
                            	  5549: * Arithmetic mean value of data bytes is 127.6724, 127.5 would be random
                            	  5550: * Monte Carlo value for Pi is 3.122871269, error 0.60 percent
                            	  5551: * Serial correlation coefficient is -0.000370, totally uncorrelated would be 0.0
                            	  5552: 
                            	  5553: LAB_RND
00:000028B8 4A2B0594        	  5554: 	TST.b		FAC1_e(a3)			* get FAC1 exponent
00:000028BC 6708            	  5555: 	BEQ.s		NextPRN			* do next random number if zero
                            	  5556: 
                            	  5557: 							* else get seed into random number store
00:000028BE 41EB05A0        	  5558: 	lea		PRNlword(a3),a0		* set PRNG pointer
00:000028C2 6100FAA6        	  5559: 	BSR		LAB_2778			* pack FAC1 into (a0)
                            	  5560: NextPRN
00:000028C6 72AF            	  5561: 	moveq		#$AF-$100,d1		* set EOR value
00:000028C8 7412            	  5562: 	moveq		#18,d2			* do this 19 times
00:000028CA 202B05A0        	  5563: 	move.l	PRNlword(a3),d0		* get current
                            	  5564: Ninc0
00:000028CE D080            	  5565: 	ADD.l		d0,d0				* shift left 1 bit
00:000028D0 6402            	  5566: 	BCC.s		Ninc1				* branch if bit 32 not set
                            	  5567: 
00:000028D2 B300            	  5568: 	EOR.b		d1,d0				* do Galois LFSR feedback
                            	  5569: Ninc1
00:000028D4 51CAFFF8        	  5570: 	DBF		d2,Ninc0			* loop
                            	  5571: 
00:000028D8 274005A0        	  5572: 	move.l	d0,PRNlword(a3)		* save back to seed word
00:000028DC 27400590        	  5573: 	move.l	d0,FAC1_m(a3)		* copy to FAC1 mantissa
00:000028E0 377C80000594    	  5574: 	MOVE.w	#$8000,FAC1_e(a3)		* set the exponent and clear the sign
00:000028E6 6000F7DC        	  5575: 	BRA		LAB_24D5			* normalise FAC1 & return
                            	  5576: 
