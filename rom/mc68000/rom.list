                            	    44: 
                            	    45: 	section	code
                            	    46: 	;org	$020000			* past the vectors in a real system
                            	    47: 
                            	    48: * the following code is simulator specific, change to suit your system
                            	    49: 
                            	    50: * output character to the console from register D0
                            	    51: 
                            	    52: VEC_OUT
00:000006F0 48E7C000        	    53: 	movem.l	D0-D1,-(SP)	* save D0, D1
00:000006F4 1200            	    54: 	move.b	D0,D1		* copy character
00:000006F6 7001            	    55: 	moveq	#1,D0		* character out (function one in trap #15)
00:000006F8 4E4F            	    56: 	trap	#15		* do I/O function
00:000006FA 4CDF0003        	    57: 	movem.l	(SP)+,D0-D1	* restore D0, D1
00:000006FE 4E75            	    58: 	rts
                            	    59: 
                            	    60: * input a character from the console into register d0
                            	    61: * else return Cb=0 if there's no character available
                            	    62: 
                            	    63: VEC_IN
00:00000700 2F01            	    64: 	move.l	d1,-(sp)		* save d1
00:00000702 7007            	    65: 	moveq	#7,d0			* get status
00:00000704 4E4F            	    66: 	trap	#15			* do I/O function
00:00000706 1001            	    67: 	move.b	d1,d0			* copy status
00:00000708 6608            	    68: 	BNE.s	RETCHR			* branch if character waiting
                            	    69: 
00:0000070A 221F            	    70: 	move.l	(sp)+,d1		* restore d1
00:0000070C 00000000        	    71: 	ORI.b	#$00,d0			* set z flag
                            	    72: *	ANDI.b	#$FE,CCR		* clear carry, flag we not got byte
                            	    73: *					* done by ORI.b
00:00000710 4E75            	    74: 	RTS
                            	    75: 
                            	    76: RETCHR
00:00000712 7005            	    77: 	moveq	#5,d0			* get byte
00:00000714 4E4F            	    78: 	trap	#15			* do I/O function
00:00000716 1001            	    79: 	move.b	d1,d0			* copy byte
00:00000718 221F            	    80: 	move.l	(sp)+,d1		* restore d1
00:0000071A 00000000        	    81: 	ORI.b	#$00,d0			* set z flag on received byte
00:0000071E 003C0001        	    82: 	ORI.b	#1,CCR			* set carry, flag we got a byte
00:00000722 4E75            	    83: 	RTS
                            	    84: 
                            	    85: * LOAD routine for the Easy68k simulator
                            	    86: 
                            	    87: VEC_LD
00:00000724 534D            	    88: 	SUBQ.w	#1,a5				* decrement execute pointer
00:00000726 61000DEE        	    89: 	BSR		LAB_GVAL			* get value from line
00:0000072A 4A2B05B5        	    90: 	TST.b		Dtypef(a3)			* test data type flag
00:0000072E 6A000266        	    91: 	BPL		LAB_TMER			* if type is not string do type mismatch error
                            	    92: 
00:00000732 61001640        	    93: 	BSR		LAB_22B6			* pop string off descriptor stack or from memory
                            	    94: 							* returns with d0 = length, a0 = pointer
