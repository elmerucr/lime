00:00002EFC 7200            	  6347: 	moveq		#0,d1				* clear mantissa
                            	  6348: LAB_rtn0
00:00002EFE 2601            	  6349: 	move.l	d1,d3				* clear exponent
00:00002F00 17430594        	  6350: 	move.b	d3,FAC1_e(a3)		* save exponent
00:00002F04 27410590        	  6351: 	move.l	d1,FAC1_m(a3)		* save mantissa
00:00002F08 4CDF003E        	  6352: 	movem.l	(sp)+,d1-d5			* restore registers
00:00002F0C 4E75            	  6353: 	RTS
                            	  6354: 
                            	  6355: * $ for hex add-on
                            	  6356: 
                            	  6357: * gets here if the first character was "$" for hex
                            	  6358: * get hex number
                            	  6359: 
                            	  6360: LAB_CHEX
00:00002F0E 177C004005B5    	  6361: 	move.b	#$40,Dtypef(a3)		* set integer numeric data type
00:00002F14 7620            	  6362: 	moveq		#32,d3			* set up max binary exponent
                            	  6363: LAB_CHXX
00:00002F16 6100E6D2        	  6364: 	BSR		LAB_IGBY			* increment & scan memory
00:00002F1A 6514            	  6365: 	BCS.s		LAB_ISHN			* branch if numeric character
                            	  6366: 
00:00002F1C 803C0020        	  6367: 	OR.b		#$20,d0			* case convert, allow "A" to "F" and "a" to "f"
00:00002F20 903C0061        	  6368: 	SUB.b		#'a',d0			* subtract "a"
00:00002F24 652A            	  6369: 	BCS.s		LAB_CHX3			* exit if <"a"
                            	  6370: 
00:00002F26 B03C0006        	  6371: 	CMP.b		#$06,d0			* compare normalised with $06 (max+1)
00:00002F2A 6424            	  6372: 	BCC.s		LAB_CHX3			* exit if >"f"
                            	  6373: 
00:00002F2C D03C003A        	  6374: 	ADD.b		#$3A,d0			* convert to nibble+"0"
                            	  6375: LAB_ISHN
00:00002F30 616C            	  6376: 	BSR.s		d1x16				* multiply d1 by 16 and add character
00:00002F32 64E2            	  6377: 	BCC.s		LAB_CHXX			* loop for more if no overflow
                            	  6378: 
                            	  6379: 							* overflowed mantissa, count 16s exponent
                            	  6380: LAB_CHX1
00:00002F34 5883            	  6381: 	ADDQ.l	#4,d3				* increment mantissa exponent count
00:00002F36 6900DAFA        	  6382: 	BVS		LAB_OFER			* do overflow error if overflowed
                            	  6383: 
00:00002F3A 6100E6AE        	  6384: 	BSR		LAB_IGBY			* get next character
00:00002F3E 65F4            	  6385: 	BCS.s		LAB_CHX1			* loop while numeric character
                            	  6386: 
00:00002F40 803C0020        	  6387: 	OR.b		#$20,d0			* case convert, allow "A" to "F" and "a" to "f"
00:00002F44 903C0061        	  6388: 	SUB.b		#'a',d0			* subtract "a"
00:00002F48 6506            	  6389: 	BCS.s		LAB_CHX3			* exit if <"a"
                            	  6390: 
00:00002F4A B03C0006        	  6391: 	CMP.b		#$06,d0			* compare normalised with $06 (max+1)
00:00002F4E 65E4            	  6392: 	BCS.s		LAB_CHX1			* loop if <="f"
                            	  6393: 
                            	  6394: 							* now return value
                            	  6395: LAB_CHX3
00:00002F50 4A81            	  6396: 	TST.l		d1				* test mantissa
00:00002F52 67AA            	  6397: 	BEQ.s		LAB_rtn0			* if mantissa=0 return 0
                            	  6398: 
00:00002F54 6B08            	  6399: 	BMI.s		LAB_exxf			* branch if already mormalised
                            	  6400: 
