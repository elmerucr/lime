00:00002EDE 0A030080        	  6407: 	EORI.b	#$80,d3			* normalise exponent
00:00002EE2 17430594        	  6408: 	move.b	d3,FAC1_e(a3)		* save exponent
00:00002EE6 27410590        	  6409: 	move.l	d1,FAC1_m(a3)		* save mantissa
00:00002EEA 4CDF003E        	  6410: 	movem.l	(sp)+,d1-d5			* restore registers
