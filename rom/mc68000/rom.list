                            	  5432: 							* now separate integer and fraction
00:0000286E 177C000005D9    	  5433: 	move.b	#0,tpower(a3)		* clear exponent add byte
00:00002874 1A2B0594        	  5434: 	move.b	FAC1_e(a3),d5		* get exponent
00:00002878 9A3C0080        	  5435: 	SUB.b		#$80,d5			* normalise
00:0000287C 6324            	  5436: 	BLS.s		LAB_ESML			* branch if < 1 (d5 is 0 or -ve)
                            	  5437: 
