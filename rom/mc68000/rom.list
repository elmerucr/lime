00:00010B68 45F900010AD2    	   225: 	LEA	TAB1.1,A2
00:00010B6E 61000A94        	   226: EXEC	BSR	IGNBLK		ignore leading blanks
00:00010B72 2648            	   227: 	MOVE.L	A0,A3		save the pointer
00:00010B74 4202            	   228: 	CLR.B	D2		clear match flag
00:00010B76 1018            	   229: EXLP	MOVE.B	(A0)+,D0	get the program character
00:00010B78 1211            	   230: 	MOVE.B	(A1),D1 	get the table character
00:00010B7A 66000008        	   231: 	BNE	EXNGO		If end of table,
00:00010B7E 204B            	   232: 	MOVE.L	A3,A0		restore the text pointer and...
00:00010B80 60000030        	   233: 	BRA	EXGO		execute the default.
00:00010B84 1600            	   234: EXNGO	MOVE.B	D0,D3		Else check for period...
00:00010B86 C602            	   235: 	AND.B	D2,D3		and a match.
00:00010B88 B63C002E        	   236: 	CMP.B	#'.',D3
00:00010B8C 67000024        	   237: 	BEQ	EXGO		if so, execute
00:00010B90 C23C007F        	   238: 	AND.B	#$7F,D1 	ignore the table's high bit
