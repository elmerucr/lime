                            	   403: *
                            	   404: *******************************************************************
                            	   405: *
                            	   406: * *** GOSUB *** & RETURN ***
                            	   407: *
                            	   408: * 'GOSUB expr:' or 'GOSUB expr<CR>' is like the 'GOTO' command,
                            	   409: * except that the current text pointer, stack pointer, etc. are
                            	   410: * saved so that execution can be continued after the subroutine
                            	   411: * 'RETURN's.  In order that 'GOSUB' can be nested (and even
                            	   412: * recursive), the save area must be stacked.  The stack pointer
                            	   413: * is saved in 'STKGOS'.  The old 'STKGOS' is saved on the stack.
                            	   414: * If we are in the main routine, 'STKGOS' is zero (this was done
                            	   415: * in the initialization section of the interpreter), but we still
                            	   416: * save it as a flag for no further 'RETURN's.
                            	   417: *
                            	   418: * 'RETURN<CR>' undoes everything that 'GOSUB' did, and thus
                            	   419: * returns the execution to the command after the most recent
                            	   420: * 'GOSUB'.  If 'STKGOS' is zero, it indicates that we never had
                            	   421: * a 'GOSUB' and is thus an error.
                            	   422: *
00:00010C96 61000798        	   423: GOSUB	BSR	PUSHA		save the current 'FOR' parameters
00:00010C9A 61000334        	   424: 	BSR	EXPR		get line number
00:00010C9E 2F08            	   425: 	MOVE.L	A0,-(SP)	save text pointer
00:00010CA0 2200            	   426: 	MOVE.L	D0,D1
00:00010CA2 61000710        	   427: 	BSR	FNDLN		find the target line
00:00010CA6 6600064A        	   428: 	BNE	AHOW		if not there, say "How?"
00:00010CAA 2F3900006122    	   429: 	MOVE.L	CURRNT,-(SP)	found it, save old 'CURRNT'...
00:00010CB0 2F3900006126    	   430: 	MOVE.L	STKGOS,-(SP)	and 'STKGOS'
00:00010CB6 42B90000612E    	   431: 	CLR.L	LOPVAR		load new values
00:00010CBC 23CF00006126    	   432: 	MOVE.L	SP,STKGOS
00:00010CC2 6000FEF2        	   433: 	BRA	RUNTSL
                            	   434: 
00:00010CC6 610005C8        	   435: RETURN	BSR	ENDCHK		there should be just a <CR>
00:00010CCA 223900006126    	   436: 	MOVE.L	STKGOS,D1	get old stack pointer
00:00010CD0 670005CC        	   437: 	BEQ	QWHAT		if zero, it doesn't exist
00:00010CD4 2E41            	   438: 	MOVE.L	D1,SP		else restore it
00:00010CD6 23DF00006126    	   439: 	MOVE.L	(SP)+,STKGOS	and the old 'STKGOS'
00:00010CDC 23DF00006122    	   440: 	MOVE.L	(SP)+,CURRNT	and the old 'CURRNT'
00:00010CE2 205F            	   441: 	MOVE.L	(SP)+,A0	and the old text pointer
00:00010CE4 61000724        	   442: 	BSR	POPA		and the old 'FOR' parameters
00:00010CE8 6000FFA4        	   443: 	BRA	FINISH		and we are back home
                            	   444: 
                            	   445: *
                            	   446: *******************************************************************
                            	   447: *
                            	   448: * *** FOR *** & NEXT ***
                            	   449: *
                            	   450: * 'FOR' has two forms:
                            	   451: * 'FOR var=exp1 TO exp2 STEP exp1' and 'FOR var=exp1 TO exp2'
                            	   452: * The second form means the same thing as the first form with a
                            	   453: * STEP of positive 1.  The interpreter will find the variable 'var'
                            	   454: * and set its value to the current value of 'exp1'.  It also
                            	   455: * evaluates 'exp2' and 'exp1' and saves all these together with
                            	   456: * the text pointer, etc. in the 'FOR' save area, which consisits of
                            	   457: * 'LOPVAR', 'LOPINC', 'LOPLMT', 'LOPLN', and 'LOPPT'.  If there is
                            	   458: * already something in the save area (indicated by a non-zero
                            	   459: * 'LOPVAR'), then the old save area is saved on the stack before
                            	   460: * the new values are stored.  The interpreter will then dig in the
                            	   461: * stack and find out if this same variable was used in another
                            	   462: * currently active 'FOR' loop.  If that is the case, then the old
                            	   463: * 'FOR' loop is deactivated. (i.e. purged from the stack)
                            	   464: *
                            	   465: * 'NEXT var' serves as the logical (not necessarily physical) end
                            	   466: * of the 'FOR' loop.  The control variable 'var' is checked with
                            	   467: * the 'LOPVAR'.  If they are not the same, the interpreter digs in
                            	   468: * the stack to find the right one and purges all those that didn't
                            	   469: * match.  Either way, it then adds the 'STEP' to that variable and
                            	   470: * checks the result with against the limit value.  If it is within
                            	   471: * the limit, control loops back to the command following the
                            	   472: * 'FOR'.  If it's outside the limit, the save area is purged and
                            	   473: * execution continues.
                            	   474: *
00:00010CEC 61000742        	   475: FOR	BSR	PUSHA		save the old 'FOR' save area
00:00010CF0 61000566        	   476: 	BSR	SETVAL		set the control variable
00:00010CF4 23CE0000612E    	   477: 	MOVE.L	A6,LOPVAR	save its address
00:00010CFA 43F900010A7D    	   478: 	LEA	TAB5,A1 	use 'EXEC' to test for 'TO'
00:00010D00 45F900010AF4    	   479: 	LEA	TAB5.1,A2
00:00010D06 6000FE24        	   480: 	BRA	EXEC
00:00010D0A 610002C4        	   481: FR1	BSR	EXPR		evaluate the limit
00:00010D0E 23C000006136    	   482: 	MOVE.L	D0,LOPLMT	save that
00:00010D14 43F900010A80    	   483: 	LEA	TAB6,A1 	use 'EXEC' to look for the
00:00010D1A 45F900010AFC    	   484: 	LEA	TAB6.1,A2	word 'STEP'
00:00010D20 6000FE0A        	   485: 	BRA	EXEC
00:00010D24 610002AA        	   486: FR2	BSR	EXPR		found it, get the step value
00:00010D28 60000004        	   487: 	BRA	FR4
00:00010D2C 7001            	   488: FR3	MOVEQ	#1,D0		not found, step defaults to 1
00:00010D2E 23C000006132    	   489: FR4	MOVE.L	D0,LOPINC	save that too
00:00010D34 23F9000061220000	   490: FR5	MOVE.L	CURRNT,LOPLN	save address of current line number
00:00010D3C 613A
00:00010D3E 23C80000613E    	   491: 	MOVE.L	A0,LOPPT	and text pointer
00:00010D44 2C4F            	   492: 	MOVE.L	SP,A6		dig into the stack to find 'LOPVAR'
00:00010D46 60000008        	   493: 	BRA	FR7
00:00010D4A DDFC00000014    	   494: FR6	ADD.L	#20,A6		look at next stack frame
00:00010D50 2016            	   495: FR7	MOVE.L	(A6),D0 	is it zero?
00:00010D52 6700001E        	   496: 	BEQ	FR8		if so, we're done
00:00010D56 B0B90000612E    	   497: 	CMP.L	LOPVAR,D0	same as current LOPVAR?
00:00010D5C 6600FFEC        	   498: 	BNE	FR6		nope, look some more
00:00010D60 244F            	   499: 	MOVE.L	SP,A2		Else remove 5 long words from...
00:00010D62 224E            	   500: 	MOVE.L	A6,A1		inside the stack.
00:00010D64 47F900000014    	   501: 	LEA	20,A3
00:00010D6A D7C9            	   502: 	ADD.L	A1,A3
00:00010D6C 61000690        	   503: 	BSR	MVDOWN
00:00010D70 2E4B            	   504: 	MOVE.L	A3,SP		set the SP 5 long words up
00:00010D72 6000FF1A        	   505: FR8	BRA	FINISH		and continue execution
                            	   506: 
00:00010D76 6100038E        	   507: NEXT	BSR	TSTV		get address of variable
00:00010D7A 65000522        	   508: 	BCS	QWHAT		if no variable, say "What?"
00:00010D7E 2240            	   509: 	MOVE.L	D0,A1		save variable's address
00:00010D80 20390000612E    	   510: NX0	MOVE.L	LOPVAR,D0	If 'LOPVAR' is zero, we never...
00:00010D86 67000516        	   511: 	BEQ	QWHAT		had a FOR loop, so say "What?"
00:00010D8A B3C0            	   512: 	CMP.L	D0,A1		else we check them
00:00010D8C 6700000A        	   513: 	BEQ	NX3		OK, they agree
00:00010D90 61000678        	   514: 	BSR	POPA		nope, let's see the next frame
00:00010D94 6000FFEA        	   515: 	BRA	NX0
00:00010D98 2011            	   516: NX3	MOVE.L	(A1),D0 	get control variable's value
00:00010D9A D0B900006132    	   517: 	ADD.L	LOPINC,D0	add in loop increment
00:00010DA0 6900054E        	   518: 	BVS	QHOW		say "How?" for 32-bit overflow
00:00010DA4 2280            	   519: 	MOVE.L	D0,(A1) 	save control variable's new value
00:00010DA6 223900006136    	   520: 	MOVE.L	LOPLMT,D1	get loop's limit value
00:00010DAC 4AB900006132    	   521: 	TST.L	LOPINC
00:00010DB2 6A000004        	   522: 	BPL	NX1		branch if loop increment is positive
00:00010DB6 C141            	   523: 	EXG	D0,D1
00:00010DB8 B280            	   524: NX1	CMP.L	D0,D1		test against limit
00:00010DBA 6D000016        	   525: 	BLT	NX2		branch if outside limit
00:00010DBE 23F90000613A0000	   526: 	MOVE.L	LOPLN,CURRNT	Within limit, go back to the...
00:00010DC6 6122
00:00010DC8 20790000613E    	   527: 	MOVE.L	LOPPT,A0	saved 'CURRNT' and text pointer.
00:00010DCE 6000FEBE        	   528: 	BRA	FINISH
00:00010DD2 61000636        	   529: NX2	BSR	POPA		purge this loop
00:00010DD6 6000FEB6        	   530: 	BRA	FINISH
                            	   531: 
                            	   532: *
                            	   533: *******************************************************************
                            	   534: *
                            	   535: * *** REM *** IF *** INPUT *** LET (& DEFLT) ***
                            	   536: *
                            	   537: * 'REM' can be followed by anything and is ignored by the
                            	   538: * interpreter.
                            	   539: *
                            	   540: * 'IF' is followed by an expression, as a condition and one or
                            	   541: * more commands (including other 'IF's) separated by colons.
                            	   542: * Note that the word 'THEN' is not used.  The interpreter evaluates
                            	   543: * the expression.  If it is non-zero, execution continues.  If it
                            	   544: * is zero, the commands that follow are ignored and execution
                            	   545: * continues on the next line.
                            	   546: *
                            	   547: * 'INPUT' is like the 'PRINT' command, and is followed by a list
                            	   548: * of items.  If the item is a string in single or double quotes,
                            	   549: * or is an underline (back arrow), it has the same effect as in
                            	   550: * 'PRINT'.  If an item is a variable, this variable name is
                            	   551: * printed out followed by a colon, then the interpreter waits for
                            	   552: * an expression to be typed in.  The variable is then set to the
                            	   553: * value of this expression.  If the variable is preceeded by a
                            	   554: * string (again in single or double quotes), the string will be
                            	   555: * displayed followed by a colon.  The interpreter the waits for an
                            	   556: * expression to be entered and sets the variable equal to the
                            	   557: * expression's value.  If the input expression is invalid, the
                            	   558: * interpreter will print "What?", "How?", or "Sorry" and reprint
                            	   559: * the prompt and redo the input.  The execution will not terminate
                            	   560: * unless you press control-C.  This is handled in 'INPERR'.
                            	   561: *
                            	   562: * 'LET' is followed by a list of items separated by commas.
                            	   563: * Each item consists of a variable, an equals sign, and an
                            	   564: * expression.  The interpreter evaluates the expression and sets
                            	   565: * the variable to that value.  The interpreter will also handle
                            	   566: * 'LET' commands without the word 'LET'.  This is done by 'DEFLT'.
                            	   567: *
00:00010DDA 6000000C        	   568: REM	BRA	IF2		skip the rest of the line
                            	   569: 
00:00010DDE 610001F0        	   570: IF	BSR	EXPR		evaluate the expression
00:00010DE2 4A80            	   571: IF1	TST.L	D0		is it zero?
00:00010DE4 6600FDDA        	   572: 	BNE	RUNSML		if not, continue
00:00010DE8 2248            	   573: IF2	MOVE.L	A0,A1
00:00010DEA 4281            	   574: 	CLR.L	D1
00:00010DEC 610005F6        	   575: 	BSR	FNDSKP		if so, skip the rest of the line
00:00010DF0 6400FDC4        	   576: 	BCC	RUNTSL		and run the next line
00:00010DF4 6000FB7C        	   577: 	BRA	WSTART		if no next line, do a warm start
                            	   578: 
00:00010DF8 2E790000612A    	   579: INPERR	MOVE.L	STKINP,SP	restore the old stack pointer
00:00010DFE 23DF00006122    	   580: 	MOVE.L	(SP)+,CURRNT	and old 'CURRNT'
00:00010E04 588F            	   581: 	ADDQ.L	#4,SP
00:00010E06 205F            	   582: 	MOVE.L	(SP)+,A0	and old text pointer
                            	   583: 
00:00010E08 2F08            	   584: INPUT	MOVE.L	A0,-(SP)	save in case of error
00:00010E0A 61000678        	   585: 	BSR	QTSTG		is next item a string?
00:00010E0E 600E            	   586: 	BRA.S	IP2		nope
00:00010E10 610002F4        	   587: 	BSR	TSTV		yes, but is it followed by a variable?
00:00010E14 6500005A        	   588: 	BCS	IP4		if not, branch
00:00010E18 2440            	   589: 	MOVE.L	D0,A2		put away the variable's address
00:00010E1A 6000001C        	   590: 	BRA	IP3		if so, input to variable
00:00010E1E 2F08            	   591: IP2	MOVE.L	A0,-(SP)	save for 'PRTSTG'
00:00010E20 610002E4        	   592: 	BSR	TSTV		must be a variable now
00:00010E24 65000478        	   593: 	BCS	QWHAT		"What?" it isn't?
00:00010E28 2440            	   594: 	MOVE.L	D0,A2		put away the variable's address
00:00010E2A 1410            	   595: 	MOVE.B	(A0),D2 	get ready for 'PRTSTG'
00:00010E2C 4200            	   596: 	CLR.B	D0
00:00010E2E 1080            	   597: 	MOVE.B	D0,(A0)
00:00010E30 225F            	   598: 	MOVE.L	(SP)+,A1
00:00010E32 61000630        	   599: 	BSR	PRTSTG		print string as prompt
00:00010E36 1082            	   600: 	MOVE.B	D2,(A0) 	restore text
00:00010E38 2F08            	   601: IP3	MOVE.L	A0,-(SP)	save in case of error
00:00010E3A 2F3900006122    	   602: 	MOVE.L	CURRNT,-(SP)	also save 'CURRNT'
00:00010E40 23FCFFFFFFFF0000	   603: 	MOVE.L	#-1,CURRNT	flag that we are in INPUT
00:00010E48 6122
00:00010E4A 23CF0000612A    	   604: 	MOVE.L	SP,STKINP	save the stack pointer too
00:00010E50 2F0A            	   605: 	MOVE.L	A2,-(SP)	save the variable address
00:00010E52 103C003A        	   606: 	MOVE.B	#':',D0         print a colon first
00:00010E56 610004A4        	   607: 	BSR	GETLN		then get an input line
00:00010E5A 41F90000614E    	   608: 	LEA	BUFFER,A0	point to the buffer
00:00010E60 6100016E        	   609: 	BSR	EXPR		evaluate the input
00:00010E64 245F            	   610: 	MOVE.L	(SP)+,A2	restore the variable address
00:00010E66 2480            	   611: 	MOVE.L	D0,(A2) 	save value in variable
00:00010E68 23DF00006122    	   612: 	MOVE.L	(SP)+,CURRNT	restore old 'CURRNT'
00:00010E6E 205F            	   613: 	MOVE.L	(SP)+,A0	and the old text pointer
00:00010E70 588F            	   614: IP4	ADDQ.L	#4,SP		clean up the stack
00:00010E72 610006F4        	   615: 	BSR	TSTC		is the next thing a comma?
00:00010E76 2C              	   616: 	DC.B	',',IP5-*
00:00010E77 05
00:00010E78 6000FF8E        	   617: 	BRA	INPUT		yes, more items
00:00010E7C 6000FE10        	   618: IP5	BRA	FINISH
                            	   619: 
00:00010E80 0C10000A        	   620: DEFLT	CMP.B	#LF,(A0)	empty line is OK
00:00010E84 67000010        	   621: 	BEQ	LT1		else it is 'LET'
                            	   622: 
00:00010E88 610003CE        	   623: LET	BSR	SETVAL		do the assignment
00:00010E8C 610006DA        	   624: 	BSR	TSTC		check for more 'LET' items
00:00010E90 2C              	   625: 	DC.B	',',LT1-*
00:00010E91 05
00:00010E92 6000FFF4        	   626: 	BRA	LET
00:00010E96 6000FDF6        	   627: LT1	BRA	FINISH		until we are finished.
