                            	  6434: LAB_CBX1
00:00002F8A 5283            	  6435: 	ADDQ.l	#1,d3				* increment mantissa exponent count
00:00002F8C 6900DAA4        	  6436: 	BVS		LAB_OFER			* do overflow error if overflowed
                            	  6437: 
00:00002F90 6100E658        	  6438: 	BSR		LAB_IGBY			* get next character
