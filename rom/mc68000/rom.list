00:00002D58 6504            	  6112: 	BCS.s		LAB_SQNS			* skip sub if remainder smaller
                            	  6113: 
00:00002D5A 9484            	  6114: 	SUB.l		d4,d2				* subtract temp from remainder
00:00002D5C 5281            	  6115: 	ADDQ.l	#1,d1				* increment root
                            	  6116: LAB_SQNS
00:00002D5E 51CBFFE6        	  6117: 	DBF		d3,LAB_SQE1			* loop if not all done
                            	  6118: 
