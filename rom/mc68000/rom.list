00:00011590 4281            	  1360: PRTLN	CLR.L	D1
00:00011592 1219            	  1361: 	MOVE.B	(A1)+,D1	get the binary line number
00:00011594 E149            	  1362: 	LSL	#8,D1
00:00011596 1219            	  1363: 	MOVE.B	(A1)+,D1
00:00011598 7805            	  1364: 	MOVEQ	#5,D4		display a 5 digit line no.
00:0001159A 6100FF70        	  1365: 	BSR	PRTNUM
00:0001159E 103C0020        	  1366: 	MOVE.B	#' ',D0         followed by a blank
00:000115A2 6100F3C2        	  1367: 	BSR	GOOUT
