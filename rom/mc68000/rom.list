                            	  5639: LAB_SCL0
00:00002978 4400            	  5640: 	NEG.b		d0				* make +ve
00:0000297A B03C001E        	  5641: 	CMP.b		#$1E,d0			* is it <= 2^-30
00:0000297E 64EA            	  5642: 	BCC.s		LAB_SCZE			* may as well do zero
                            	  5643: 
00:00002980 E0AE            	  5644: 	LSR.l		d0,d6				* shift out <= 2^-32 bits
                            	  5645: 
