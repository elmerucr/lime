00:0000284A 7200            	  5473: 	moveq		#0,d1				* y = 0
00:0000284C 2C3CE6A3D110    	  5474: 	move.l	#KFCTSEED,d6		* x = 1 with jkh inverse factored out
00:00002852 41FA09FC        	  5475: 	lea		(TAB_HTHET,PC),a0		* get pointer to hyperbolic arctan table
