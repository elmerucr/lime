                            	   946: *
                            	   947: * ===== Divide the 32 bit value in D0 by the 32 bit value in D1.
                            	   948: *	Returns the 32 bit quotient in D0, remainder in D1.
                            	   949: *
00:000111CE 4A81            	   950: DIV32	TST.L	D1		check for divide-by-zero
00:000111D0 67000142        	   951: 	BEQ	QHOW		if so, say "How?"
00:000111D4 2401            	   952: 	MOVE.L	D1,D2
00:000111D6 2801            	   953: 	MOVE.L	D1,D4
00:000111D8 B184            	   954: 	EOR.L	D0,D4		see if the signs are the same
00:000111DA 4A80            	   955: 	TST.L	D0		take absolute value of D0
00:000111DC 6A000004        	   956: 	BPL	DIV1
00:000111E0 4480            	   957: 	NEG.L	D0
00:000111E2 4A81            	   958: DIV1	TST.L	D1		take absolute value of D1
00:000111E4 6A000004        	   959: 	BPL	DIV2
00:000111E8 4481            	   960: 	NEG.L	D1
00:000111EA 761F            	   961: DIV2	MOVEQ	#31,D3		iteration count for 32 bits
00:000111EC 2200            	   962: 	MOVE.L	D0,D1
00:000111EE 4280            	   963: 	CLR.L	D0
00:000111F0 D281            	   964: DIV3	ADD.L	D1,D1		(This algorithm was translated from
00:000111F2 D180            	   965: 	ADDX.L	D0,D0		the divide routine in Ron Cain's
00:000111F4 6700000C        	   966: 	BEQ	DIV4		Small-C run time library.)
00:000111F8 B082            	   967: 	CMP.L	D2,D0
00:000111FA 6B000006        	   968: 	BMI	DIV4
00:000111FE 5281            	   969: 	ADDQ.L	#1,D1
00:00011200 9082            	   970: 	SUB.L	D2,D0
00:00011202 51CBFFEC        	   971: DIV4	DBRA	D3,DIV3
00:00011206 C141            	   972: 	EXG	D0,D1		put rem. & quot. in proper registers
00:00011208 4A84            	   973: 	TST.L	D4		were the signs the same?
00:0001120A 6A000006        	   974: 	BPL	DIVRT
