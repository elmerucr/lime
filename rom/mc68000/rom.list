                            	   403: *
                            	   404: *******************************************************************
                            	   405: *
                            	   406: * *** GOSUB *** & RETURN ***
                            	   407: *
                            	   408: * 'GOSUB expr:' or 'GOSUB expr<CR>' is like the 'GOTO' command,
                            	   409: * except that the current text pointer, stack pointer, etc. are
                            	   410: * saved so that execution can be continued after the subroutine
                            	   411: * 'RETURN's.  In order that 'GOSUB' can be nested (and even
                            	   412: * recursive), the save area must be stacked.  The stack pointer
                            	   413: * is saved in 'STKGOS'.  The old 'STKGOS' is saved on the stack.
                            	   414: * If we are in the main routine, 'STKGOS' is zero (this was done
                            	   415: * in the initialization section of the interpreter), but we still
                            	   416: * save it as a flag for no further 'RETURN's.
                            	   417: *
                            	   418: * 'RETURN<CR>' undoes everything that 'GOSUB' did, and thus
                            	   419: * returns the execution to the command after the most recent
                            	   420: * 'GOSUB'.  If 'STKGOS' is zero, it indicates that we never had
                            	   421: * a 'GOSUB' and is thus an error.
                            	   422: *
00:00010CC2 61000798        	   423: GOSUB	BSR	PUSHA		save the current 'FOR' parameters
00:00010CC6 61000334        	   424: 	BSR	EXPR		get line number
00:00010CCA 2F08            	   425: 	MOVE.L	A0,-(SP)	save text pointer
00:00010CCC 2200            	   426: 	MOVE.L	D0,D1
00:00010CCE 61000710        	   427: 	BSR	FNDLN		find the target line
00:00010CD2 6600064A        	   428: 	BNE	AHOW		if not there, say "How?"
00:00010CD6 2F3900006126    	   429: 	MOVE.L	CURRNT,-(SP)	found it, save old 'CURRNT'...
00:00010CDC 2F390000612A    	   430: 	MOVE.L	STKGOS,-(SP)	and 'STKGOS'
00:00010CE2 42B900006132    	   431: 	CLR.L	LOPVAR		load new values
00:00010CE8 23CF0000612A    	   432: 	MOVE.L	SP,STKGOS
00:00010CEE 6000FEF2        	   433: 	BRA	RUNTSL
                            	   434: 
00:00010CF2 610005C8        	   435: RETURN	BSR	ENDCHK		there should be just a <CR>
00:00010CF6 22390000612A    	   436: 	MOVE.L	STKGOS,D1	get old stack pointer
00:00010CFC 670005CC        	   437: 	BEQ	QWHAT		if zero, it doesn't exist
00:00010D00 2E41            	   438: 	MOVE.L	D1,SP		else restore it
00:00010D02 23DF0000612A    	   439: 	MOVE.L	(SP)+,STKGOS	and the old 'STKGOS'
00:00010D08 23DF00006126    	   440: 	MOVE.L	(SP)+,CURRNT	and the old 'CURRNT'
00:00010D0E 205F            	   441: 	MOVE.L	(SP)+,A0	and the old text pointer
00:00010D10 61000724        	   442: 	BSR	POPA		and the old 'FOR' parameters
00:00010D14 6000FFA4        	   443: 	BRA	FINISH		and we are back home
                            	   444: 
                            	   445: *
                            	   446: *******************************************************************
                            	   447: *
                            	   448: * *** FOR *** & NEXT ***
                            	   449: *
                            	   450: * 'FOR' has two forms:
                            	   451: * 'FOR var=exp1 TO exp2 STEP exp1' and 'FOR var=exp1 TO exp2'
                            	   452: * The second form means the same thing as the first form with a
                            	   453: * STEP of positive 1.  The interpreter will find the variable 'var'
                            	   454: * and set its value to the current value of 'exp1'.  It also
                            	   455: * evaluates 'exp2' and 'exp1' and saves all these together with
                            	   456: * the text pointer, etc. in the 'FOR' save area, which consisits of
                            	   457: * 'LOPVAR', 'LOPINC', 'LOPLMT', 'LOPLN', and 'LOPPT'.  If there is
                            	   458: * already something in the save area (indicated by a non-zero
                            	   459: * 'LOPVAR'), then the old save area is saved on the stack before
                            	   460: * the new values are stored.  The interpreter will then dig in the
                            	   461: * stack and find out if this same variable was used in another
                            	   462: * currently active 'FOR' loop.  If that is the case, then the old
                            	   463: * 'FOR' loop is deactivated. (i.e. purged from the stack)
                            	   464: *
                            	   465: * 'NEXT var' serves as the logical (not necessarily physical) end
                            	   466: * of the 'FOR' loop.  The control variable 'var' is checked with
                            	   467: * the 'LOPVAR'.  If they are not the same, the interpreter digs in
                            	   468: * the stack to find the right one and purges all those that didn't
                            	   469: * match.  Either way, it then adds the 'STEP' to that variable and
                            	   470: * checks the result with against the limit value.  If it is within
                            	   471: * the limit, control loops back to the command following the
                            	   472: * 'FOR'.  If it's outside the limit, the save area is purged and
                            	   473: * execution continues.
                            	   474: *
00:00010D18 61000742        	   475: FOR	BSR	PUSHA		save the old 'FOR' save area
00:00010D1C 61000566        	   476: 	BSR	SETVAL		set the control variable
00:00010D20 23CE00006132    	   477: 	MOVE.L	A6,LOPVAR	save its address
00:00010D26 43F900010AA9    	   478: 	LEA	TAB5,A1 	use 'EXEC' to test for 'TO'
00:00010D2C 45F900010B20    	   479: 	LEA	TAB5.1,A2
00:00010D32 6000FE24        	   480: 	BRA	EXEC
00:00010D36 610002C4        	   481: FR1	BSR	EXPR		evaluate the limit
00:00010D3A 23C00000613A    	   482: 	MOVE.L	D0,LOPLMT	save that
00:00010D40 43F900010AAC    	   483: 	LEA	TAB6,A1 	use 'EXEC' to look for the
00:00010D46 45F900010B28    	   484: 	LEA	TAB6.1,A2	word 'STEP'
00:00010D4C 6000FE0A        	   485: 	BRA	EXEC
00:00010D50 610002AA        	   486: FR2	BSR	EXPR		found it, get the step value
00:00010D54 60000004        	   487: 	BRA	FR4
00:00010D58 7001            	   488: FR3	MOVEQ	#1,D0		not found, step defaults to 1
00:00010D5A 23C000006136    	   489: FR4	MOVE.L	D0,LOPINC	save that too
00:00010D60 23F9000061260000	   490: FR5	MOVE.L	CURRNT,LOPLN	save address of current line number
00:00010D68 613E
00:00010D6A 23C800006142    	   491: 	MOVE.L	A0,LOPPT	and text pointer
00:00010D70 2C4F            	   492: 	MOVE.L	SP,A6		dig into the stack to find 'LOPVAR'
00:00010D72 60000008        	   493: 	BRA	FR7
00:00010D76 DDFC00000014    	   494: FR6	ADD.L	#20,A6		look at next stack frame
00:00010D7C 2016            	   495: FR7	MOVE.L	(A6),D0 	is it zero?
00:00010D7E 6700001E        	   496: 	BEQ	FR8		if so, we're done
00:00010D82 B0B900006132    	   497: 	CMP.L	LOPVAR,D0	same as current LOPVAR?
00:00010D88 6600FFEC        	   498: 	BNE	FR6		nope, look some more
00:00010D8C 244F            	   499: 	MOVE.L	SP,A2		Else remove 5 long words from...
00:00010D8E 224E            	   500: 	MOVE.L	A6,A1		inside the stack.
00:00010D90 47F900000014    	   501: 	LEA	20,A3
00:00010D96 D7C9            	   502: 	ADD.L	A1,A3
00:00010D98 61000690        	   503: 	BSR	MVDOWN
00:00010D9C 2E4B            	   504: 	MOVE.L	A3,SP		set the SP 5 long words up
00:00010D9E 6000FF1A        	   505: FR8	BRA	FINISH		and continue execution
                            	   506: 
00:00010DA2 6100038E        	   507: NEXT	BSR	TSTV		get address of variable
00:00010DA6 65000522        	   508: 	BCS	QWHAT		if no variable, say "What?"
00:00010DAA 2240            	   509: 	MOVE.L	D0,A1		save variable's address
00:00010DAC 203900006132    	   510: NX0	MOVE.L	LOPVAR,D0	If 'LOPVAR' is zero, we never...
00:00010DB2 67000516        	   511: 	BEQ	QWHAT		had a FOR loop, so say "What?"
00:00010DB6 B3C0            	   512: 	CMP.L	D0,A1		else we check them
00:00010DB8 6700000A        	   513: 	BEQ	NX3		OK, they agree
00:00010DBC 61000678        	   514: 	BSR	POPA		nope, let's see the next frame
00:00010DC0 6000FFEA        	   515: 	BRA	NX0
00:00010DC4 2011            	   516: NX3	MOVE.L	(A1),D0 	get control variable's value
00:00010DC6 D0B900006136    	   517: 	ADD.L	LOPINC,D0	add in loop increment
00:00010DCC 6900054E        	   518: 	BVS	QHOW		say "How?" for 32-bit overflow
00:00010DD0 2280            	   519: 	MOVE.L	D0,(A1) 	save control variable's new value
00:00010DD2 22390000613A    	   520: 	MOVE.L	LOPLMT,D1	get loop's limit value
00:00010DD8 4AB900006136    	   521: 	TST.L	LOPINC
00:00010DDE 6A000004        	   522: 	BPL	NX1		branch if loop increment is positive
00:00010DE2 C141            	   523: 	EXG	D0,D1
00:00010DE4 B280            	   524: NX1	CMP.L	D0,D1		test against limit
00:00010DE6 6D000016        	   525: 	BLT	NX2		branch if outside limit
00:00010DEA 23F90000613E0000	   526: 	MOVE.L	LOPLN,CURRNT	Within limit, go back to the...
00:00010DF2 6126
00:00010DF4 207900006142    	   527: 	MOVE.L	LOPPT,A0	saved 'CURRNT' and text pointer.
00:00010DFA 6000FEBE        	   528: 	BRA	FINISH
00:00010DFE 61000636        	   529: NX2	BSR	POPA		purge this loop
00:00010E02 6000FEB6        	   530: 	BRA	FINISH
