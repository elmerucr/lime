00:000110FC 6000FA5A        	   860: 	BRA	EXEC
00:00011100 61000030        	   861: XP40	BSR	TSTV		nope, not a function
00:00011104 6500000A        	   862: 	BCS	XP41		nor a variable
00:00011108 2240            	   863: 	MOVE.L	D0,A1
00:0001110A 4280            	   864: 	CLR.L	D0
00:0001110C 2011            	   865: 	MOVE.L	(A1),D0 	if a variable, return its value in D0
00:0001110E 4E75            	   866: EXP4RT	RTS
00:00011110 6100049E        	   867: XP41	BSR	TSTNUM		or is it a number?
00:00011114 2001            	   868: 	MOVE.L	D1,D0
00:00011116 4A42            	   869: 	TST	D2		(if not, # of digits will be zero)
00:00011118 6600FFF4        	   870: 	BNE	EXP4RT		if so, return it in D0
00:0001111C 61000476        	   871: PARN	BSR	TSTC		else look for ( EXPR )
00:00011120 28              	   872: 	DC.B	'(',XP43-*
00:00011121 0D
