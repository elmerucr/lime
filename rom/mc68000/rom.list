                            	    36: ; Subroutine: b_remove_spaces
                            	    37: ; Inputs:     A0 pointer to text in buffer
                            	    38: ; Outputs:    A0 point to first item not #$20 (char OR 0 = EOL), D0.b contains content at A0
                            	    39: ; ----------------------------------------------------------------------
                            	    40: b_remove_spaces
