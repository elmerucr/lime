00:00010602 65000022        	   569: 	blo	.2			; no
                            	   570: 
00:00010606 06410080        	   571: .lf	addi.w	#TERMINAL_HPITCH,D1	; yes, move cursor one line down, followed by carriage return
00:0001060A 0241FF80        	   572: .cr	andi.w	#%1111111110000000,D1	; cursor to beginning of line (carriage return)
                            	   573: 
00:0001060E B27C0A00        	   574: .1	cmp.w	#(TERMINAL_HPITCH*TERMINAL_HEIGHT),D1	; check for cursor out of screen
00:00010612 65000012        	   575: 	blo	.2			; no
                            	   576: 
