00:00002DDC 6600DBE4        	  6265: 	BNE		LAB_SNER			* wasn't - + TK_MINUS TK_PLUS or # so do error
                            	  6266: 
                            	  6267: LAB_2X03
00:00002DE0 6100E788        	  6268: 	BSR		LAB_IGBY			* get next character
00:00002DE4 6436            	  6269: 	BCC.s		LAB_2Y01			* if not digit all done, go evaluate
                            	  6270: LAB_2X04
