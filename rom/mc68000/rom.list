00:00002DBC 6528            	  6248: 	BCS.s		LAB_2X04			* branch if digit
                            	  6249: 
00:00002DBE B03C002D        	  6250: 	CMP.b		#'-',d0			* or is it -ve number
00:00002DC2 6706            	  6251: 	BEQ.s		LAB_2X01			* branch if so
                            	  6252: 
00:00002DC4 B03C00B2        	  6253: 	CMP.b		#TK_MINUS,d0		* or is it -ve number
00:00002DC8 6608            	  6254: 	BNE.s		LAB_2X02			* branch if not
