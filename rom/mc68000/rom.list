00:000111BE 6300000E        	   927: 	BLS	MLT3		OK, let it through
00:000111C2 C141            	   928: 	EXG	D0,D1		else swap the two arguments
00:000111C4 B2BC0000FFFF    	   929: 	CMP.L	#$FFFF,D1	and check 2nd argument again
00:000111CA 62000168        	   930: 	BHI	QHOW		one of them MUST be 16 bits
00:000111CE 3400            	   931: MLT3	MOVE	D0,D2		prepare for 32 bit X 16 bit multiply
00:000111D0 C4C1            	   932: 	MULU	D1,D2		multiply low word
00:000111D2 4840            	   933: 	SWAP	D0
00:000111D4 C0C1            	   934: 	MULU	D1,D0		multiply high word
00:000111D6 4840            	   935: 	SWAP	D0
                            	   936: *** Rick Murray's bug correction follows:
00:000111D8 4A40            	   937: 	TST	D0		if lower word not 0, then overflow
00:000111DA 66000158        	   938: 	BNE	QHOW		if overflow, say "How?"
00:000111DE D082            	   939: 	ADD.L	D2,D0		D0 now holds the product
00:000111E0 6B000152        	   940: 	BMI	QHOW		if sign bit set, it's an overflow
00:000111E4 4A84            	   941: 	TST.L	D4		were the signs the same?
00:000111E6 6A000004        	   942: 	BPL	MLTRET
00:000111EA 4480            	   943: 	NEG.L	D0		if not, make the result negative
00:000111EC 4E75            	   944: MLTRET	RTS
                            	   945: 
                            	   946: *
                            	   947: * ===== Divide the 32 bit value in D0 by the 32 bit value in D1.
                            	   948: *	Returns the 32 bit quotient in D0, remainder in D1.
                            	   949: *
00:000111EE 4A81            	   950: DIV32	TST.L	D1		check for divide-by-zero
00:000111F0 67000142        	   951: 	BEQ	QHOW		if so, say "How?"
00:000111F4 2401            	   952: 	MOVE.L	D1,D2
00:000111F6 2801            	   953: 	MOVE.L	D1,D4
00:000111F8 B184            	   954: 	EOR.L	D0,D4		see if the signs are the same
00:000111FA 4A80            	   955: 	TST.L	D0		take absolute value of D0
00:000111FC 6A000004        	   956: 	BPL	DIV1
00:00011200 4480            	   957: 	NEG.L	D0
00:00011202 4A81            	   958: DIV1	TST.L	D1		take absolute value of D1
00:00011204 6A000004        	   959: 	BPL	DIV2
00:00011208 4481            	   960: 	NEG.L	D1
00:0001120A 761F            	   961: DIV2	MOVEQ	#31,D3		iteration count for 32 bits
00:0001120C 2200            	   962: 	MOVE.L	D0,D1
00:0001120E 4280            	   963: 	CLR.L	D0
00:00011210 D281            	   964: DIV3	ADD.L	D1,D1		(This algorithm was translated from
00:00011212 D180            	   965: 	ADDX.L	D0,D0		the divide routine in Ron Cain's
00:00011214 6700000C        	   966: 	BEQ	DIV4		Small-C run time library.)
00:00011218 B082            	   967: 	CMP.L	D2,D0
00:0001121A 6B000006        	   968: 	BMI	DIV4
00:0001121E 5281            	   969: 	ADDQ.L	#1,D1
00:00011220 9082            	   970: 	SUB.L	D2,D0
00:00011222 51CBFFEC        	   971: DIV4	DBRA	D3,DIV3
00:00011226 C141            	   972: 	EXG	D0,D1		put rem. & quot. in proper registers
00:00011228 4A84            	   973: 	TST.L	D4		were the signs the same?
00:0001122A 6A000006        	   974: 	BPL	DIVRT
00:0001122E 4480            	   975: 	NEG.L	D0		if not, results are negative
00:00011230 4481            	   976: 	NEG.L	D1
00:00011232 4E75            	   977: DIVRT	RTS
                            	   978: 
                            	   979: *
                            	   980: * ===== The PEEK function returns the byte stored at the address
                            	   981: *	contained in the following expression.
                            	   982: *
00:00011234 6100FEFE        	   983: PEEK	BSR	PARN		get the memory address
00:00011238 2240            	   984: 	MOVE.L	D0,A1
00:0001123A 4280            	   985: 	CLR.L	D0		upper 3 bytes will be zero
00:0001123C 1011            	   986: 	MOVE.B	(A1),D0 	get the addressed byte
00:0001123E 4E75            	   987: 	RTS			and return it
                            	   988: 
                            	   989: *
                            	   990: * ===== The RND function returns a random number from 1 to
                            	   991: *	the value of the following expression in D0.
                            	   992: *
00:00011240 6100FEF2        	   993: RND	BSR	PARN		get the upper limit
00:00011244 4A80            	   994: 	TST.L	D0		it must be positive and non-zero
00:00011246 670000EC        	   995: 	BEQ	QHOW
00:0001124A 6B0000E8        	   996: 	BMI	QHOW
00:0001124E 2200            	   997: 	MOVE.L	D0,D1
00:00011250 227900006122    	   998: 	MOVE.L	RANPNT,A1	get memory as a random number
00:00011256 B3FC0001171F    	   999: 	CMP.L	#LSTROM,A1
00:0001125C 65000008        	  1000: 	BCS	RA1
00:00011260 43F90001095E    	  1001: 	LEA	START,A1	wrap around if end of program
00:00011266 2019            	  1002: RA1	MOVE.L	(A1)+,D0	get the slightly random number
00:00011268 0880001F        	  1003: 	BCLR	#31,D0		make sure it's positive
00:0001126C 23C900006122    	  1004: 	MOVE.L	A1,RANPNT	(even I can do better than this!)
00:00011272 6100FF7A        	  1005: 	BSR	DIV32		RND(n)=MOD(number,n)+1
00:00011276 2001            	  1006: 	MOVE.L	D1,D0		MOD is the remainder of the div.
00:00011278 5280            	  1007: 	ADDQ.L	#1,D0
00:0001127A 4E75            	  1008: 	RTS
