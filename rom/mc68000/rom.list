00:00010F04 6100002A        	   651: 	BSR	GBYTE		get first byte of line no.
00:00010F08 10C1            	   652: 	MOVE.B	D1,(A0)+	store it
00:00010F0A 61000024        	   653: 	BSR	GBYTE		get 2nd bye of line no.
