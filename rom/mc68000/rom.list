00:00011042 2F00            	   812: 	MOVE.L	D0,-(SP)
00:00011044 2F01            	   813: 	MOVE.L	D1,-(SP)
00:00011046 61000008        	   814: 	BSR	EXPR2		do second <EXPR2>
00:0001104A 221F            	   815: 	MOVE.L	(SP)+,D1
