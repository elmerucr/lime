00:00002E52 B03C002B        	  6261: 	CMP.b		#'+',d0			* or is it +ve number
00:00002E56 6708            	  6262: 	BEQ.s		LAB_2X03			* branch if so
                            	  6263: 
00:00002E58 B03C00B1        	  6264: 	CMP.b		#TK_PLUS,d0			* or is it +ve number
00:00002E5C 6600DBE4        	  6265: 	BNE		LAB_SNER			* wasn't - + TK_MINUS TK_PLUS or # so do error
                            	  6266: 
                            	  6267: LAB_2X03
00:00002E60 6100E788        	  6268: 	BSR		LAB_IGBY			* get next character
00:00002E64 6436            	  6269: 	BCC.s		LAB_2Y01			* if not digit all done, go evaluate
                            	  6270: LAB_2X04
00:00002E66 C8FC000A        	  6271: 	MULU		#10,d4			* multiply decimal exponent by 10
00:00002E6A C0BC000000FF    	  6272: 	AND.l		#$FF,d0			* mask character
00:00002E70 903C0030        	  6273: 	SUB.b		#'0',d0			* convert to value
00:00002E74 D880            	  6274: 	ADD.l		d0,d4				* add to decimal exponent
00:00002E76 B83C0030        	  6275: 	CMP.b		#48,d4			* compare with decimal exponent limit+10
00:00002E7A 6FE4            	  6276: 	BLE.s		LAB_2X03			* loop if no overflow/underflow
                            	  6277: 
                            	  6278: LAB_2X05
                            	  6279: 							* exponent value has overflowed
00:00002E7C 6100E76C        	  6280: 	BSR		LAB_IGBY			* get next character
00:00002E80 65FA            	  6281: 	BCS.s		LAB_2X05			* loop while numeric digit
                            	  6282: 
00:00002E82 6018            	  6283: 	BRA.s		LAB_2Y01			* all done, go evaluate
                            	  6284: 
                            	  6285: LAB_2902
00:00002E84 B03C002E        	  6286: 	CMP.b		#'.',d0			* else compare with '.'
00:00002E88 6704            	  6287: 	BEQ.s		LAB_2904			* branch if was '.'
                            	  6288: 
00:00002E8A 60A6            	  6289: 	BRA.s		LAB_2901			* branch if not '.' (go check/do 'E')
                            	  6290: 
