00:00002864 5948            	  5486: 	SUBQ.w	#4,a0				* do table entry again
00:00002866 5384            	  5487: 	SUBQ.l	#1,d4				* do shift count again
00:00002868 7A12            	  5488: 	moveq		#18,d5			* 19 loops
00:0000286A 6126            	  5489: 	BSR.s		LAB_EXCC			* do loops 13 (again) through 31
                            	  5490: 
