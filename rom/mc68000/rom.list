00:0001107E 610004E8        	   834: XP25	BSR	TSTC		subtract?
00:00011082 2D              	   835: 	DC.B	'-',XP42-*
00:00011083 7D
00:00011084 2F00            	   836: XP26	MOVE.L	D0,-(SP)	yes, save the result of 1st <EXPR3>
00:00011086 6100000A        	   837: 	BSR	EXPR3		get second <EXPR3>
