00:00002D46 D080            	  6100: 	ADD.l		d0,d0				* shift highest bit of number ..
00:00002D48 D582            	  6101: 	ADDX.l	d2,d2				* .. into remainder .. never overflows
00:00002D4A D281            	  6102: 	ADD.l		d1,d1				* root = root * 2 .. never overflows
                            	  6103: LAB_SQE2
