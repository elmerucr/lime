                            	  1425: *
                            	  1426: * ===== Convert the line of text in the input buffer to upper
                            	  1427: *	case (except for stuff between quotes).
                            	  1428: *
00:000115FE 41F900006152    	  1429: TOUPBUF LEA	BUFFER,A0	set up text pointer
00:00011604 4201            	  1430: 	CLR.B	D1		clear quote flag
00:00011606 1018            	  1431: TOUPB1	MOVE.B	(A0)+,D0	get the next text char.
00:00011608 B03C000A        	  1432: 	CMP.B	#LF,D0		is it end of line?
00:0001160C 67000024        	  1433: 	BEQ	TOUPBRT 	if so, return
00:00011610 B03C0022        	  1434: 	CMP.B	#'"',D0         a double quote?
00:00011614 6700001E        	  1435: 	BEQ	DOQUO
00:00011618 B03C0027        	  1436: 	CMP.B	#'''',D0        or a single quote?
00:0001161C 67000016        	  1437: 	BEQ	DOQUO
00:00011620 4A01            	  1438: 	TST.B	D1		inside quotes?
00:00011622 6600FFE2        	  1439: 	BNE	TOUPB1		if so, do the next one
00:00011626 61000024        	  1440: 	BSR	TOUPPER 	convert to upper case
00:0001162A 1100            	  1441: 	MOVE.B	D0,-(A0)	store it
00:0001162C 5288            	  1442: 	ADDQ.L	#1,A0
00:0001162E 6000FFD6        	  1443: 	BRA	TOUPB1		and go back for more
00:00011632 4E75            	  1444: TOUPBRT RTS
                            	  1445: 
00:00011634 4A01            	  1446: DOQUO	TST.B	D1		are we inside quotes?
00:00011636 66000008        	  1447: 	BNE	DOQUO1
00:0001163A 1200            	  1448: 	MOVE.B	D0,D1		if not, toggle inside-quotes flag
00:0001163C 6000FFC8        	  1449: 	BRA	TOUPB1
00:00011640 B200            	  1450: DOQUO1	CMP.B	D0,D1		make sure we're ending proper quote
00:00011642 6600FFC2        	  1451: 	BNE	TOUPB1		if not, ignore it
00:00011646 4201            	  1452: 	CLR.B	D1		else clear quote flag
00:00011648 6000FFBC        	  1453: 	BRA	TOUPB1
                            	  1454: 
                            	  1455: *
                            	  1456: * ===== Convert the character in D0 to upper case
                            	  1457: *
00:0001164C B03C0061        	  1458: TOUPPER CMP.B	#'a',D0         is it < 'a'?
00:00011650 6500000E        	  1459: 	BCS	TOUPRET
00:00011654 B03C007A        	  1460: 	CMP.B	#'z',D0         or > 'z'?
00:00011658 62000006        	  1461: 	BHI	TOUPRET
00:0001165C 903C0020        	  1462: 	SUB.B	#32,D0		if not, make it upper case
00:00011660 4E75            	  1463: TOUPRET RTS
                            	  1464: 
                            	  1465: *
                            	  1466: * 'CHKIO' checks the input. If there's no input, it will return
                            	  1467: * to the caller with the Z flag set. If there is input, the Z
                            	  1468: * flag is cleared and the input byte is in D0. However, if a
                            	  1469: * control-C is read, 'CHKIO' will warm-start BASIC and will not
                            	  1470: * return to the caller.
                            	  1471: *
00:00011662 6100F2EE        	  1472: CHKIO	BSR	GOIN		get input if possible
00:00011666 6700000E        	  1473: 	BEQ	CHKRET		if Zero, no input
00:0001166A B03C0003        	  1474: 	CMP.B	#CTRLC,D0	is it control-C?
00:0001166E 66000006        	  1475: 	BNE	CHKRET		if not
00:00011672 6000F32A        	  1476: 	BRA	WSTART		if so, do a warm start
00:00011676 4E75            	  1477: CHKRET	RTS
