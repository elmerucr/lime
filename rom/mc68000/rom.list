00:00011079 07
00:0001107A 4280            	   821: 	CLR.L	D0		yes, fake '0-'
00:0001107C 6000002A        	   822: 	BRA	XP26
00:00011080 6100050A        	   823: XP21	BSR	TSTC		positive sign? ignore it
00:00011084 2B              	   824: 	DC.B	'+',XP22-*
00:00011085 01
00:00011086 6100002E        	   825: XP22	BSR	EXPR3		first <EXPR3>
00:0001108A 61000500        	   826: XP23	BSR	TSTC		add?
00:0001108E 2B              	   827: 	DC.B	'+',XP25-*
00:0001108F 13
00:00011090 2F00            	   828: 	MOVE.L	D0,-(SP)	yes, save the value
00:00011092 61000022        	   829: 	BSR	EXPR3		get the second <EXPR3>
00:00011096 221F            	   830: XP24	MOVE.L	(SP)+,D1
00:00011098 D081            	   831: 	ADD.L	D1,D0		add it to the first <EXPR3>
00:0001109A 69000278        	   832: 	BVS	QHOW		branch if there's an overflow
00:0001109E 6000FFEA        	   833: 	BRA	XP23		else go back for more operations
00:000110A2 610004E8        	   834: XP25	BSR	TSTC		subtract?
00:000110A6 2D              	   835: 	DC.B	'-',XP42-*
00:000110A7 7D
00:000110A8 2F00            	   836: XP26	MOVE.L	D0,-(SP)	yes, save the result of 1st <EXPR3>
00:000110AA 6100000A        	   837: 	BSR	EXPR3		get second <EXPR3>
00:000110AE 4480            	   838: 	NEG.L	D0		change its sign
00:000110B0 4EF900011096    	   839: 	JMP	XP24		and do an addition
                            	   840: 
00:000110B6 61000030        	   841: EXPR3	BSR	EXPR4		get first <EXPR4>
00:000110BA 610004D0        	   842: XP31	BSR	TSTC		multiply?
