00:000111FA D180            	   965: 	ADDX.L	D0,D0		the divide routine in Ron Cain's
00:000111FC 6700000C        	   966: 	BEQ	DIV4		Small-C run time library.)
00:00011200 B082            	   967: 	CMP.L	D2,D0
00:00011202 6B000006        	   968: 	BMI	DIV4
00:00011206 5281            	   969: 	ADDQ.L	#1,D1
00:00011208 9082            	   970: 	SUB.L	D2,D0
00:0001120A 51CBFFEC        	   971: DIV4	DBRA	D3,DIV3
