                            	  5455: LAB_ESML
00:000028A2 277CB17217F80598	  5456: 	move.l	#$B17217F8,FAC2_m(a3)	* LOG(2) mantissa
00:000028AA 377C8000059C    	  5457: 	MOVE.w	#$8000,FAC2_e(a3)		* LOG(2) exponent & sign
00:000028B0 177C0000059E    	  5458: 	move.b	#0,FAC_sc(a3)		* clear sign compare
00:000028B6 6100F9B4        	  5459: 	BSR		LAB_MULTIPLY		* multiply by log(2)
                            	  5460: 
00:000028BA 202B0590        	  5461: 	move.l	FAC1_m(a3),d0		* get mantissa
00:000028BE 1A2B0594        	  5462: 	move.b	FAC1_e(a3),d5		* get exponent
00:000028C2 9A7C0082        	  5463: 	SUB.w		#$82,d5			* normalise and -2 (result is -1 to -30)
00:000028C6 4445            	  5464: 	NEG.w		d5				* make +ve
00:000028C8 EAA8            	  5465: 	LSR.l		d5,d0				* shift for 2 integer bits
                            	  5466: 
                            	  5467: * d0 = arg
                            	  5468: * d6 = x, d1 = y
                            	  5469: * d2 = x1, d3 = y1
                            	  5470: * d4 = shift count
                            	  5471: * d5 = loop count
                            	  5472: 							* now do cordic set-up
00:000028CA 7200            	  5473: 	moveq		#0,d1				* y = 0
00:000028CC 2C3CE6A3D110    	  5474: 	move.l	#KFCTSEED,d6		* x = 1 with jkh inverse factored out
00:000028D2 41FA09FC        	  5475: 	lea		(TAB_HTHET,PC),a0		* get pointer to hyperbolic arctan table
00:000028D6 7800            	  5476: 	moveq		#0,d4				* clear shift count
                            	  5477: 
