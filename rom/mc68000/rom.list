                            	  6359: 
                            	  6360: LAB_CHEX
00:00002E8E 177C004005B5    	  6361: 	move.b	#$40,Dtypef(a3)		* set integer numeric data type
00:00002E94 7620            	  6362: 	moveq		#32,d3			* set up max binary exponent
                            	  6363: LAB_CHXX
00:00002E96 6100E6D2        	  6364: 	BSR		LAB_IGBY			* increment & scan memory
00:00002E9A 6514            	  6365: 	BCS.s		LAB_ISHN			* branch if numeric character
                            	  6366: 
00:00002E9C 803C0020        	  6367: 	OR.b		#$20,d0			* case convert, allow "A" to "F" and "a" to "f"
00:00002EA0 903C0061        	  6368: 	SUB.b		#'a',d0			* subtract "a"
00:00002EA4 652A            	  6369: 	BCS.s		LAB_CHX3			* exit if <"a"
                            	  6370: 
00:00002EA6 B03C0006        	  6371: 	CMP.b		#$06,d0			* compare normalised with $06 (max+1)
00:00002EAA 6424            	  6372: 	BCC.s		LAB_CHX3			* exit if >"f"
                            	  6373: 
00:00002EAC D03C003A        	  6374: 	ADD.b		#$3A,d0			* convert to nibble+"0"
                            	  6375: LAB_ISHN
00:00002EB0 616C            	  6376: 	BSR.s		d1x16				* multiply d1 by 16 and add character
00:00002EB2 64E2            	  6377: 	BCC.s		LAB_CHXX			* loop for more if no overflow
                            	  6378: 
                            	  6379: 							* overflowed mantissa, count 16s exponent
                            	  6380: LAB_CHX1
00:00002EB4 5883            	  6381: 	ADDQ.l	#4,d3				* increment mantissa exponent count
00:00002EB6 6900DAFA        	  6382: 	BVS		LAB_OFER			* do overflow error if overflowed
                            	  6383: 
00:00002EBA 6100E6AE        	  6384: 	BSR		LAB_IGBY			* get next character
00:00002EBE 65F4            	  6385: 	BCS.s		LAB_CHX1			* loop while numeric character
                            	  6386: 
00:00002EC0 803C0020        	  6387: 	OR.b		#$20,d0			* case convert, allow "A" to "F" and "a" to "f"
00:00002EC4 903C0061        	  6388: 	SUB.b		#'a',d0			* subtract "a"
00:00002EC8 6506            	  6389: 	BCS.s		LAB_CHX3			* exit if <"a"
                            	  6390: 
00:00002ECA B03C0006        	  6391: 	CMP.b		#$06,d0			* compare normalised with $06 (max+1)
00:00002ECE 65E4            	  6392: 	BCS.s		LAB_CHX1			* loop if <="f"
                            	  6393: 
                            	  6394: 							* now return value
                            	  6395: LAB_CHX3
00:00002ED0 4A81            	  6396: 	TST.l		d1				* test mantissa
00:00002ED2 67AA            	  6397: 	BEQ.s		LAB_rtn0			* if mantissa=0 return 0
                            	  6398: 
00:00002ED4 6B08            	  6399: 	BMI.s		LAB_exxf			* branch if already mormalised
                            	  6400: 
