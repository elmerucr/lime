00:00010B68 C602            	   235: 	AND.B	D2,D3		and a match.
00:00010B6A B63C002E        	   236: 	CMP.B	#'.',D3
00:00010B6E 67000024        	   237: 	BEQ	EXGO		if so, execute
00:00010B72 C23C007F        	   238: 	AND.B	#$7F,D1 	ignore the table's high bit
