00:0001160A 66000008        	  1420: 	BNE	IGBRET		if so, swallow it
00:0001160E 5288            	  1421: IGB1	ADDQ.L	#1,A0		increment the text pointer
00:00011610 6000FFF4        	  1422: 	BRA	IGNBLK
00:00011614 4E75            	  1423: IGBRET	RTS
