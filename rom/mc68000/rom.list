00:0001126E 20390000614E    	  1023: SIZE	MOVE.L	VARBGN,D0	get the number of free bytes...
00:00011274 90B90000614A    	  1024: 	SUB.L	TXTUNF,D0	between 'TXTUNF' and 'VARBGN'
