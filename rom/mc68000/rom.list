                            	   323: *
                            	   324: *******************************************************************
                            	   325: *
                            	   326: * *** LIST *** PRINT ***
                            	   327: *
                            	   328: * LIST has two forms:
                            	   329: * 'LIST<CR>' lists all saved lines
                            	   330: * 'LIST #<CR>' starts listing at the line #
                            	   331: * Control-S pauses the listing, control-C stops it.
                            	   332: *
                            	   333: * PRINT command is 'PRINT ....:' or 'PRINT ....<CR>'
                            	   334: * where '....' is a list of expressions, formats, back-arrows,
                            	   335: * and strings.	These items a separated by commas.
                            	   336: *
                            	   337: * A format is a pound sign followed by a number.  It controls
                            	   338: * the number of spaces the value of an expression is going to
                            	   339: * be printed in.  It stays effective for the rest of the print
                            	   340: * command unless changed by another format.  If no format is
                            	   341: * specified, 11 positions will be used.
                            	   342: *
                            	   343: * A string is quoted in a pair of single- or double-quotes.
                            	   344: *
                            	   345: * An underline (back-arrow) means generate a <CR> without a <LF>
                            	   346: *
                            	   347: * A <CR LF> is generated after the entire list has been printed
                            	   348: * or if the list is empty.  If the list ends with a semicolon,
                            	   349: * however, no <CR LF> is generated.
                            	   350: *
                            	   351: 
00:00010C2C 61000998        	   352: LIST	BSR	TSTNUM		see if there's a line no.
00:00010C30 610006A0        	   353: 	BSR	ENDCHK		if not, we get a zero
00:00010C34 610007C0        	   354: 	BSR	FNDLN		find this or next line
00:00010C38 6500FD7A        	   355: LS1	BCS	WSTART		warm start if we passed the end
00:00010C3C 61000950        	   356: 	BSR	PRTLN		print the line
00:00010C40 61000A36        	   357: 	BSR	CHKIO		check for listing halt request
00:00010C44 67000012        	   358: 	BEQ	LS3
00:00010C48 B03C0013        	   359: 	CMP.B	#CTRLS,D0	pause the listing?
00:00010C4C 6600000A        	   360: 	BNE	LS3
00:00010C50 61000A26        	   361: LS2	BSR	CHKIO		if so, wait for another keypress
00:00010C54 6700FFFA        	   362: 	BEQ	LS2
00:00010C58 610007AC        	   363: LS3	BSR	FNDLNP		find the next line
00:00010C5C 6000FFDA        	   364: 	BRA	LS1
                            	   365: 
00:00010C60 383C000B        	   366: PRINT	MOVE	#11,D4		D4 = number of print spaces
00:00010C64 61000944        	   367: 	BSR	TSTC		if null list and ":"
00:00010C68 3A              	   368: 	DC.B	':',PR2-*
00:00010C69 09
00:00010C6A 61000A22        	   369: 	BSR	CRLF		give CR-LF and continue
00:00010C6E 6000FF92        	   370: 	BRA	RUNSML		execution on the same line
00:00010C72 61000936        	   371: PR2	BSR	TSTC		if null list and <CR>
00:00010C76 0D              	   372: 	DC.B	CR,PR0-*
00:00010C77 09
00:00010C78 61000A14        	   373: 	BSR	CRLF		also give CR-LF and
00:00010C7C 6000FF64        	   374: 	BRA	RUNNXL		execute the next line
00:00010C80 61000928        	   375: PR0	BSR	TSTC		else is it a format?
00:00010C84 23              	   376: 	DC.B	'#',PR1-*
00:00010C85 0B
00:00010C86 6100038A        	   377: 	BSR	EXPR		yes, evaluate expression
00:00010C8A 3800            	   378: 	MOVE	D0,D4		and save it as print width
00:00010C8C 6000001A        	   379: 	BRA	PR3		look for more to print
00:00010C90 61000918        	   380: PR1	BSR	TSTC		is character expression? (MRL)
00:00010C94 24              	   381: 	DC.B	'$',PR4-*
00:00010C95 0D
00:00010C96 6100037A        	   382: 	BSR	EXPR		yep. Evaluate expression (MRL)
00:00010C9A 6100FCC8        	   383: 	BSR	GOOUT		print low byte (MRL)
00:00010C9E 60000008        	   384: 	BRA	PR3		look for more. (MRL)
00:00010CA2 61000822        	   385: PR4	BSR	QTSTG		is it a string?
00:00010CA6 6016            	   386: 	BRA.S	PR8		if not, must be an expression
00:00010CA8 61000900        	   387: PR3	BSR	TSTC		if ",", go find next
00:00010CAC 2C              	   388: 	DC.B	',',PR6-*
00:00010CAD 09
00:00010CAE 61000608        	   389: 	BSR	FIN		in the list.
00:00010CB2 6000FFCC        	   390: 	BRA	PR0
00:00010CB6 610009D6        	   391: PR6	BSR	CRLF		list ends here
00:00010CBA 60000014        	   392: 	BRA	FINISH
00:00010CBE 3F04            	   393: PR8	MOVE	D4,-(SP)	save the width value
00:00010CC0 61000350        	   394: 	BSR	EXPR		evaluate the expression
00:00010CC4 381F            	   395: 	MOVE	(SP)+,D4	restore the width
00:00010CC6 2200            	   396: 	MOVE.L	D0,D1
00:00010CC8 61000840        	   397: 	BSR	PRTNUM		print its value
00:00010CCC 6000FFDA        	   398: 	BRA	PR3		more to print?
                            	   399: 
