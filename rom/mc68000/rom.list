00:00002CDC 5281            	  6115: 	ADDQ.l	#1,d1				* increment root
                            	  6116: LAB_SQNS
00:00002CDE 51CBFFE6        	  6117: 	DBF		d3,LAB_SQE1			* loop if not all done
                            	  6118: 
