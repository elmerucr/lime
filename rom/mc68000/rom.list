00:000105F6 65000022        	   569: 	blo	.2			; no
                            	   570: 
00:000105FA 06410080        	   571: .lf	addi.w	#TERMINAL_HPITCH,D1	; yes, move cursor one line down, followed by carriage return
00:000105FE 0241FF80        	   572: .cr	andi.w	#%1111111110000000,D1	; cursor to beginning of line (carriage return)
                            	   573: 
00:00010602 B27C0A00        	   574: .1	cmp.w	#(TERMINAL_HPITCH*TERMINAL_HEIGHT),D1	; check for cursor out of screen
00:00010606 65000012        	   575: 	blo	.2			; no
                            	   576: 
