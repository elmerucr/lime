                            	     7: ;-----------------------------------------------------------------------
                            	     8: ; Calling convention:
                            	     9: ; - D0-D1/A0-A1 are scratch registers, and need to be caller saved
                            	    10: ;   when to be kept
                            	    11: ; - Calling a trap is an exception, but otherwise works the same as
                            	    12: ;   a conventional function / routine (scratch registers)
                            	    13: ; - Other (real) exceptions will save and restore all registers
                            	    14: ;
                            	    15: ; - Tab size: 8
                            	    16: ;
                            	    17: ;-----------------------------------------------------------------------
                            	    18: ; rom v0.10
                            	    19: ; adjusted (again) for 320x180 resolution
                            	    20: ;
                            	    21: ; rom v0.9
                            	    22: ; adjusted for 320x176 screen resolution
