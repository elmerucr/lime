                            	   629: *
                            	   630: *******************************************************************
                            	   631: *
                            	   632: * *** LOAD *** & SAVE ***
                            	   633: *
                            	   634: * These two commands transfer a program to/from an auxiliary
                            	   635: * device such as a cassette, another computer, etc.  The program
                            	   636: * is converted to an easily-stored format: each line starts with
                            	   637: * a colon, the line no. as 4 hex digits, and the rest of the line.
                            	   638: * At the end, a line starting with an '@' sign is sent.  This
                            	   639: * format can be read back with a minimum of processing time by
                            	   640: * the 68000.
                            	   641: *
00:00010E9A 207900010936    	   642: LOAD	MOVE.L	TXTBGN,A0	set pointer to start of prog. area
00:00010EA0 103C000D        	   643: 	MOVE.B	#CR,D0		For a CP/M host, tell it we're ready...
00:00010EA4 6100FA84        	   644: 	BSR	GOAUXO		by sending a CR to finish PIP command.
00:00010EA8 6100FA84        	   645: LOD1	BSR	GOAUXI		look for start of line
00:00010EAC 6700FFFA        	   646: 	BEQ	LOD1
00:00010EB0 B03C0040        	   647: 	CMP.B	#'@',D0         end of program?
00:00010EB4 6700002C        	   648: 	BEQ	LODEND
00:00010EB8 B03C003A        	   649: 	CMP.B	#':',D0         if not, is it start of line?
00:00010EBC 6600FFEA        	   650: 	BNE	LOD1		if not, wait for it
00:00010EC0 6100002A        	   651: 	BSR	GBYTE		get first byte of line no.
00:00010EC4 10C1            	   652: 	MOVE.B	D1,(A0)+	store it
00:00010EC6 61000024        	   653: 	BSR	GBYTE		get 2nd bye of line no.
00:00010ECA 10C1            	   654: 	MOVE.B	D1,(A0)+	store that, too
00:00010ECC 6100FA60        	   655: LOD2	BSR	GOAUXI		get another text char.
00:00010ED0 6700FFFA        	   656: 	BEQ	LOD2
00:00010ED4 10C0            	   657: 	MOVE.B	D0,(A0)+	store it
00:00010ED6 B03C000D        	   658: 	CMP.B	#CR,D0		is it the end of the line?
00:00010EDA 6600FFF0        	   659: 	BNE	LOD2		if not, go back for more
00:00010EDE 6000FFC8        	   660: 	BRA	LOD1		if so, start a new line
