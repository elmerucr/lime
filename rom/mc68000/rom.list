00:00002F1E 2401            	  6449: 	move.l	d1,d2				* copy value
00:00002F20 D482            	  6450: 	ADD.l		d2,d2				* times two
00:00002F22 65CA            	  6451: 	BCS.s		RTS_024			* return if overflow
                            	  6452: 
00:00002F24 D482            	  6453: 	ADD.l		d2,d2				* times four
00:00002F26 65C6            	  6454: 	BCS.s		RTS_024			* return if overflow
                            	  6455: 
00:00002F28 D482            	  6456: 	ADD.l		d2,d2				* times eight
