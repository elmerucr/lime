                            	  1207: *******************************************************************
                            	  1208: *
                            	  1209: * *** MVUP *** MVDOWN *** POPA *** PUSHA ***
                            	  1210: *
                            	  1211: * 'MVUP' moves a block up from where A1 points to where A2 points
                            	  1212: * until A1=A3
                            	  1213: *
                            	  1214: * 'MVDOWN' moves a block down from where A1 points to where A3
                            	  1215: * points until A1=A2
                            	  1216: *
                            	  1217: * 'POPA' restores the 'FOR' loop variable save area from the stack
                            	  1218: *
                            	  1219: * 'PUSHA' stacks for 'FOR' loop variable save area onto the stack
                            	  1220: *
00:0001141C B7C9            	  1221: MVUP	CMP.L	A1,A3		see the above description
00:0001141E 67000008        	  1222: 	BEQ	MVRET
00:00011422 14D9            	  1223: 	MOVE.B	(A1)+,(A2)+
00:00011424 6000FFF6        	  1224: 	BRA	MVUP
00:00011428 4E75            	  1225: MVRET	RTS
                            	  1226: 
00:0001142A B5C9            	  1227: MVDOWN	CMP.L	A1,A2		see the above description
00:0001142C 6700FFFA        	  1228: 	BEQ	MVRET
00:00011430 1721            	  1229: 	MOVE.B	-(A1),-(A3)
00:00011432 6000FFF6        	  1230: 	BRA	MVDOWN
                            	  1231: 
00:00011436 2C5F            	  1232: POPA	MOVE.L	(SP)+,A6	A6 = return address
00:00011438 23DF00006132    	  1233: 	MOVE.L	(SP)+,LOPVAR	restore LOPVAR, but zero means no more
00:0001143E 6700001A        	  1234: 	BEQ	PP1
00:00011442 23DF00006136    	  1235: 	MOVE.L	(SP)+,LOPINC	if not zero, restore the rest
00:00011448 23DF0000613A    	  1236: 	MOVE.L	(SP)+,LOPLMT
00:0001144E 23DF0000613E    	  1237: 	MOVE.L	(SP)+,LOPLN
00:00011454 23DF00006142    	  1238: 	MOVE.L	(SP)+,LOPPT
00:0001145A 4ED6            	  1239: PP1	JMP	(A6)		return
                            	  1240: 
00:0001145C 22390000614E    	  1241: PUSHA	MOVE.L	STKLMT,D1	Are we running out of stack room?
00:00011462 928F            	  1242: 	SUB.L	SP,D1
00:00011464 6400FEAA        	  1243: 	BCC	QSORRY		if so, say we're sorry
00:00011468 2C5F            	  1244: 	MOVE.L	(SP)+,A6	else get the return address
00:0001146A 223900006132    	  1245: 	MOVE.L	LOPVAR,D1	save loop variables
00:00011470 6700001A        	  1246: 	BEQ	PU1		if LOPVAR is zero, that's all
00:00011474 2F3900006142    	  1247: 	MOVE.L	LOPPT,-(SP)	else save all the others
00:0001147A 2F390000613E    	  1248: 	MOVE.L	LOPLN,-(SP)
00:00011480 2F390000613A    	  1249: 	MOVE.L	LOPLMT,-(SP)
00:00011486 2F3900006136    	  1250: 	MOVE.L	LOPINC,-(SP)
00:0001148C 2F01            	  1251: PU1	MOVE.L	D1,-(SP)
00:0001148E 4ED6            	  1252: 	JMP	(A6)		return
