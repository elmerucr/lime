                            	   532: *
                            	   533: *******************************************************************
                            	   534: *
                            	   535: * *** REM *** IF *** INPUT *** LET (& DEFLT) ***
                            	   536: *
                            	   537: * 'REM' can be followed by anything and is ignored by the
                            	   538: * interpreter.
                            	   539: *
                            	   540: * 'IF' is followed by an expression, as a condition and one or
                            	   541: * more commands (including other 'IF's) separated by colons.
                            	   542: * Note that the word 'THEN' is not used.  The interpreter evaluates
                            	   543: * the expression.  If it is non-zero, execution continues.  If it
                            	   544: * is zero, the commands that follow are ignored and execution
                            	   545: * continues on the next line.
                            	   546: *
                            	   547: * 'INPUT' is like the 'PRINT' command, and is followed by a list
                            	   548: * of items.  If the item is a string in single or double quotes,
                            	   549: * or is an underline (back arrow), it has the same effect as in
                            	   550: * 'PRINT'.  If an item is a variable, this variable name is
                            	   551: * printed out followed by a colon, then the interpreter waits for
                            	   552: * an expression to be typed in.  The variable is then set to the
                            	   553: * value of this expression.  If the variable is preceeded by a
                            	   554: * string (again in single or double quotes), the string will be
                            	   555: * displayed followed by a colon.  The interpreter the waits for an
                            	   556: * expression to be entered and sets the variable equal to the
                            	   557: * expression's value.  If the input expression is invalid, the
                            	   558: * interpreter will print "What?", "How?", or "Sorry" and reprint
                            	   559: * the prompt and redo the input.  The execution will not terminate
                            	   560: * unless you press control-C.  This is handled in 'INPERR'.
                            	   561: *
                            	   562: * 'LET' is followed by a list of items separated by commas.
                            	   563: * Each item consists of a variable, an equals sign, and an
                            	   564: * expression.  The interpreter evaluates the expression and sets
                            	   565: * the variable to that value.  The interpreter will also handle
                            	   566: * 'LET' commands without the word 'LET'.  This is done by 'DEFLT'.
                            	   567: *
00:00010DFE 6000000C        	   568: REM	BRA	IF2		skip the rest of the line
                            	   569: 
00:00010E02 610001F0        	   570: IF	BSR	EXPR		evaluate the expression
00:00010E06 4A80            	   571: IF1	TST.L	D0		is it zero?
00:00010E08 6600FDDA        	   572: 	BNE	RUNSML		if not, continue
00:00010E0C 2248            	   573: IF2	MOVE.L	A0,A1
00:00010E0E 4281            	   574: 	CLR.L	D1
00:00010E10 610005F6        	   575: 	BSR	FNDSKP		if so, skip the rest of the line
00:00010E14 6400FDC4        	   576: 	BCC	RUNTSL		and run the next line
00:00010E18 6000FB7C        	   577: 	BRA	WSTART		if no next line, do a warm start
                            	   578: 
00:00010E1C 2E7900006132    	   579: INPERR	MOVE.L	STKINP,SP	restore the old stack pointer
00:00010E22 23DF0000612A    	   580: 	MOVE.L	(SP)+,CURRNT	and old 'CURRNT'
00:00010E28 588F            	   581: 	ADDQ.L	#4,SP
00:00010E2A 205F            	   582: 	MOVE.L	(SP)+,A0	and old text pointer
                            	   583: 
00:00010E2C 2F08            	   584: INPUT	MOVE.L	A0,-(SP)	save in case of error
00:00010E2E 61000678        	   585: 	BSR	QTSTG		is next item a string?
00:00010E32 600E            	   586: 	BRA.S	IP2		nope
00:00010E34 610002F4        	   587: 	BSR	TSTV		yes, but is it followed by a variable?
00:00010E38 6500005A        	   588: 	BCS	IP4		if not, branch
00:00010E3C 2440            	   589: 	MOVE.L	D0,A2		put away the variable's address
00:00010E3E 6000001C        	   590: 	BRA	IP3		if so, input to variable
00:00010E42 2F08            	   591: IP2	MOVE.L	A0,-(SP)	save for 'PRTSTG'
00:00010E44 610002E4        	   592: 	BSR	TSTV		must be a variable now
00:00010E48 65000478        	   593: 	BCS	QWHAT		"What?" it isn't?
00:00010E4C 2440            	   594: 	MOVE.L	D0,A2		put away the variable's address
00:00010E4E 1410            	   595: 	MOVE.B	(A0),D2 	get ready for 'PRTSTG'
00:00010E50 4200            	   596: 	CLR.B	D0
00:00010E52 1080            	   597: 	MOVE.B	D0,(A0)
00:00010E54 225F            	   598: 	MOVE.L	(SP)+,A1
00:00010E56 61000630        	   599: 	BSR	PRTSTG		print string as prompt
00:00010E5A 1082            	   600: 	MOVE.B	D2,(A0) 	restore text
00:00010E5C 2F08            	   601: IP3	MOVE.L	A0,-(SP)	save in case of error
00:00010E5E 2F390000612A    	   602: 	MOVE.L	CURRNT,-(SP)	also save 'CURRNT'
00:00010E64 23FCFFFFFFFF0000	   603: 	MOVE.L	#-1,CURRNT	flag that we are in INPUT
00:00010E6C 612A
00:00010E6E 23CF00006132    	   604: 	MOVE.L	SP,STKINP	save the stack pointer too
00:00010E74 2F0A            	   605: 	MOVE.L	A2,-(SP)	save the variable address
00:00010E76 103C003A        	   606: 	MOVE.B	#':',D0         print a colon first
00:00010E7A 610004A4        	   607: 	BSR	GETLN		then get an input line
00:00010E7E 41F900006156    	   608: 	LEA	BUFFER,A0	point to the buffer
00:00010E84 6100016E        	   609: 	BSR	EXPR		evaluate the input
00:00010E88 245F            	   610: 	MOVE.L	(SP)+,A2	restore the variable address
00:00010E8A 2480            	   611: 	MOVE.L	D0,(A2) 	save value in variable
00:00010E8C 23DF0000612A    	   612: 	MOVE.L	(SP)+,CURRNT	restore old 'CURRNT'
00:00010E92 205F            	   613: 	MOVE.L	(SP)+,A0	and the old text pointer
00:00010E94 588F            	   614: IP4	ADDQ.L	#4,SP		clean up the stack
00:00010E96 610006F4        	   615: 	BSR	TSTC		is the next thing a comma?
00:00010E9A 2C              	   616: 	DC.B	',',IP5-*
00:00010E9B 05
00:00010E9C 6000FF8E        	   617: 	BRA	INPUT		yes, more items
00:00010EA0 6000FE10        	   618: IP5	BRA	FINISH
                            	   619: 
