                            	   718: *
                            	   719: *******************************************************************
                            	   720: *
                            	   721: * *** POKE *** & CALL ***
                            	   722: *
                            	   723: * 'POKE expr1,expr2' stores the byte from 'expr2' into the memory
                            	   724: * address specified by 'expr1'.
                            	   725: *
                            	   726: * 'CALL expr' jumps to the machine language subroutine whose
                            	   727: * starting address is specified by 'expr'.  The subroutine can use
                            	   728: * all registers but must leave the stack the way it found it.
                            	   729: * The subroutine returns to the interpreter by executing an RTS.
                            	   730: *
00:00010FE2 61000030        	   731: POKE	BSR	EXPR		get the memory address
00:00010FE6 610005C4        	   732: 	BSR	TSTC		it must be followed by a comma
00:00010FEA 2C              	   733: 	DC.B	',',PKER-*
00:00010FEB 0F
00:00010FEC 2F00            	   734: 	MOVE.L	D0,-(SP)	save the address
00:00010FEE 61000024        	   735: 	BSR	EXPR		get the byte to be POKE'd
00:00010FF2 225F            	   736: 	MOVE.L	(SP)+,A1	get the address back
00:00010FF4 1280            	   737: 	MOVE.B	D0,(A1) 	store the byte in memory
00:00010FF6 6000FCDA        	   738: 	BRA	FINISH
00:00010FFA 600002E6        	   739: PKER	BRA	QWHAT		if no comma, say "What?"
                            	   740: 
00:00010FFE 61000014        	   741: CALL	BSR	EXPR		get the subroutine's address
00:00011002 4A80            	   742: 	TST.L	D0		make sure we got a valid address
00:00011004 6700032E        	   743: 	BEQ	QHOW		if not, say "How?"
00:00011008 2F08            	   744: 	MOVE.L	A0,-(SP)	save the text pointer
00:0001100A 2240            	   745: 	MOVE.L	D0,A1
00:0001100C 4E91            	   746: 	JSR	(A1)		jump to the subroutine
00:0001100E 205F            	   747: 	MOVE.L	(SP)+,A0	restore the text pointer
00:00011010 6000FCC0        	   748: 	BRA	FINISH
                            	   749: *
                            	   750: *******************************************************************
                            	   751: *
                            	   752: * *** EXPR ***
                            	   753: *
                            	   754: * 'EXPR' evaluates arithmetical or logical expressions.
                            	   755: * <EXPR>::=<EXPR2>
                            	   756: *	   <EXPR2><rel.op.><EXPR2>
                            	   757: * where <rel.op.> is one of the operators in TAB8 and the result
                            	   758: * of these operations is 1 if true and 0 if false.
                            	   759: * <EXPR2>::=(+ or -)<EXPR3>(+ or -)<EXPR3>(...
                            	   760: * where () are optional and (... are optional repeats.
                            	   761: * <EXPR3>::=<EXPR4>( <* or /><EXPR4> )(...
                            	   762: * <EXPR4>::=<variable>
                            	   763: *	    <function>
                            	   764: *	    (<EXPR>)
                            	   765: * <EXPR> is recursive so that the variable '@' can have an <EXPR>
                            	   766: * as an index, functions can have an <EXPR> as arguments, and
                            	   767: * <EXPR4> can be an <EXPR> in parenthesis.
                            	   768: *
00:00011014 6100007E        	   769: EXPR	BSR	EXPR2
00:00011018 2F00            	   770: 	MOVE.L	D0,-(SP)	save <EXPR2> value
00:0001101A 43F900010AC9    	   771: 	LEA	TAB8,A1 	look up a relational operator
00:00011020 45F900010B48    	   772: 	LEA	TAB8.1,A2
00:00011026 6000FB48        	   773: 	BRA	EXEC		go do it
                            	   774: 
00:0001102A 61000056        	   775: XP11	BSR	XP18		is it ">="?
00:0001102E 6D000046        	   776: 	BLT	XPRT0		no, return D0=0
00:00011032 60000046        	   777: 	BRA	XPRT1		else return D0=1
                            	   778: 
00:00011036 6100004A        	   779: XP12	BSR	XP18		is it "<>"?
00:0001103A 6700003A        	   780: 	BEQ	XPRT0		no, return D0=0
00:0001103E 6000003A        	   781: 	BRA	XPRT1		else return D0=1
                            	   782: 
00:00011042 6100003E        	   783: XP13	BSR	XP18		is it ">"?
00:00011046 6F00002E        	   784: 	BLE	XPRT0		no, return D0=0
00:0001104A 6000002E        	   785: 	BRA	XPRT1		else return D0=1
                            	   786: 
00:0001104E 61000032        	   787: XP14	BSR	XP18		is it "<="?
00:00011052 6E000022        	   788: 	BGT	XPRT0		no, return D0=0
