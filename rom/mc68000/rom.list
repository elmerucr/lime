00:00011046 4E75            	   794: XP15RT	RTS
                            	   795: 
00:00011048 61000018        	   796: XP16	BSR	XP18		is it "<"?
00:0001104C 6C000008        	   797: 	BGE	XPRT0		if not, return D0=0
00:00011050 60000008        	   798: 	BRA	XPRT1		else return D0=1
00:00011054 4E75            	   799: XP16RT	RTS
                            	   800: 
00:00011056 4280            	   801: XPRT0	CLR.L	D0		return D0=0 (false)
00:00011058 4E75            	   802: 	RTS
                            	   803: 
00:0001105A 7001            	   804: XPRT1	MOVEQ	#1,D0		return D0=1 (true)
00:0001105C 4E75            	   805: 	RTS
