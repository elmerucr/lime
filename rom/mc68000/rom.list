                            	   532: *
                            	   533: *******************************************************************
                            	   534: *
                            	   535: * *** REM *** IF *** INPUT *** LET (& DEFLT) ***
                            	   536: *
                            	   537: * 'REM' can be followed by anything and is ignored by the
                            	   538: * interpreter.
                            	   539: *
                            	   540: * 'IF' is followed by an expression, as a condition and one or
                            	   541: * more commands (including other 'IF's) separated by colons.
                            	   542: * Note that the word 'THEN' is not used.  The interpreter evaluates
                            	   543: * the expression.  If it is non-zero, execution continues.  If it
                            	   544: * is zero, the commands that follow are ignored and execution
                            	   545: * continues on the next line.
                            	   546: *
                            	   547: * 'INPUT' is like the 'PRINT' command, and is followed by a list
                            	   548: * of items.  If the item is a string in single or double quotes,
                            	   549: * or is an underline (back arrow), it has the same effect as in
                            	   550: * 'PRINT'.  If an item is a variable, this variable name is
                            	   551: * printed out followed by a colon, then the interpreter waits for
                            	   552: * an expression to be typed in.  The variable is then set to the
                            	   553: * value of this expression.  If the variable is preceeded by a
                            	   554: * string (again in single or double quotes), the string will be
                            	   555: * displayed followed by a colon.  The interpreter the waits for an
                            	   556: * expression to be entered and sets the variable equal to the
                            	   557: * expression's value.  If the input expression is invalid, the
                            	   558: * interpreter will print "What?", "How?", or "Sorry" and reprint
                            	   559: * the prompt and redo the input.  The execution will not terminate
                            	   560: * unless you press control-C.  This is handled in 'INPERR'.
                            	   561: *
                            	   562: * 'LET' is followed by a list of items separated by commas.
                            	   563: * Each item consists of a variable, an equals sign, and an
                            	   564: * expression.  The interpreter evaluates the expression and sets
                            	   565: * the variable to that value.  The interpreter will also handle
                            	   566: * 'LET' commands without the word 'LET'.  This is done by 'DEFLT'.
                            	   567: *
00:00010E1E 6000000C        	   568: REM	BRA	IF2		skip the rest of the line
                            	   569: 
00:00010E22 610001F0        	   570: IF	BSR	EXPR		evaluate the expression
00:00010E26 4A80            	   571: IF1	TST.L	D0		is it zero?
00:00010E28 6600FDDA        	   572: 	BNE	RUNSML		if not, continue
00:00010E2C 2248            	   573: IF2	MOVE.L	A0,A1
00:00010E2E 4281            	   574: 	CLR.L	D1
00:00010E30 610005F6        	   575: 	BSR	FNDSKP		if so, skip the rest of the line
00:00010E34 6400FDC4        	   576: 	BCC	RUNTSL		and run the next line
00:00010E38 6000FB7C        	   577: 	BRA	WSTART		if no next line, do a warm start
                            	   578: 
00:00010E3C 2E790000612E    	   579: INPERR	MOVE.L	STKINP,SP	restore the old stack pointer
00:00010E42 23DF00006126    	   580: 	MOVE.L	(SP)+,CURRNT	and old 'CURRNT'
00:00010E48 588F            	   581: 	ADDQ.L	#4,SP
00:00010E4A 205F            	   582: 	MOVE.L	(SP)+,A0	and old text pointer
                            	   583: 
00:00010E4C 2F08            	   584: INPUT	MOVE.L	A0,-(SP)	save in case of error
00:00010E4E 61000678        	   585: 	BSR	QTSTG		is next item a string?
00:00010E52 600E            	   586: 	BRA.S	IP2		nope
00:00010E54 610002F4        	   587: 	BSR	TSTV		yes, but is it followed by a variable?
00:00010E58 6500005A        	   588: 	BCS	IP4		if not, branch
00:00010E5C 2440            	   589: 	MOVE.L	D0,A2		put away the variable's address
00:00010E5E 6000001C        	   590: 	BRA	IP3		if so, input to variable
00:00010E62 2F08            	   591: IP2	MOVE.L	A0,-(SP)	save for 'PRTSTG'
00:00010E64 610002E4        	   592: 	BSR	TSTV		must be a variable now
00:00010E68 65000478        	   593: 	BCS	QWHAT		"What?" it isn't?
00:00010E6C 2440            	   594: 	MOVE.L	D0,A2		put away the variable's address
00:00010E6E 1410            	   595: 	MOVE.B	(A0),D2 	get ready for 'PRTSTG'
00:00010E70 4200            	   596: 	CLR.B	D0
00:00010E72 1080            	   597: 	MOVE.B	D0,(A0)
00:00010E74 225F            	   598: 	MOVE.L	(SP)+,A1
00:00010E76 61000630        	   599: 	BSR	PRTSTG		print string as prompt
00:00010E7A 1082            	   600: 	MOVE.B	D2,(A0) 	restore text
00:00010E7C 2F08            	   601: IP3	MOVE.L	A0,-(SP)	save in case of error
00:00010E7E 2F3900006126    	   602: 	MOVE.L	CURRNT,-(SP)	also save 'CURRNT'
00:00010E84 23FCFFFFFFFF0000	   603: 	MOVE.L	#-1,CURRNT	flag that we are in INPUT
00:00010E8C 6126
00:00010E8E 23CF0000612E    	   604: 	MOVE.L	SP,STKINP	save the stack pointer too
00:00010E94 2F0A            	   605: 	MOVE.L	A2,-(SP)	save the variable address
00:00010E96 103C003A        	   606: 	MOVE.B	#':',D0         print a colon first
00:00010E9A 610004A4        	   607: 	BSR	GETLN		then get an input line
00:00010E9E 41F900006152    	   608: 	LEA	BUFFER,A0	point to the buffer
00:00010EA4 6100016E        	   609: 	BSR	EXPR		evaluate the input
00:00010EA8 245F            	   610: 	MOVE.L	(SP)+,A2	restore the variable address
00:00010EAA 2480            	   611: 	MOVE.L	D0,(A2) 	save value in variable
00:00010EAC 23DF00006126    	   612: 	MOVE.L	(SP)+,CURRNT	restore old 'CURRNT'
00:00010EB2 205F            	   613: 	MOVE.L	(SP)+,A0	and the old text pointer
00:00010EB4 588F            	   614: IP4	ADDQ.L	#4,SP		clean up the stack
00:00010EB6 610006F4        	   615: 	BSR	TSTC		is the next thing a comma?
00:00010EBA 2C              	   616: 	DC.B	',',IP5-*
00:00010EBB 05
00:00010EBC 6000FF8E        	   617: 	BRA	INPUT		yes, more items
00:00010EC0 6000FE10        	   618: IP5	BRA	FINISH
                            	   619: 
00:00010EC4 0C10000A        	   620: DEFLT	CMP.B	#LF,(A0)	empty line is OK
00:00010EC8 67000010        	   621: 	BEQ	LT1		else it is 'LET'
                            	   622: 
00:00010ECC 610003CE        	   623: LET	BSR	SETVAL		do the assignment
00:00010ED0 610006DA        	   624: 	BSR	TSTC		check for more 'LET' items
00:00010ED4 2C              	   625: 	DC.B	',',LT1-*
00:00010ED5 05
00:00010ED6 6000FFF4        	   626: 	BRA	LET
00:00010EDA 6000FDF6        	   627: LT1	BRA	FINISH		until we are finished.
