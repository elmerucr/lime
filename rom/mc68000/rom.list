00:00002D2E 67F0            	  6087: 	BEQ.s		RTS_023			* exit if zero
                            	  6088: 
00:00002D30 48E77800        	  6089: 	movem.l	d1-d4,-(sp)			* save registers
00:00002D34 202B0590        	  6090: 	move.l	FAC1_m(a3),d0		* copy FAC1
00:00002D38 7400            	  6091: 	moveq		#0,d2				* clear remainder
00:00002D3A 2202            	  6092: 	move.l	d2,d1				* clear root
                            	  6093: 
00:00002D3C 761F            	  6094: 	moveq		#$1F,d3			* $1F for DBF, 64 pairs of bits to
                            	  6095: 							* do for a 32 bit result
00:00002D3E 082B00000594    	  6096: 	BTST		#0,FAC1_e(a3)		* test exponent odd/even
00:00002D44 6606            	  6097: 	BNE.s		LAB_SQE2			* if odd only 1 shift first time
                            	  6098: 
