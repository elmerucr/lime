00:00011492 2F390000613E    	  1248: 	MOVE.L	LOPLN,-(SP)
00:00011498 2F390000613A    	  1249: 	MOVE.L	LOPLMT,-(SP)
00:0001149E 2F3900006136    	  1250: 	MOVE.L	LOPINC,-(SP)
