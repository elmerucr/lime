                            	  5686: 
00:00002A46 DC98            	  5687: 	ADD.l		(a0)+,d6			* z = z + arctan(i)/2pi
00:00002A48 D083            	  5688: 	ADD.l		d3,d0				* x = x + y1
00:00002A4A 9282            	  5689: 	SUB.l		d2,d1				* y = y + x1
                            	  5690: nexta
