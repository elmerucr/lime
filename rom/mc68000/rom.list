                            	  6095: 							* do for a 32 bit result
00:00002CBE 082B00000594    	  6096: 	BTST		#0,FAC1_e(a3)		* test exponent odd/even
00:00002CC4 6606            	  6097: 	BNE.s		LAB_SQE2			* if odd only 1 shift first time
                            	  6098: 
