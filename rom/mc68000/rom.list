00:000028F2 276B05900598    	  5583: 	move.l	FAC1_m(a3),FAC2_m(a3)	* copy FAC1 mantissa to FAC2 mantissa
00:000028F8 27410590        	  5584: 	move.l	d1,FAC1_m(a3)		* get COS(x) mantissa
00:000028FC 17430594        	  5585: 	move.b	d3,FAC1_e(a3)		* get COS(x) exponent
00:00002900 6700E0B0        	  5586: 	BEQ		LAB_OFER			* do overflow if COS = 0
                            	  5587: 
00:00002904 6100F7BE        	  5588: 	BSR		LAB_24D5			* normalise FAC1
00:00002908 6000F974        	  5589: 	BRA		LAB_DIVIDE			* do FAC2/FAC1 and return, FAC_sc set by SIN
                            	  5590: 							* COS calculation
