00:00011174 221F            	   898: 	MOVE.L	(SP)+,D1	get back the index
00:00011176 B081            	   899: 	CMP.L	D1,D0		see if there's enough memory
00:00011178 630001AC        	   900: 	BLS	QSORRY		if not, say "Sorry"
00:0001117C 203900006152    	   901: 	MOVE.L	VARBGN,D0	put address of array element...
00:00011182 9081            	   902: 	SUB.L	D1,D0		into D0
00:00011184 4E75            	   903: 	RTS
00:00011186 B03C001B        	   904: TV1	CMP.B	#27,D0		if not @, is it A through Z?
00:0001118A 0A3C0001        	   905: 	EOR	#1,CCR
00:0001118E 65000010        	   906: 	BCS	TSTVRT		if not, set Carry and return
00:00011192 5248            	   907: 	ADDQ	#1,A0		else bump the text pointer
